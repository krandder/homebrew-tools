<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.agent-browser</string>
  <key>ProgramArguments</key>
  <array>
    <string>__PREFIX__/run.sh</string>
  </array>
  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <true/>
  <key>StandardOutPath</key>
  <string>__PREFIX__/logs/agent-browser.log</string>
  <key>StandardErrorPath</key>
  <string>__PREFIX__/logs/agent-browser.log</string>
</dict>
</plist>
