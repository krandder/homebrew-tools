#!/bin/bash
# Put the agent browser away again: drop the .show flag and restart the
# LaunchAgent, which brings it back in headless mode (no window, no Dock icon).
set -euo pipefail
DATA_DIR="${AGENT_BROWSER_DATA_DIR:-$HOME/.agent-chrome}"
PORT="${AGENT_BROWSER_CDP_PORT:-9222}"
LABEL="${AGENT_BROWSER_LABEL:-com.agent-browser}"

rm -f "$DATA_DIR/.show"
launchctl kickstart -k "gui/$(id -u)/$LABEL"

for _ in $(seq 1 60); do
  curl -fsS "http://127.0.0.1:$PORT/json/version" >/dev/null 2>&1 && break
  sleep 0.5
done
echo "agent browser hidden (headless)"
