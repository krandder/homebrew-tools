print(json.dumps({"ts": datetime.datetime.now(datetime.timezone.utc).isoformat(),
                  "tool": "claude-token", "version": version, "host": host,
                  "profile": user, "mode": mode, "status": status}))
PY
    vault_http POST "/heartbeat/claude-token" "$tmp" >/dev/null
