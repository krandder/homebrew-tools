# ---- token proxy (per-profile fresh-token injection) ----
PROXY_REGISTRY="${CLAUDE_PROXY_REGISTRY:-$CLAUDE_TOKEN_REAL_HOME/.claude-token/proxy-ports.json}"
PROXY_PORT_BASE="${CLAUDE_PROXY_PORT_BASE:-7801}"

proxy_alive() { # base_url -> 0 if something answers HTTP on it
    command -v curl >/dev/null 2>&1 || return 1
    curl -s -o /dev/null -m 2 "$1/" 2>/dev/null
}

claude_cmd_proxy_url() { # [profile] -> base URL; assigns a stable port on first use
    if [ $# -eq 0 ]; then cat "$PROXY_REGISTRY" 2>/dev/null || echo "{}"; return 0; fi
    local p="$1"
    validate_profile_name "$p"
    mkdir -p "$(dirname "$PROXY_REGISTRY")"
    (
        flock -w 5 9 || die "proxy-url: registry lock timeout"
        python3 - "$PROXY_REGISTRY" "$p" "$PROXY_PORT_BASE" <<'PY'
import json, os, sys, tempfile
path, profile, base = sys.argv[1], sys.argv[2], int(sys.argv[3])
try:
    with open(path) as fh:
        reg = json.load(fh)
except Exception:
    reg = {}
if profile not in reg:
    used = set(reg.values())
    port = base
    while port in used:
        port += 1
    reg[profile] = port
    fd, tmp = tempfile.mkstemp(dir=os.path.dirname(path) or ".")
    with os.fdopen(fd, "w") as fh:
        json.dump(reg, fh, indent=1, sort_keys=True)
        fh.write("\n")
    os.chmod(tmp, 0o600)
    os.replace(tmp, path)
print("http://127.0.0.1:%d" % reg[profile])
PY
    ) 9>"$PROXY_REGISTRY.lock"
}

proxy_runtime() { # prefer bun (matches claude.real's TLS/HTTP stack), fall back to node
    local c found=""
    for c in ${CLAUDE_PROXY_RUNTIME:-} "$CLAUDE_TOKEN_REAL_HOME/.bun/bin/bun" "$CLAUDE_TOKEN_REAL_HOME/bin/bun" $(command -v bun 2>/dev/null) "$CLAUDE_TOKEN_REAL_HOME/.local/bin/node" "$CLAUDE_TOKEN_REAL_HOME/bin/node" $(command -v node 2>/dev/null) $CLAUDE_TOKEN_REAL_HOME/.nvm/versions/node/*/bin/node; do
        if [ -z "$found" ] && [ -n "$c" ] && [ -x "$c" ]; then found="$c"; fi
    done
    [ -n "$found" ] || return 1
    echo "$found"
}

claude_cmd_proxy() { # run the proxy (foreground; normally via systemd --user)
    local rt js tmp
    rt="$(proxy_runtime)" || die "proxy: no JS runtime found (need bun or node)"
    js="$CLAUDE_TOKEN_REAL_HOME/.claude-token/proxy.mjs"
    mkdir -p "$(dirname "$js")"
    tmp="$(mktemp)"
    cat > "$tmp" <<'JS'
// claude-token proxy — per-profile fresh-token injection (JS runtime edition).
// Each request is forwarded to api.anthropic.com with the freshest published
// accessToken injected as Authorization: Bearer (client authorization and
// x-api-key headers are stripped). Running under bun/node keeps the upstream
// TLS/HTTP fingerprint in the same family as Claude Code's own runtime.
import http from "node:http";
import { readFileSync } from "node:fs";

const [registryPath, sharedDir] = process.argv.slice(2);
const UPSTREAM = process.env.CLAUDE_PROXY_UPSTREAM || "https://api.anthropic.com";
const HOP_BY_HOP = new Set([
  "connection", "keep-alive", "proxy-authenticate", "proxy-authorization",
  "te", "trailer", "trailers", "transfer-encoding", "upgrade",
]);

function loadRegistry() {
  try { return JSON.parse(readFileSync(registryPath, "utf8")); } catch { return {}; }
}

function tokenFor(profile) {
  try {
    const d = JSON.parse(readFileSync(`${sharedDir}/${profile}.json`, "utf8"));
    return (d.claudeAiOauth || d).accessToken || null;
  } catch { return null; }
}

function log(profile, method, path, status) {
  const ts = new Date().toISOString().replace("T", " ").slice(0, 19);
  console.log(`${ts} ${profile} ${method} ${path} -> ${status}`);
}

async function handle(profile, req, res) {
  const token = tokenFor(profile);
  if (!token) {
    const body = JSON.stringify({
      type: "error",
      error: { type: "authentication_error", message: "token proxy: no published token for profile" },
    });
    res.writeHead(502, { "content-type": "application/json", "content-length": Buffer.byteLength(body) });
    res.end(body);
    log(profile, req.method, req.url, 502);
    return;
  }
  const chunks = [];
  for await (const chunk of req) chunks.push(chunk);
  const body = chunks.length ? Buffer.concat(chunks) : undefined;
  const headers = {};
  for (const [k, v] of Object.entries(req.headers)) {
    const lk = k.toLowerCase();
    if (HOP_BY_HOP.has(lk) || lk === "authorization" || lk === "x-api-key" || lk === "host" || lk === "content-length") continue;
    headers[lk] = v;
  }
  headers["authorization"] = `Bearer ${token}`;
  let up;
  try {
    up = await fetch(UPSTREAM + req.url, { method: req.method, headers, body, redirect: "manual" });
  } catch (err) {
    const msg = `token proxy: upstream error: ${err.message}`;
    res.writeHead(502, { "content-type": "text/plain", "content-length": Buffer.byteLength(msg) });
    res.end(msg);
    log(profile, req.method, req.url, "502-upstream");
    return;
  }
  const outHeaders = {};
  up.headers.forEach((v, k) => {
    const lk = k.toLowerCase();
    // fetch() already decoded the body: never forward the original framing
    // or content-encoding, or the client would try to decompress plain bytes.
    if (HOP_BY_HOP.has(lk) || lk === "content-length" || lk === "content-encoding") return;
    outHeaders[lk] = v;
  });
  res.writeHead(up.status, outHeaders);
  if (req.method === "HEAD" || up.status === 204 || up.status === 304 || !up.body) {
    res.end();
  } else {
    for await (const chunk of up.body) {
      if (!res.write(chunk)) await new Promise((resolve) => res.once("drain", resolve));
    }
    res.end();
  }
  log(profile, req.method, req.url, up.status);
}

const servers = new Map();
function ensureListeners() {
  for (const [profile, portRaw] of Object.entries(loadRegistry())) {
    const port = Number(portRaw);
    if (!Number.isInteger(port) || servers.has(port)) continue;
    const server = http.createServer((req, res) => {
      handle(profile, req, res).catch((err) => {
        try {
          const msg = `token proxy: handler error: ${err.message}`;
          if (res.headersSent) {
            res.destroy(err);
          } else {
            res.writeHead(502, { "content-type": "text/plain", "content-length": Buffer.byteLength(msg) });
            res.end(msg);
          }
        } catch {}
        log(profile, req.method, req.url, "502-handler");
      });
    });
    server.listen(port, "127.0.0.1", () => console.log(`claude-token proxy: ${profile} on 127.0.0.1:${port}`));
    servers.set(port, server);
  }
}

ensureListeners();
setInterval(ensureListeners, 5000);
JS
    if cmp -s "$tmp" "$js" 2>/dev/null; then rm -f "$tmp"; else mv "$tmp" "$js"; fi
    log_event proxy "" start "runtime=$rt registry=$PROXY_REGISTRY"
    exec "$rt" "$js" "$PROXY_REGISTRY" "$CLAUDE_SHARED_DIR"
}

claude_cmd_proxy_install() {
    [ "$(uname)" = Linux ] || die "proxy-install: requires Linux (systemd --user)"
    need_cmd systemctl
    local bin unit_dir unit
    bin="$AI_TOKEN_SELF"
    unit_dir="$CLAUDE_TOKEN_REAL_HOME/.config/systemd/user"
    unit="$unit_dir/claude-token-proxy.service"
    mkdir -p "$unit_dir"
    cat > "$unit" <<EOF
[Unit]
Description=claude-token proxy (per-profile fresh OAuth token injection)
After=network-online.target

[Service]
Environment=PATH=$(dirname "$bin"):/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin
ExecStart=$bin claude proxy
Restart=always
RestartSec=2

[Install]
WantedBy=default.target
EOF
    systemctl --user daemon-reload
    systemctl --user enable --now claude-token-proxy.service >/dev/null 2>&1 || true
    systemctl --user restart claude-token-proxy.service
    say "token proxy installed (systemd --user, claude-token-proxy.service)"
    say "registry: $(cat "$PROXY_REGISTRY" 2>/dev/null || echo '{}')"
}

claude_cmd_install_profile_wrapper() { # profile — standard wrapper with proxy auth
    local p="${1:-}" w backup bin
    validate_profile_name "$p"
    bin="$(shell_quote "$AI_TOKEN_SELF")"
    w="$CLAUDE_TOKEN_REAL_HOME/.local/bin/claude-$p"
    if [ -e "$w" ]; then
        backup="$w.bak-$(date +%Y%m%dT%H%M%S)"
        cp "$w" "$backup"
        say "backed up existing -> $backup"
    fi
    mkdir -p "$(dirname "$w")"
    cat > "$w" <<EOF
#!/bin/bash
# Claude wrapper - $p profile (generated by claude-token install-profile-wrapper)

# hub-q82x: keep TypeScript tooling on polling watchers (zero inotify).
export TSC_WATCHFILE=DynamicPriorityPolling
export TSC_WATCHDIRECTORY=RecursiveDirectoryUsingDynamicPriorityPolling

REAL_HOME="\${HOME%/.claude-profiles/$p}"
PROFILE_HOME="\$REAL_HOME/.claude-profiles/$p"
mkdir -p "\$PROFILE_HOME"
export CLAUDE_CONFIG_DIR="\$REAL_HOME/.claude"

# Auth goes through claude-token proxy: the freshest vault-published token is
# injected on every request, so sessions never hold a real token.
export ANTHROPIC_BASE_URL="\$($bin claude proxy-url $p)"
export ANTHROPIC_AUTH_TOKEN=token-proxy-managed
export CLAUDE_PROFILE=$p

CLAUDE_BIN="\$REAL_HOME/bin/claude.real"
[ -x "\$CLAUDE_BIN" ] || CLAUDE_BIN="\$(command -v claude 2>/dev/null || true)"
[ -x "\$CLAUDE_BIN" ] || CLAUDE_BIN="\$(ls -d "\$REAL_HOME"/.nvm/versions/node/*/bin/claude 2>/dev/null | sort -V | tail -1)"
[ -x "\$CLAUDE_BIN" ] || { echo "claude binary not found" >&2; exit 127; }

exec env HOME="\$PROFILE_HOME" "\$CLAUDE_BIN" "\$@"
EOF
    chmod +x "$w"
    say "installed $w (auth: $(claude_cmd_proxy_url "$p"))"
}

claude_dispatch() {
    [ $# -eq 0 ] && { claude_cmd_print; exit 0; }
    case "$1" in
    publish) shift; while [ $# -gt 0 ]; do case "$1" in --profile|-p) PROFILE="$2"; shift 2;; --all|-a) ALL=1; shift;; *) die "unknown arg: $1";; esac; done; claude_cmd_publish;;
    pull)    shift; while [ $# -gt 0 ]; do case "$1" in --profile|-p) PROFILE="$2"; shift 2;; *) PROFILE="$1"; shift;; esac; done; claude_cmd_pull;;
    push)    shift; while [ $# -gt 0 ]; do case "$1" in --profile|-p) PROFILE="$2"; shift 2;; *) PROFILE="$1"; shift;; esac; done; claude_cmd_push;;
    sync)    shift; while [ $# -gt 0 ]; do case "$1" in --profile|-p) PROFILE="$2"; shift 2;; *) PROFILE="$1"; shift;; esac; done; claude_cmd_sync;;
    heartbeat) shift; claude_cmd_heartbeat "${1:-manual}";;
    maintain) shift; claude_cmd_maintain;;
    install-maintenance) shift; [ $# -eq 0 ] || die "install-maintenance: no arguments expected"; claude_cmd_install_maintenance;;
    setup-owner) shift; [ $# -eq 1 ] || die "setup-owner: specify one profile name"; claude_cmd_setup_owner "$1";;
    push-logs|logs-push) shift; claude_cmd_push_logs "$@";;
    check)   claude_cmd_check;;
    status)  claude_cmd_status;;
    pair|setup) shift; while [ $# -gt 0 ]; do case "$1" in --user|-u) CODEX_USER="$2"; shift 2;; --owner|--no-wrapper) PAIR_MODE=owner; shift;; --follower) PAIR_MODE=follower; shift;; *) CODEX_USER="$1"; shift;; esac; done; claude_cmd_pair;;
    add-follower) shift; [ $# -eq 1 ] || die "add-follower: specify one profile name"; claude_cmd_add_follower "$1";;
    install-follower-wrapper) shift; [ $# -eq 1 ] || die "install-follower-wrapper: specify one profile name"; claude_cmd_reinstall_follower_wrapper "$1";;
    repair-follower-wrappers) shift; [ $# -eq 0 ] || die "repair-follower-wrappers: no arguments expected"; claude_cmd_repair_follower_wrappers;;
    run-follower) shift; claude_cmd_run_follower "$@";;
    login)   shift; claude_cmd_login "$@";;
    run)     shift; claude_cmd_run "$@";;
    go-live) shift; claude_cmd_go_live "$@";;
    install-wrapper) claude_cmd_install_wrapper;;
    proxy) shift; [ $# -eq 0 ] || die "proxy: no arguments expected"; claude_cmd_proxy;;
    proxy-url) shift; claude_cmd_proxy_url "$@";;
    proxy-install) shift; [ $# -eq 0 ] || die "proxy-install: no arguments expected"; claude_cmd_proxy_install;;
    install-profile-wrapper) shift; [ $# -eq 1 ] || die "install-profile-wrapper: specify one profile name"; claude_cmd_install_profile_wrapper "$1";;
    set-url)   shift; claude_cmd_set_url "$@";;
    set-token) shift; claude_cmd_set_token "$@";;
    set-mode)  shift; claude_cmd_set_mode "$@";;
    --diagnose|--diagnostics|--debug) claude_cmd_diagnose;;
    --version|-v) echo "claude-token $VERSION";;
    --help|-h) sed -n '2,/^$/p' "$0" | sed 's/^# *//';;
    *) die "unknown command: $1 (see --help)";;
    esac
    exit 0
}

# ---- dispatch ----
case "$TOOL" in
    claude) claude_dispatch "$@" ;;
    kimi)   kimi_dispatch "$@" ;;
    codex)  codex_dispatch "$@" ;;
    *)      die "unknown backend '$TOOL'" ;;
esac
