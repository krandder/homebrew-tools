# One-shot bootstrap to "go live" on this machine: push the local real refresh
# token to the leader (making the leader the sole owner), then install the
# wrapper so plain `claude` runs transparently via the broker. After this, the
# local keychain refresh token is inert (sentinel) and Claude Code runs on
# broker-served access tokens — install-and-forget.
claude_cmd_go_live() {
    local user; user="$(config_user)"; [ -n "$user" ] || die "go-live: run 'claude-token pair --user <name>' first"
    local oauth rt
    oauth="$(read_oauth_json 2>/dev/null)" || die "go-live: no local Claude creds — run 'claude login' first"
    rt="$(printf '%s' "$oauth" | python3 -c 'import json,sys;print(json.load(sys.stdin).get("refreshToken",""))' 2>/dev/null)"
    [ -n "$rt" ] && [ "$rt" != "$SENTINEL_RT" ] || die "go-live: no real refresh token locally (already a follower?) — run 'claude login' first"
    say "WARNING: go-live is a legacy handoff and will demote local Claude credentials"
    say "go-live: pushing your Claude token to the leader as '$user'..."
    claude_push_profile "$user" || die "go-live: push failed (leader unreachable or rate-limited — retry later)"
    claude_cmd_install_wrapper
    say "go-live complete. Plain 'claude' now runs via the broker. Leader: $LEADER_HOST"
}

claude_cmd_publish() {
    local p="${PROFILE:-}"
    [ "$(config_mode)" != owner ] || die "publish is disabled in owner mode; use native Claude refresh and 'claude-token sync'"
    if [ "${ALL:-0}" = 1 ]; then
        for p in $(ls "$CLAUDE_PROFILES_DIR" 2>/dev/null); do ( claude_publish_profile "$p" ) || say "  (skipped $p)"; done
    else
        [ -n "$p" ] || p="$(config_user)"; [ -n "$p" ] || die "publish: specify --profile <name> or --all"
        claude_publish_profile "$p"
    fi
}
claude_cmd_pull() {
    local p="${PROFILE:-$(config_user)}" mode local_mode o
    [ -n "$p" ] || die "pull: specify --profile <name>"
    mode="$(config_mode)"; local_mode="$(claude_local_refresh_mode)"
    case "$mode" in auto|owner|follower) ;; *) die "invalid mode '$mode' (expected auto, owner, or follower)" ;; esac
    if [ "$mode" = owner ] || [ "$local_mode" = owner ]; then
        die "pull is disabled for an owner login; local Claude credentials unchanged"
    fi
    o="$(claude_pull_profile "$p")"
    write_oauth_json "$o"
    say "pulled fresh follower credentials for '$p' into the local store"
}
claude_cmd_push() {
    local p="${PROFILE:-$(config_user)}"
    [ -n "$p" ] || die "push: specify --profile <name>"
    say "WARNING: legacy push hands refresh ownership to the vault and demotes local Claude credentials"
    say "Use 'claude-token sync --profile $p' to copy credentials without changing local Claude"
    claude_push_profile "$p"
}
