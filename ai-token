claude_pull_profile() { # profile -> local store
    local p="$1" sf tmp=""
    log_event pull "$p" start ""
    sf="$(claude_shared_file "$p")"
    if [ -f "$sf" ] && [ -n "$(claude_fresh_access_from_file "$sf" 2>/dev/null || true)" ]; then
        : # fast path: syncthing mesh
    elif have_http_vault; then
        say "pulling '$p' from $(vault_url) (HTTPS, ACL-gated)..."
        log_event pull "$p" http "$(vault_url)"
        tmp="$(mktemp)"; vault_http GET "/pull/claude/$p" > "$tmp" || { rm -f "$tmp"; die "pull: vault denied/unavailable for '$p'"; }
        sf="$tmp"
    else
        need_cmd ssh; tmp="$(mktemp)"
        say "pulling '$p' from leader $LEADER_HOST (vault, ACL-gated)..."
        ssh_vault "ai-vault serve claude:$p" > "$tmp" || { rm -f "$tmp"; die "pull: leader denied/unavailable for '$p'"; }
        sf="$tmp"
    fi
    set +e
    python3 - "$sf" <<'PY'
import json, os, sys, time
d=json.load(open(sys.argv[1])); o=d.get("claudeAiOauth",d)
if not o.get("accessToken"): sys.exit("pull: no accessToken in published token")
try:
    now=float(os.environ.get("AI_TOKEN_TEST_NOW") or time.time())
    fresh=float(o.get("expiresAt") or 0)/1000 > now+60
except Exception:
    fresh=False
if not fresh: sys.exit("pull: published access token is stale")
print(json.dumps(o))
PY
    local rc=$?
    set -e
    [ -z "$tmp" ] || rm -f "$tmp"
    [ "$rc" -eq 0 ] || return "$rc"
    log_event pull "$p" ok "token-json"
}

claude_push_profile() { # profile -> leader (then revert local to sentinel)
    local p="$1" oauth rt
    log_event push "$p" start ""
    oauth="$(read_oauth_json)" || die "push: no local Claude creds found"
    rt="$(echo "$oauth" | python3 -c 'import json,sys;print(json.load(sys.stdin).get("refreshToken",""))')"
    [ -n "$rt" ] || die "push: no refreshToken locally"
    [ "$rt" = "$SENTINEL_RT" ] && die "push: only sentinel token present (already a follower). Run 'claude-token login' first."
    if have_http_vault; then
        say "pushing '$p' to $(vault_url) (HTTPS)..."
        printf '%s' "$oauth" | vault_http POST "/push/claude/$p" /dev/stdin >/dev/null || { log_event push "$p" failed "http-rejected"; die "push: leader rejected '$p'"; }
    else
        need_cmd ssh
        say "pushing '$p' to leader $LEADER_HOST (vault/SSH)..."
        printf '%s\n' "$oauth" | ssh_vault "ai-vault receive claude:$p" || { log_event push "$p" failed "ssh-rejected"; die "push: leader rejected '$p'"; }
    fi
    # revert local store to follower (sentinel RT), then pull fresh
    local follower; follower="$(echo "$oauth" | python3 -c 'import json,sys;o=json.load(sys.stdin);o["refreshToken"]="'$SENTINEL_RT'";print(json.dumps(o))')"
    write_oauth_json "$follower"
    local fresh; fresh="$(claude_pull_profile "$p" 2>/dev/null || true)"; [ -n "$fresh" ] && write_oauth_json "$fresh"
    say "reverted '$p' to follower (sentinel token)"
    log_event push "$p" ok "reverted-local-to-follower"
}

claude_sync_profile() { # profile -> leader; never changes local credentials
    local p="$1" oauth rt
    log_event sync "$p" start ""
    oauth="$(read_oauth_json)" || die "sync: no local Claude credentials found"
    rt="$(printf '%s' "$oauth" | python3 -c 'import json,sys;print(json.load(sys.stdin).get("refreshToken", ""))')"
    [ -n "$rt" ] || die "sync: no refreshToken locally"
    case "$rt" in "$SENTINEL_RT"|vlt:*) die "sync: local credentials are a follower token, not an owner login" ;; esac
    if have_http_vault; then
        printf '%s' "$oauth" | vault_http POST "/sync/claude/$p" /dev/stdin >/dev/null \
            || { say "sync failed; local Claude credentials unchanged (retry: claude-token sync --profile $p)"; log_event sync "$p" failed "http-rejected"; return 1; }
    else
        need_cmd ssh
        printf '%s\n' "$oauth" | ssh_vault "ai-vault sync-receive claude:$p" >/dev/null \
            || { say "sync failed; local Claude credentials unchanged (retry: claude-token sync --profile $p)"; log_event sync "$p" failed "ssh-rejected"; return 1; }
    fi
    say "synced '$p' to the vault; local Claude credentials unchanged"
    log_event sync "$p" ok "local-unchanged"
}

