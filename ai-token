claude_cmd_check() {
    local oauth
    oauth="$(read_oauth_json 2>/dev/null)" || { echo "missing: no Claude credentials found"; return 1; }
    printf '%s' "$oauth" | python3 -c '
import json, os, sys, time

sentinel = sys.argv[1]
try:
    oauth = json.load(sys.stdin)
except Exception:
    print("missing: credentials are not valid JSON")
    sys.exit(1)

access = oauth.get("accessToken") or ""
refresh = oauth.get("refreshToken") or ""
missing = []
if not access:
    missing.append("accessToken")
if not refresh:
    missing.append("refreshToken")
if missing:
    print("missing: " + ", ".join(missing))
    sys.exit(1)

exp = oauth.get("expiresAt") or 0
try:
    now = float(os.environ.get("AI_TOKEN_TEST_NOW") or time.time())
    seconds = float(exp) / 1000 - now
except Exception:
    seconds = -1
follower = refresh == sentinel or refresh.startswith("vlt:")
if seconds <= 60:
    if follower:
        print("stale: follower access token expired; the owner must sync fresh credentials to Farol")
        sys.exit(1)
    print("ok: owner refreshToken present; access token needs native refresh (run plain claude)")
    sys.exit(0)
ttl = f", expires in {seconds / 3600:.1f}h"
mode = "sentinel refreshToken (follower)" if follower else "owner refreshToken present"
print(f"ok: valid JSON, accessToken present, {mode}{ttl}")
' "$SENTINEL_RT"
}

claude_cmd_status() {
    say "machine: $(short_host)   leader: $LEADER_HOST"
    echo "  mode: configured=$(config_mode)  local=$(claude_local_refresh_mode)"
    local oauth email exp
    if oauth="$(read_oauth_json 2>/dev/null)"; then
        email="$(echo "$oauth" | python3 -c 'import json,sys;print(json.load(sys.stdin).get("subscriptionType","?"))' 2>/dev/null)"
        exp="$(echo "$oauth" | python3 -c 'import json,sys,time;o=json.load(sys.stdin);e=o.get("expiresAt",0);print(round((e/1000-time.time())/3600,1),"h" if e else "?")' 2>/dev/null)"
        local rt; rt="$(echo "$oauth" | python3 -c 'import json,sys;print(json.load(sys.stdin).get("refreshToken",""))')"
        local state
        case "$rt" in
            "$SENTINEL_RT"|vlt:*) state="sentinel (follower)" ;;
            "") state="missing" ;;
            *) state="REAL (owner/standalone)" ;;
        esac
        echo "  active: plan=$email  access valid: $exp  rt=$state"
    else
        echo "  active: (no creds)"
    fi
    local p
    local p m
    for p in $(ls "$CLAUDE_PROFILES_DIR" 2>/dev/null); do
        m=""
        [ "$(claude_needs_relogin_marker "$(claude_canonical_file "$p")")" = yes ] && m="  *** NEEDS RE-LOGIN (owner must sync fresh creds) ***"
        echo "  profile: $p$m"
    done
}

claude_cmd_pair() {  # [--user NAME] — magical onboarding: print a code, poll until approved, auto-configure
    local user="${CODEX_USER:-}" mode="${PAIR_MODE:-auto}"
    while [ -z "$user" ]; do read -rp "Your username on the vault: " user; done
    mkdir -p "$VAULT_DIR_CLIENT"
    local url; url="${CLAUDE_VAULT_URL:-$(vault_url 2>/dev/null)}"
    [ -n "$url" ] || url="https://vault.ekelvin.com"
    set_config url "$url"; set_config user "$user"; set_config mode "$mode"
    need_cmd curl
    # generate a short pairing code + a long secret
    local code secret sh
    code="$(python3 -c 'import secrets,string;print("".join(secrets.choice(string.ascii_uppercase+string.digits) for _ in range(8)))')"
    secret="$(python3 -c 'import secrets;print(secrets.token_urlsafe(32))')"
    sh="$(python3 -c 'import hashlib,sys;print(hashlib.sha256(sys.argv[1].encode()).hexdigest())' "$secret")"
    # post the pairing request
    curl -fsS -X POST "$url/pair" -H "Content-Type: application/json" \
        -d "{\"user\":\"$user\",\"code\":\"$code\",\"secret_hash\":\"$sh\"}" >/dev/null \
        || die "pair: cannot reach $url (is it correct?)"
    cat <<EOF

Pairing as '$user' against $url

   Pairing code:  $code

Ask the operator to approve it on the leader (farol):

   ai-vault pair-approve $code

Waiting for approval — this auto-completes (timeout 5 min)...
EOF
    # poll until approved / timeout
    local i status token
    for i in $(seq 1 60); do
        sleep 5
        local resp; resp="$(curl -fsS -X POST "$url/pair/$code/poll" -H "Content-Type: application/json" \
            -d "{\"secret\":\"$secret\"}" 2>/dev/null || echo '{}')"
        status="$(printf '%s' "$resp" | python3 -c 'import json,sys;print(json.load(sys.stdin).get("status",""))' 2>/dev/null)"
        [ "$status" = "approved" ] && { token="$(printf '%s' "$resp" | python3 -c 'import json,sys;print(json.load(sys.stdin).get("token",""))' 2>/dev/null)"; break; }
        { [ "$status" = "unknown" ] || [ "$status" = "expired" ]; } && die "pair: pairing $status before approval — please retry."
        printf "." >&2
    done
    [ "$status" = "approved" ] || die "pair: timed out waiting for approval. Re-run when the operator is ready."
    set_config token "$token"
    local local_mode=missing
    [ "$mode" = follower ] || local_mode="$(claude_local_refresh_mode)"
    if [ "$mode" = owner ] || { [ "$mode" = auto ] && [ "$local_mode" = owner ]; }; then
        say "native owner path selected; plain 'claude' was not changed"
    elif [ "${PAIR_SKIP_WRAPPER:-0}" = 1 ]; then
        say "named follower selected; plain 'claude' was not changed"
    else
        claude_cmd_install_wrapper
    fi
    if [ "$mode" = follower ]; then
        say "follower pairing complete; local Claude credentials were not read or changed"
    else
        # Owner/auto pairing may publish an existing native login, but never
        # changes it. Follower pairing must not inspect the macOS Keychain.
        local oauth rt
        oauth="$(read_oauth_json 2>/dev/null || true)"
        rt="$(printf '%s' "$oauth" | python3 -c 'import json,sys;print(json.load(sys.stdin).get("refreshToken",""))' 2>/dev/null || true)"
        if [ -n "$rt" ] && [ "$rt" != "$SENTINEL_RT" ]; then
            say "local login found — syncing without changing it..."
            ( claude_sync_profile "$user" ) || say "sync deferred; retry with: claude-token sync --profile $user"
        else
            say "no local owner login yet — run 'claude-token login' after pairing."
        fi
    fi
    echo >&2
    say "paired as '$user' in $mode mode."
}

claude_cmd_login() {
    local user; user="$(config_user)"
    local bin; bin="$(resolve_claude_bin)"; [ -n "$bin" ] || die "login: claude binary not found"
    log_event login "$user" start "$bin"
    say "starting native Claude browser login..."
    local rc=0
    set +e
    "$bin" auth login "$@"
    rc=$?
    set -e
    if [ "$rc" -ne 0 ]; then
        log_event login "$user" failed "claude_rc=$rc"
        return "$rc"
    fi
    local oauth rt
    oauth="$(read_oauth_json 2>/dev/null)" || { log_event login "$user" failed no-readable-creds; die "login completed, but no credentials were readable"; }
    rt="$(printf '%s' "$oauth" | python3 -c 'import json,sys;print(json.load(sys.stdin).get("refreshToken",""))')"
    if [ -n "$rt" ] && [ "$rt" != "$SENTINEL_RT" ]; then
        if [ -n "$user" ]; then
            ( claude_sync_profile "$user" ) || say "login succeeded; vault sync deferred (retry: claude-token sync --profile $user)"
        else
            say "vault sync skipped; configure a user later with 'claude-token pair --user NAME --owner'"
        fi
        say "native Claude login is active locally"
        log_event login "$user" ok "local-active"
    else
        say "logged in (no refresh token to push)."
        log_event login "$user" ok "no-refresh-token"
    fi
}

claude_cmd_run() { # [claude args...]  — follower launcher; falls back to normal claude if no fresh broker token
    local isolated="${CLAUDE_TOKEN_ISOLATED_FOLLOWER:-0}"
    if [ "$isolated" = 1 ]; then
        case "${1:-}" in
            login|logout|auth|setup-token) die "named followers cannot change login state; authenticate on the owner machine" ;;
        esac
    fi
    # `claude login` -> login (browser) + auto-push the refresh token to the leader
    if [ "$isolated" != 1 ] && [ "${1:-}" = login ]; then shift; claude_cmd_login "$@"; return $?; fi
    if [ "$isolated" != 1 ] && [ "${1:-}" = auth ] && [ "${2:-}" = login ]; then shift 2; claude_cmd_login "$@"; return $?; fi
    local user; user="$(config_user)"
    local bin; bin="$(resolve_claude_bin)"; [ -n "$bin" ] || die "run: claude binary not found"
    case "${1:-}" in auth|setup-token) exec "$bin" "$@" ;; esac
    # If no user configured, just run claude normally (standalone).
    [ -n "$user" ] || exec "$bin" "$@"

    # Owner machines always use Claude's native login and refresh path. Auto mode
    # protects existing standalone installs that already hold a real refresh token.
    local mode local_mode
    mode="$(config_mode)"; [ -n "$mode" ] || mode=auto
    if [ "$isolated" = 1 ]; then local_mode=follower; else local_mode="$(claude_local_refresh_mode)"; fi
    case "$mode" in auto|owner|follower) ;; *) die "invalid mode '$mode' (expected auto, owner, or follower)" ;; esac
    if [ "$isolated" != 1 ] && { [ "$mode" = owner ] || [ "$local_mode" = owner ]; }; then
        log_event run "$user" native "mode=$mode local=$local_mode"
        exec "$bin" "$@"
    fi

    local sf="$CLAUDE_SHARED_DIR/$user.json" access=""
    # 1. Syncthing shared file, validated from its expiresAt metadata. Claude
    # OAuth access tokens are opaque and cannot be decoded as JWTs.
    if [ -f "$sf" ]; then
        access="$(claude_fresh_access_from_file "$sf" 2>/dev/null || true)"
    fi
    # 2. Pull the broker's JSON so this client can validate freshness itself.
    if [ -z "$access" ] && have_http_vault; then
        local tmp
        tmp="$(mktemp)"
        if vault_http GET "/pull/claude/$user" > "$tmp" 2>/dev/null; then
            access="$(claude_fresh_access_from_file "$tmp" 2>/dev/null || true)"
        fi
        rm -f "$tmp"
    fi
    if [ -z "$access" ] && ! have_http_vault; then
        local tmp
        tmp="$(mktemp)"
        if ssh_vault "ai-vault serve claude:$user" > "$tmp" 2>/dev/null; then
            access="$(claude_fresh_access_from_file "$tmp" 2>/dev/null || true)"
        fi
        rm -f "$tmp"
    fi
    # If we have a fresh broker/shared token, keep Claude in the caller's normal
    # HOME and select only the account through environment credentials.
    # Otherwise -> fall through to normal claude (uses the local keychain/login).
    if [ -n "$access" ]; then
        if [ "$isolated" = 1 ]; then
            unset ANTHROPIC_API_KEY ANTHROPIC_AUTH_TOKEN CLAUDE_CODE_OAUTH_TOKEN
        fi
        # Prefer a local token proxy: the process then never holds the token,
        # so access-token expiry can no longer kill the session. Fall back to
        # env injection when no proxy is listening (install: claude-token
        # proxy-install). API traffic still goes direct to Anthropic; the
        # proxy only injects the freshest token, per request, on localhost.
        local proxy_url=""
        if proxy_url="$(claude_cmd_proxy_url "$user" 2>/dev/null)" && [ -n "$proxy_url" ] && proxy_alive "$proxy_url"; then
            export ANTHROPIC_BASE_URL="$proxy_url"
            export ANTHROPIC_AUTH_TOKEN="token-proxy-managed"
            export CLAUDE_PROFILE="$user"
            log_event run "$user" proxy "base_url=$proxy_url"
            exec "$bin" "$@"
        fi
        export ANTHROPIC_AUTH_TOKEN="$access"
        export CLAUDE_CODE_OAUTH_TOKEN="$access"
        exec "$bin" "$@"
    fi
    if [ "$local_mode" = follower ] || [ "$mode" = follower ]; then
        die "no fresh follower token for '$user'; local credentials were not changed"
    fi
    # Fallback: run claude normally (keychain OAuth mode — connectors work, standalone).
    exec "$bin" "$@"
}

claude_cmd_install_wrapper() {
    mkdir -p "$HOME/bin"
    local w="$HOME/bin/claude" bin
    bin="$(shell_quote "$AI_TOKEN_SELF")"
    [ -e "$w" ] && [ ! -e "$w.pre-claude-token" ] && { mv "$w" "$w.pre-claude-token"; say "backed up existing -> $w.pre-claude-token"; }
    cat > "$w" <<EOF
#!/usr/bin/env bash
exec $bin claude run "\$@"
EOF
    chmod +x "$w"
    say "installed $w -> ai-token claude run"
}

named_wrapper_dir() {
    local d="${CLAUDE_TOKEN_WRAPPER_DIR:-}" command_path
    if [ -z "$d" ]; then
        command_path="$(command -v claude-token 2>/dev/null || true)"
        [ -z "$command_path" ] || d="$(dirname "$command_path")"
    fi
    [ -n "$d" ] && [ -w "$d" ] || d="$CLAUDE_TOKEN_REAL_HOME/bin"
    echo "$d"
}
claude_cmd_install_follower_wrapper() { # profile
    local p="$1" dir w existing
    validate_profile_name "$p"
    if [ -n "${CLAUDE_TOKEN_WRAPPER_DIR:-}" ]; then
        dir="$(named_wrapper_dir)"; mkdir -p "$dir"; w="$dir/claude-$p"
    else
        existing="$(command -v "claude-$p" 2>/dev/null || true)"
        if [ -n "$existing" ] && [ -w "$(dirname "$existing")" ]; then
            w="$existing"; dir="$(dirname "$w")"
        else
            dir="$(named_wrapper_dir)"; mkdir -p "$dir"; w="$dir/claude-$p"
        fi
    fi
    write_follower_wrapper "$p" "$w"
    remove_shadowing_aliases "$p"
    claude_cmd_install_maintenance
    case ":$PATH:" in *":$dir:"*) ;; *) say "add $dir to PATH before running claude-$p" ;; esac
}
configure_follower_permissions() { # profile
    local p="$1" answer="${CLAUDE_TOKEN_FULL_PERMISSIONS:-}"
    [ -n "$answer" ] || [ -z "$(config_full_permissions)" ] || return 0
    if [ -z "$answer" ]; then
        [ -t 0 ] || return 0
        printf "Give claude-%s full permissions (equivalent to --dangerously-skip-permissions)? [y/N] " "$p" >&2
        IFS= read -r answer
    fi
    case "$answer" in y|Y|yes|YES) set_config full_permissions yes ;; *) set_config full_permissions no ;; esac
}
write_follower_wrapper() { # profile path
    local p="$1" w="$2" marker="# generated by claude-token named follower" backup bin invocation
    bin="$(shell_quote "$AI_TOKEN_SELF")"
    invocation="exec $bin claude run-follower \"$p\" \"\$@\""
    mkdir -p "$(dirname "$w")"
    if [ -e "$w" ] && grep -qF "$marker" "$w" 2>/dev/null \
        && grep -qF "$invocation" "$w" 2>/dev/null; then
        return
    fi
    if [ -e "$w" ] && ! grep -qF "$marker" "$w" 2>/dev/null; then
        backup="$w.pre-claude-token"
        [ ! -e "$backup" ] || backup="$backup.$(date +%s).$$"
        mv "$w" "$backup"
        say "backed up existing -> $backup"
    fi
    cat > "$w" <<EOF
#!/usr/bin/env bash
$marker
$invocation
EOF
    chmod +x "$w"
    say "installed $w"
}
remove_shadowing_aliases() { # profile
    local p="$1" rc backup
    for rc in "$CLAUDE_TOKEN_REAL_HOME/.zshrc" "$CLAUDE_TOKEN_REAL_HOME/.bashrc" "$CLAUDE_TOKEN_REAL_HOME/.bash_profile"; do
        [ -f "$rc" ] || continue
        backup="$(python3 - "$rc" "claude-$p" <<'PY'
import os, re, shutil, sys, time
path, name = sys.argv[1:]
lines = open(path).readlines()
kept = [line for line in lines if not re.match(r"^\s*alias\s+" + re.escape(name) + r"=", line)]
if kept != lines:
    backup = f"{path}.pre-claude-token.{int(time.time())}"
    shutil.copy2(path, backup)
    with open(path, "w") as fh:
        fh.writelines(kept)
    print(backup)
PY
        )"
        [ -z "$backup" ] || say "removed shadowing alias from $rc (backup: $backup)"
    done
}
claude_cmd_add_follower() { # profile
    local p="${1:-}"
    use_follower_context "$p"
    PAIR_MODE=follower
    PAIR_SKIP_WRAPPER=1
    claude_cmd_pair
    configure_follower_permissions "$p"
    claude_cmd_install_follower_wrapper "$p"
    say "named follower ready: claude-$p"
}
claude_cmd_reinstall_follower_wrapper() { # profile
    local p="${1:-}" main_config="$CONFIG_FILE" follower_config
    validate_profile_name "$p"
    follower_config="${CLAUDE_FOLLOWERS_DIR:-$CLAUDE_TOKEN_REAL_HOME/.claude-token/followers}/$p/config"
    if [ ! -f "$follower_config" ]; then
        [ -f "$main_config" ] || die "no vault configuration (run: claude-token add-follower $p)"
        mkdir -p "$(dirname "$follower_config")"
        cp "$main_config" "$follower_config"
        chmod 600 "$follower_config"
    fi
    use_follower_context "$p"
    set_config user "$p"
    set_config mode follower
    configure_follower_permissions "$p"
    claude_cmd_install_follower_wrapper "$p"
}
claude_cmd_repair_follower_wrappers() {
    local root="${CLAUDE_FOLLOWERS_DIR:-$CLAUDE_TOKEN_REAL_HOME/.claude-token/followers}" config p active w seen
    [ -d "$root" ] || return 0
    for config in "$root"/*/config; do
        [ -f "$config" ] || continue
        p="$(basename "$(dirname "$config")")"
        validate_profile_name "$p"
        active="$(command -v "claude-$p" 2>/dev/null || true)"
        seen=""
        for w in "$CLAUDE_TOKEN_REAL_HOME/bin/claude-$p" "$CLAUDE_TOKEN_REAL_HOME/.local/bin/claude-$p" "$active"; do
            [ -n "$w" ] && [ -e "$w" ] || continue
            case ":$seen:" in *":$w:"*) continue ;; esac
            seen="${seen:+$seen:}$w"
            if [ -w "$(dirname "$w")" ]; then write_follower_wrapper "$p" "$w"; fi
        done
        [ -n "$seen" ] || ( use_follower_context "$p"; claude_cmd_install_follower_wrapper "$p" )
    done
}
claude_cmd_run_follower() { # profile [claude args...]
    local p="${1:-}"; shift || true
    use_follower_context "$p"
    [ -f "$CONFIG_FILE" ] || die "follower '$p' is not paired (run: claude-token add-follower $p)"
    [ "${1:-}" != -- ] || shift
    [ "$(config_full_permissions)" != yes ] || set -- --dangerously-skip-permissions "$@"
    claude_cmd_run "$@"
}

