claude_cmd_maintain() {
    local p mode local_mode status=ok config
    if [ "${CLAUDE_TOKEN_VAULT_AUTHORITY:-no}" = yes ]; then
        # Vault leader: publish every profile, refreshing the vault-authority
        # ones. Strip the hijack permission for this loop, so a mixed fleet is
        # safe by default: owner-managed profiles (refreshAuthority=owner) are
        # republished while their owner-synced token is fresh and skipped when
        # a refresh would be needed — never refreshed by the vault. Deliberate
        # takeover stays possible as a manual act:
        #   CLAUDE_TOKEN_VAULT_AUTHORITY=yes claude-token publish --profile P
        ALL=1 CLAUDE_TOKEN_MODE=auto CLAUDE_TOKEN_VAULT_AUTHORITY=no claude_cmd_publish
        return
    fi
    p="$(config_user)"
    if [ -z "$p" ]; then
        config="$(find "${CLAUDE_FOLLOWERS_DIR:-$CLAUDE_TOKEN_REAL_HOME/.claude-token/followers}" -mindepth 2 -maxdepth 2 -name config 2>/dev/null | sort | head -1)"
        [ -n "$config" ] || die "maintain: no configured profile"
        p="$(basename "$(dirname "$config")")"
        use_follower_context "$p"
    fi
    mode="$(config_mode)"; local_mode="$(claude_local_refresh_mode)"
    if [ "$mode" = owner ] || [ "$local_mode" = owner ]; then
        if claude_sync_profile "$p" >/dev/null 2>&1; then status=synced; else status=sync-failed; fi
    else
        status=follower
    fi
    claude_cmd_heartbeat "$status"
}

