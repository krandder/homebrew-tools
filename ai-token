#!/usr/bin/env bash
# ai-token — one credential-sync tool for AI CLIs: claude, codex, kimi.
#
# Replaces the forked claude-token / codex-token scripts. Each CLI is a
# backend section in this file; orchestration (pair/publish/pull/sync/run)
# and the vault protocol are shared. Old entrypoints (claude-token,
# codex-token) are shims that call `ai-token <tool> ...`.
#
# Usage: ai-token <tool> <command> [args]
#   tool: claude | codex | kimi   (also inferred from argv0 shims)
#
# Common commands (per-backend nuances noted in each backend section):
#   print [--profile P]      print active credential object (default)
#   status                   accounts, token age, sync health (no secrets)
#   check                    validate creds without printing secrets
#   pair --user NAME         pair this machine with the vault
#   install --token T [--user U]   one-command onboarding
#   login                    native OAuth login + vault sync
#   publish [--profile P|--all]  LEADER: refresh + publish follower token(s)
#   pull   [--profile P]     FOLLOWER: replace local store with published creds
#   push   [--profile P]     LEGACY HANDOFF: push local creds, demote to follower
#   sync   [--profile P]     copy local creds to vault without changing them
#   run [args...]            follower launcher (freshen store, exec the CLI)
#   maintain                 cron entrypoint (leader publish / owner sync)
#   --version | --help | --diagnose
#
# claude-only: proxy family (proxy/proxy-url/proxy-install/install-profile-wrapper),
#   go-live, setup-owner, followers (add-follower/run-follower/...), push-logs.
# kimi-only: keepfresh (background pull loop; 15-min token TTL needs it).
#
# Model: each owner machine keeps its native login + refresh path and syncs
# fresh snapshots to the vault without changing local auth. Followers receive
# freshness-validated access tokens and never hold a real refresh token.
# Mixed fleets are safe by default: the vault's maintain loop refreshes
# vault-authority profiles and republishes owner-managed ones, but never
# refreshes an owner-managed token (takeover is an explicit manual publish).

set -euo pipefail
VERSION="3.0.9"
infer_machine_home() {
    case "$1" in
        */.codex-profiles/*) printf '%s\n' "${1%%/.codex-profiles/*}" ;;
        */.claude-profiles/*) printf '%s\n' "${1%%/.claude-profiles/*}" ;;
        *) printf '%s\n' "$1" ;;
    esac
}
AI_TOKEN_REAL_HOME="${AI_TOKEN_REAL_HOME:-$(infer_machine_home "$HOME")}"

# ---- tool selection (arg or shim name) ----
TOOL="${AI_TOKEN_TOOL:-}"
case "${1:-}" in claude|codex|kimi) TOOL="$1"; shift ;; esac
if [ -z "$TOOL" ]; then
    case "$(basename "$0")" in
        claude-token) TOOL=claude ;;
        codex-token)  TOOL=codex ;;
        kimi-token)   TOOL=kimi ;;
    esac
fi
[ -n "$TOOL" ] || { echo "usage: ai-token <claude|codex|kimi> <command> [args]  (see --help)" >&2; exit 1; }

# ---- shared core ----
PROG="ai-token"
die() { echo "$PROG: error: $*" >&2; exit 1; }
say() { echo "$PROG: $*" >&2; }
need_cmd() { command -v "$1" >/dev/null 2>&1 || die "missing required command: $1"; }
shell_quote() { printf '%q' "$1"; }
need_cmd python3
short_host() { hostname -s 2>/dev/null || hostname; }
is_mac() { [ "$(uname)" = Darwin ]; }
now_epoch() { [ -z "${AI_TOKEN_TEST_NOW:-}" ] && date +%s || printf '%.0f\n' "$AI_TOKEN_TEST_NOW"; }
resolve_invoked_binary() {
    case "$0" in
        /*) printf '%s\n' "$0" ;;
        */*) printf '%s/%s\n' "$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)" "$(basename -- "$0")" ;;
        *) command -v "$0" ;;
    esac
}
AI_TOKEN_SELF="${AI_TOKEN_BIN:-$(resolve_invoked_binary)}"

SENTINEL_RT="__follower_no_refresh__"
BLACKHOLE_URL="http://127.0.0.1:9/oauth/token"
LEADER_HOST="${AI_TOKEN_LEADER:-farol-ts}"

# One pairing serves all tools (reuse the codex-token config dir when present).
if [ -d "$AI_TOKEN_REAL_HOME/.codex-token" ]; then VAULT_DIR_CLIENT="$AI_TOKEN_REAL_HOME/.codex-token"; else VAULT_DIR_CLIENT="$AI_TOKEN_REAL_HOME/.claude-token"; fi
VAULT_DIR_CLIENT="${AI_TOKEN_VAULT_DIR:-${CODEX_VAULT_DIR:-${CLAUDE_VAULT_DIR:-$VAULT_DIR_CLIENT}}}"
VAULT_KEY="${AI_TOKEN_VAULT_KEY:-$VAULT_DIR_CLIENT/id_ed25519}"
CONFIG_FILE="$VAULT_DIR_CLIENT/config"
LOG_DIR="${AI_TOKEN_LOG_DIR:-$VAULT_DIR_CLIENT/logs}"
LOG_FILE="$LOG_DIR/events.jsonl"
[ -f "$CONFIG_FILE" ] && while IFS='=' read -r _k _v; do
    case "$_k" in
        user)   CODEX_USER="${CODEX_USER:-$_v}" ;;
        leader) LEADER_HOST="${AI_TOKEN_LEADER:-$_v}" ;;
    esac
done < "$CONFIG_FILE" 2>/dev/null || true

validate_profile_name() {
    case "${1:-}" in ""|.|..|*[!A-Za-z0-9._-]*) die "invalid profile name '$1'" ;; esac
}
config_user() {
    if [ -n "${CODEX_USER:-}" ]; then echo "$CODEX_USER"
    elif [ -f "$CONFIG_FILE" ]; then awk -F= '/^user=/{print $2;exit}' "$CONFIG_FILE"; fi
}
config_mode() {
    local mode="${AI_TOKEN_MODE:-${CLAUDE_TOKEN_MODE:-}}"
    if [ -z "$mode" ] && [ -f "$CONFIG_FILE" ]; then mode="$(awk -F= '/^mode=/{print $2;exit}' "$CONFIG_FILE")"; fi
    echo "${mode:-auto}"
}
set_config() {
    mkdir -p "$VAULT_DIR_CLIENT"
    python3 - "$CONFIG_FILE" "$1" "$2" <<'PY'
import sys,os
f,k,v=sys.argv[1],sys.argv[2],sys.argv[3]
lines=[]; found=False
if os.path.exists(f):
    for line in open(f):
        if line.rstrip("\n").startswith(k+"="): lines.append(f"{k}={v}"); found=True
        else: lines.append(line.rstrip("\n"))
if not found: lines.append(f"{k}={v}")
open(f,"w").write("\n".join(lines)+"\n"); os.chmod(f,0o600)
PY
}
log_event() { # event profile status detail
    local event="${1:-event}" profile="${2:-}" status="${3:-}" detail="${4:-}"
    mkdir -p "$LOG_DIR"
    python3 - "$LOG_FILE" "$VERSION" "$TOOL" "$(short_host)" "$(config_user 2>/dev/null || true)" "$event" "$profile" "$status" "$detail" <<'PY'
import datetime, json, os, sys
path, version, tool, host, user, event, profile, status, detail = sys.argv[1:10]
rec = {"ts": datetime.datetime.now(datetime.timezone.utc).isoformat(),
       "tool": "ai-token", "version": version, "backend": tool, "host": host,
       "user": user, "event": event, "profile": profile, "status": status,
       "detail": detail, "pid": os.getpid()}
with open(path, "a") as fh: fh.write(json.dumps(rec, separators=(",", ":")) + "\n")
os.chmod(path, 0o600)
PY
}

# ---- vault transport (HTTPS if configured, else SSH) ----
have_http_vault() { [ -n "${AI_VAULT_TOKEN:-${CLAUDE_VAULT_TOKEN:-${CODEX_VAULT_TOKEN:-}}}" ] || grep -q '^token=' "$CONFIG_FILE" 2>/dev/null; }
vault_url()   { echo "${AI_VAULT_URL:-${CLAUDE_VAULT_URL:-${CODEX_VAULT_URL:-$(awk -F= '/^url=/{print $2;exit}' "$CONFIG_FILE" 2>/dev/null)}}}"; }
vault_token() { echo "${AI_VAULT_TOKEN:-${CLAUDE_VAULT_TOKEN:-${CODEX_VAULT_TOKEN:-$(sed -n 's/^token=//p' "$CONFIG_FILE" 2>/dev/null)}}}"; }
ssh_vault() {
    local remote=("$@")
    case "${1:-}" in
        "ai-vault receive "*|"ai-vault sync-receive "*)
            remote=("ai-vault client $VERSION ${1#ai-vault }")
            ;;
    esac
    if [ -f "$VAULT_KEY" ]; then ssh -i "$VAULT_KEY" -o IdentitiesOnly=yes "$LEADER_HOST" "${remote[@]}";
    else ssh "$LEADER_HOST" "${remote[@]}"; fi
}
vault_http() { # method path [data_file]
    local method="$1" path="$2" data="${3:-}" url tok host
    url="$(vault_url)"; tok="$(vault_token)"
    host="$(short_host | tr -cd 'A-Za-z0-9._-')"
    [ -n "$url" ] || die "no vault URL (run 'ai-token $TOOL set-url <url>')"
    [ -n "$tok" ] || die "no vault token (ask operator, then 'ai-token $TOOL set-token <token>')"
    if [ -n "$data" ]; then curl -fsS -X "$method" "$url$path" -H "Authorization: Bearer $tok" -H "X-Ai-Token-Version: $VERSION" -H "X-Ai-Token-Host: $host" --data-binary @"$data";
    else curl -fsS -X "$method" "$url$path" -H "Authorization: Bearer $tok" -H "X-Ai-Token-Version: $VERSION" -H "X-Ai-Token-Host: $host"; fi
}

stat_mtime() { if stat -f %m "$1" >/dev/null 2>&1; then stat -f %m "$1"; else stat -c %Y "$1"; fi; }

# Refresh throttling is deliberately shared by every profile for a provider:
# the credential sidecar protects one refresh token, while the provider file
# protects this machine's IP when an endpoint asks us to back off.
refresh_global_cooldown_file() {
    printf '%s/%s.json\n' "${AI_TOKEN_REFRESH_STATE_DIR:-$VAULT_DIR_CLIENT/refresh-state}" "$TOOL"
}
refresh_cooldown_remaining() { # credential_file -> seconds; 0 iff blocked
    python3 - "$1.refresh-cooldown" "$(refresh_global_cooldown_file)" "$(now_epoch)" <<'PY'
import json, math, os, sys
now = float(sys.argv[3])
remaining = []
for path in sys.argv[1:3]:
    try:
        with open(path) as fh:
            until = float(json.load(fh).get("until", 0))
        if until > now:
            remaining.append(until - now)
        else:
            os.unlink(path)
    except (FileNotFoundError, ValueError, TypeError, json.JSONDecodeError, OSError):
        pass
if remaining:
    print(max(1, math.ceil(max(remaining))))
    sys.exit(0)
sys.exit(1)
PY
}
mark_refresh_cooldown() { # credential_file seconds
    local seconds="${2:-60}" global
    case "$seconds" in ''|*[!0-9]*) seconds=60 ;; esac
    [ "$seconds" -ge 1 ] || seconds=1
    [ "$seconds" -le 86400 ] || seconds=86400
    global="$(refresh_global_cooldown_file)"
    python3 - "$1.refresh-cooldown" "$global" "$(now_epoch)" "$seconds" <<'PY'
import json, os, sys
paths, now, seconds = sys.argv[1:3], int(sys.argv[3]), int(sys.argv[4])
record = {"until": now + seconds, "reason": "rate-limit"}
for path in paths:
    os.makedirs(os.path.dirname(path), exist_ok=True)
    tmp = path + ".tmp"
    with open(tmp, "w") as fh:
        json.dump(record, fh, separators=(",", ":"))
        fh.flush()
        os.fsync(fh.fileno())
    os.chmod(tmp, 0o600)
    os.replace(tmp, path)
PY
}
retry_after_from_error() { # captured refresh stderr -> seconds
    printf '%s\n' "$1" | python3 -c 'import re,sys
s=sys.stdin.read()
m=re.search(r"retry-after-seconds=([0-9]+)",s)
print(min(86400,max(1,int(m.group(1))))) if m else print(60)'
}
refresh_cooldown_guard() { # credential_file profile -> nonzero when blocked
    local remaining
    if remaining="$(refresh_cooldown_remaining "$1")"; then
        log_event refresh "${2:-}" skipped "cooldown=${remaining}s"
        say "refresh cooldown active for $TOOL:${2:-unknown} (${remaining}s remaining)"
        return 1
    fi
    return 0
}
acquire_provider_refresh_lock() {
    local state_dir lock i now mt age delay
    state_dir="${AI_TOKEN_REFRESH_STATE_DIR:-$VAULT_DIR_CLIENT/refresh-state}"
    lock="$state_dir/$TOOL.lock"
    mkdir -p "$state_dir"
    for i in 1 2 3 4 5; do
        if mkdir "$lock" 2>/dev/null; then
            printf '%s\n' "$lock"
            return 0
        fi
        now="$(date +%s)"
        mt="$(stat_mtime "$lock" 2>/dev/null || echo 0)"
        age=$((now - mt))
        if [ "$age" -ge 10 ]; then
            rmdir "$lock" 2>/dev/null || true
            continue
        fi
        delay="$(python3 -c 'import random; print("%.3f" % (1 + random.random()))')"
        sleep "$delay"
    done
    return 1
}
release_provider_refresh_lock() { rmdir "$1" 2>/dev/null || true; }

# ═══════════════════════════════════════════════════════════════════════════
# BACKEND: kimi
#
# store:   ~/.kimi-code/credentials/kimi-code.json (flat snake_case JSON 0600)
#          keys: access_token, refresh_token, expires_at (SECONDS), expires_in
#          (900), scope, token_type
# refresh: POST form https://auth.kimi.com/api/oauth/token  (verified 2026-07-18:
#          bogus RT -> 400 invalid_grant; real RT -> 200 + expires_in=900)
#          client_id 17e5f671-d194-4dfb-9706-5516cb48c098 (from kimi-code dist)
#          host override: KIMI_CODE_OAUTH_HOST / KIMI_OAUTH_HOST (same env the
#          CLI reads -> blackhole it on followers so they can never rotate)
# TTL:     900s. Publish-on-cron is useless for followers; followers pull at
#          launch AND run `keepfresh` (pull every 300s) while the session
#          lives. The vault refreshes-on-serve when the shared copy is stale.
# ═══════════════════════════════════════════════════════════════════════════
KIMI_STORE="${KIMI_CODE_STORE:-$AI_TOKEN_REAL_HOME/.kimi-code/credentials/kimi-code.json}"
KIMI_SHARED_DIR="${KIMI_SHARED_DIR:-$AI_TOKEN_REAL_HOME/shared/kimi-tokens}"
KIMI_PROFILES_DIR="${KIMI_PROFILES_DIR:-$AI_TOKEN_REAL_HOME/.kimi-profiles}"
KIMI_CLIENT_ID="17e5f671-d194-4dfb-9706-5516cb48c098"
KIMI_CANONICAL_KEEPER_REFRESH=1   # this machine's kimi CLI refreshes the live store natively

kimi_oauth_host() { echo "${KIMI_CODE_OAUTH_HOST:-${KIMI_OAUTH_HOST:-https://auth.kimi.com}}"; }
kimi_canonical_file() { echo "$KIMI_PROFILES_DIR/$1/credentials.json"; }
kimi_shared_file()    { echo "$KIMI_SHARED_DIR/$1.json"; }

kimi_read_store()  { python3 -c 'import json,sys; print(json.dumps(json.load(open(sys.argv[1]))))' "$1" 2>/dev/null; }
kimi_rt_of()       { python3 -c 'import json,sys; print(json.load(open(sys.argv[1])).get("refresh_token",""))' "$1" 2>/dev/null; }
kimi_expiry_of()   { python3 -c 'import json,sys; print(int(json.load(open(sys.argv[1])).get("expires_at") or 0))' "$1" 2>/dev/null; }
kimi_access_of()   { python3 -c 'import json,sys; print(json.load(open(sys.argv[1])).get("access_token",""))' "$1" 2>/dev/null; }
kimi_authority_of() { python3 -c 'import json,sys; print((json.load(open(sys.argv[1])).get("kimiTokenSync") or {}).get("refreshAuthority", "vault"))' "$1" 2>/dev/null; }

kimi_write_store() { # json_str dest — atomic, 0600
    python3 -c 'import json,os,sys
d=json.loads(sys.argv[1])
tmp=sys.argv[2]+".tmp"
json.dump(d,open(tmp,"w"),indent=2); os.chmod(tmp,0o600); os.replace(tmp,sys.argv[2])' "$1" "$2"
}

kimi_needs_refresh() { # file -> yes/no (60s margin)
    python3 - "$1" <<'PY'
import json,os,sys,time
try:
    with open(sys.argv[1]) as fh:
        d=json.load(fh)
    rt=d.get("refresh_token","")
    exp=int(d.get("expires_at") or 0)
    now=float(os.environ.get("AI_TOKEN_TEST_NOW") or time.time())
    print("yes" if (not rt or rt=="__follower_no_refresh__" or exp <= now+60) else "no")
except Exception:
    print("yes")
PY
}

kimi_fresh_access_from_file() { # file -> access token iff fresh (>60s)
    python3 - "$1" <<'PY'
import json,os,sys,time
try:
    with open(sys.argv[1]) as fh:
        d=json.load(fh)
    tok=d.get("access_token","")
    exp=int(d.get("expires_at") or 0)
    now=float(os.environ.get("AI_TOKEN_TEST_NOW") or time.time())
    if tok and exp > now+60: print(tok)
except Exception: pass
PY
}

kimi_refresh_store_unlocked() { # creds_file — refresh in place (atomic). Verified endpoint.
    python3 - "$1" "$KIMI_CLIENT_ID" "$(kimi_oauth_host)" <<'PY'
import datetime, email.utils, json, os, sys, time, urllib.request, urllib.parse, urllib.error
f, client_id, host = sys.argv[1], sys.argv[2], sys.argv[3].rstrip("/")
creds = json.load(open(f))
rt = creds.get("refresh_token", "")
if not rt or rt == "__follower_no_refresh__":
    sys.stderr.write("kimi refresh: no real refresh_token in %s\n" % f); sys.exit(1)
body = urllib.parse.urlencode({"grant_type": "refresh_token", "client_id": client_id,
                               "refresh_token": rt}).encode()
req = urllib.request.Request(host + "/api/oauth/token", data=body,
    headers={"Content-Type": "application/x-www-form-urlencoded"}, method="POST")
try:
    resp = urllib.request.urlopen(req, timeout=30)
    tok = json.loads(resp.read())
except urllib.error.HTTPError as e:
    retry = e.headers.get("Retry-After") or ""
    retry_seconds = 60
    try:
        retry_seconds = int(retry)
    except (TypeError, ValueError):
        try:
            when = email.utils.parsedate_to_datetime(retry)
            retry_seconds = max(1, int((when - datetime.datetime.now(datetime.timezone.utc)).total_seconds()))
        except (TypeError, ValueError, OverflowError):
            pass
    sys.stderr.write("kimi refresh FAILED: HTTP %d retry-after-seconds=%d %s\n" %
                     (e.code, retry_seconds, e.read().decode(errors="replace")[:200])); sys.exit(1)
except Exception as e:
    sys.stderr.write("kimi refresh FAILED: %s\n" % e); sys.exit(1)
new = dict(creds)
new["access_token"] = tok["access_token"]
new["refresh_token"] = tok.get("refresh_token") or rt
new["expires_in"] = int(tok.get("expires_in", 900))
new["expires_at"] = int(float(os.environ.get("AI_TOKEN_TEST_NOW") or time.time())) + new["expires_in"]
if tok.get("scope"): new["scope"] = tok["scope"]
if tok.get("token_type"): new["token_type"] = tok["token_type"]
tmp = f + ".tmp"
json.dump(new, open(tmp, "w"), indent=2); os.chmod(tmp, 0o600); os.replace(tmp, f)
print("refreshed (expires_in=%ds)" % new["expires_in"])
PY
}

kimi_refresh_store() { # creds_file [profile] — serialized and rate-limit safe
    local store="$1" profile="${2:-$(config_user)}" lock output rc retry_after
    refresh_cooldown_guard "$store" "$profile" || return 1
    lock="$(acquire_provider_refresh_lock)" || { say "could not acquire kimi refresh lock"; return 1; }
    if ! refresh_cooldown_guard "$store" "$profile"; then
        release_provider_refresh_lock "$lock"
        return 1
    fi
    if [ "$(kimi_needs_refresh "$store")" != yes ]; then
        release_provider_refresh_lock "$lock"
        return 0
    fi
    set +e
    output="$(kimi_refresh_store_unlocked "$store" 2>&1)"
    rc=$?
    set -e
    if [ "$rc" -ne 0 ] && printf '%s' "$output" | grep -q 'HTTP 429'; then
        retry_after="$(retry_after_from_error "$output")"
        mark_refresh_cooldown "$store" "$retry_after"
        log_event refresh "$profile" rate-limited "cooldown=${retry_after}s"
    fi
    release_provider_refresh_lock "$lock"
    if [ "$rc" -eq 0 ]; then
        [ -z "$output" ] || printf '%s\n' "$output"
    else
        printf '%s\n' "$output" >&2
    fi
    return "$rc"
}

kimi_local_refresh_mode() { # owner/follower/missing for the LIVE local store
    [ -f "$KIMI_STORE" ] || { echo missing; return; }
    local rt; rt="$(kimi_rt_of "$KIMI_STORE")"
    case "$rt" in "$SENTINEL_RT"|"") echo follower ;; *) echo owner ;; esac
}

kimi_make_follower_copy() { # src_file dest — strip RT to sentinel
    python3 - "$1" "$2" "$SENTINEL_RT" <<'PY'
import json,os,sys
s,d,sentinel=sys.argv[1],sys.argv[2],sys.argv[3]
creds=json.load(open(s)); creds["refresh_token"]=sentinel
tmp=d+".tmp"; json.dump(creds,open(tmp,"w"),indent=2); os.chmod(tmp,0o600); os.replace(tmp,d)
PY
}

# ---- kimi orchestration ----
kimi_cmd_print() { kimi_read_store "$KIMI_STORE" || { echo '{"error":"no kimi credentials found"}' >&2; exit 1; }; }

kimi_cmd_check() {
    [ -f "$KIMI_STORE" ] || { echo "missing: $KIMI_STORE"; return 1; }
    local exp rt
    exp="$(kimi_expiry_of "$KIMI_STORE")"; rt="$(kimi_rt_of "$KIMI_STORE")"
    local now mode ttl; now="$(now_epoch)"; mode="$(kimi_local_refresh_mode)"
    if [ "$exp" -le $((now + 60)) ]; then
        if [ "$mode" = owner ]; then echo "ok: owner refreshToken present; access token expired (native kimi refreshes on next call)"
        else echo "stale: follower access token expired; the vault must publish a fresh one"; return 1; fi
    else
        ttl=$(( (exp - now) / 60 ))
        echo "ok: valid JSON, accessToken valid (${ttl}m left), rt=$mode"
    fi
}

kimi_cmd_status() {
    say "machine: $(short_host)   leader: $LEADER_HOST   backend: kimi"
    echo "  store: $KIMI_STORE"
    kimi_cmd_check | sed 's/^/  /'
    local sf; sf="$(kimi_shared_file "$(config_user)")"
    [ -f "$sf" ] && echo "  published: $(python3 -c 'import json,sys; d=json.load(open(sys.argv[1])); print(d.get("published_at","?"))' "$sf" 2>/dev/null) (vault serve refreshes when stale)"
    return 0
}

# publish [--profile P]: refresh-if-stale and write the shared copy (sentinel
# RT). Source of truth order: canonical ~/.kimi-profiles/<p>/credentials.json
# when present (owner-synced accounts), else the live store (farol's own account).
kimi_cmd_publish() {
    local p="${PROFILE:-$(config_user)}"; [ -n "$p" ] || die "publish: specify --profile <name> or configure a user"
    validate_profile_name "$p"
    local src cf; cf="$(kimi_canonical_file "$p")"
    if [ -f "$cf" ]; then
        src="$cf"
    else
        [ "$p" = "$(config_user)" ] || die "publish: no canonical creds for kimi:$p (owner must sync first)"
        src="$KIMI_STORE"
        [ -f "$src" ] || die "publish: no local kimi store at $src"
    fi
    local rt; rt="$(kimi_rt_of "$src")"
    [ -n "$rt" ] && [ "$rt" != "$SENTINEL_RT" ] || die "publish: '$p' has no real refresh_token (follower copy?)"
    local sf; sf="$(kimi_shared_file "$p")"
    mkdir -p "$KIMI_SHARED_DIR"
    if [ "$(kimi_needs_refresh "$src")" = yes ]; then
        log_event refresh "$p" start "kimi ttl=900"
        kimi_refresh_store "$src" "$p" || { log_event refresh "$p" failed "endpoint"; die "publish: kimi refresh failed"; }
        log_event refresh "$p" ok "$src"
    fi
    kimi_make_follower_copy "$src" "$sf"
    python3 - "$sf" "$p" "$(short_host)" <<'PY'
import json,sys,datetime,os
sf,p,host=sys.argv[1],sys.argv[2],sys.argv[3]
d=json.load(open(sf)); d["profile"]=p; d["leader"]=host
d["published_at"]=datetime.datetime.now(datetime.timezone.utc).isoformat()
tmp=sf+".tmp"; json.dump(d,open(tmp,"w"),indent=2); os.chmod(tmp,0o600); os.replace(tmp,sf)
PY
    say "published kimi:$p -> $sf"
    log_event publish "$p" ok "shared"
}

# serve <p>: print fresh follower creds JSON for the vault (refresh-on-serve).
kimi_cmd_serve() {
    local p="$1" sf cf
    validate_profile_name "$p"
    sf="$(kimi_shared_file "$p")"
    if [ -f "$sf" ] && [ -n "$(kimi_fresh_access_from_file "$sf" 2>/dev/null || true)" ]; then
        cat "$sf"; return 0
    fi
    cf="$(kimi_canonical_file "$p")"
    if [ -f "$cf" ]; then
        if [ "$(kimi_needs_refresh "$cf")" = yes ]; then
            [ "$(kimi_authority_of "$cf")" != owner ] || return 1
            kimi_refresh_store "$cf" "$p" || return 1
        fi
        PROFILE="$p" kimi_cmd_publish >/dev/null 2>&1 || return 1
        cat "$sf"; return 0
    fi
    if [ "$p" = "$(config_user)" ] && [ "$(kimi_local_refresh_mode)" = owner ]; then
        PROFILE="$p" kimi_cmd_publish >/dev/null 2>&1 || return 1
        cat "$sf"; return 0
    fi
    return 1
}

# serve-access <p>: print ONLY the fresh access token (transparent followers).
kimi_cmd_serve_access() {
    local p="$1" json
    json="$(kimi_cmd_serve "$p")" || return 1
    printf '%s' "$json" | python3 -c 'import json,sys; print(json.load(sys.stdin).get("access_token",""))'
}

# pull [--profile P]: follower installs the published creds into the live store.
kimi_cmd_pull() {
    local p="${PROFILE:-$(config_user)}" tok="" sf
    [ -n "$p" ] || die "pull: specify --profile <name>"
    sf="$(kimi_shared_file "$p")"
    if [ -f "$sf" ] && [ -n "$(kimi_fresh_access_from_file "$sf" 2>/dev/null || true)" ]; then
        : # mesh fast path
    elif have_http_vault; then
        local tmp; tmp="$(mktemp)"
        vault_http GET "/pull/kimi/$p" > "$tmp" || { rm -f "$tmp"; die "pull: vault denied/unavailable for kimi:$p"; }
        sf="$tmp"
        if [ -z "$(kimi_fresh_access_from_file "$sf" 2>/dev/null || true)" ]; then rm -f "$tmp"; die "pull: vault served a stale kimi token (leader must refresh)"; fi
    else
        need_cmd ssh; local tmp; tmp="$(mktemp)"
        ssh_vault "ai-vault serve kimi:$p" > "$tmp" || { rm -f "$tmp"; die "pull: leader denied/unavailable for kimi:$p"; }
        sf="$tmp"
    fi
    mkdir -p "$(dirname "$KIMI_STORE")"
    python3 - "$sf" "$KIMI_STORE" <<'PY'
import json,os,sys
s,d=sys.argv[1],sys.argv[2]
creds=json.load(open(s))
tmp=d+".tmp"; json.dump(creds,open(tmp,"w"),indent=2); os.chmod(tmp,0o600); os.replace(tmp,d)
PY
    [ -z "${tmp:-}" ] || rm -f "$tmp"
    say "pulled kimi:$p into the local store"
    log_event pull "$p" ok ""
}

# push [--profile P]: hand local owner creds to the vault, demote local to follower.
kimi_cmd_push() {
    local p="${PROFILE:-$(config_user)}"
    [ -n "$p" ] || die "push: specify --profile <name>"
    [ -f "$KIMI_STORE" ] || die "push: no local kimi store"
    [ "$(kimi_local_refresh_mode)" = owner ] || die "push: only sentinel token present (already a follower)"
    say "WARNING: push hands kimi refresh ownership to the vault and demotes local creds"
    if have_http_vault; then
        kimi_read_store "$KIMI_STORE" | vault_http POST "/push/kimi/$p" /dev/stdin >/dev/null || die "push: vault rejected kimi:$p"
    else
        need_cmd ssh
        kimi_read_store "$KIMI_STORE" | ssh_vault "ai-vault receive kimi:$p" || die "push: leader rejected kimi:$p"
    fi
    python3 - "$KIMI_STORE" "$SENTINEL_RT" <<'PY'
import json,os,sys
f,s=sys.argv[1],sys.argv[2]
d=json.load(open(f)); d["refresh_token"]=s
tmp=f+".tmp"; json.dump(d,open(tmp,"w"),indent=2); os.chmod(tmp,0o600); os.replace(tmp,f)
PY
    kimi_cmd_pull >/dev/null 2>&1 || true
    say "reverted kimi:$p to follower (sentinel RT)"
    log_event push "$p" ok "demoted"
}

# sync [--profile P]: copy local owner creds to the vault; local auth unchanged.
kimi_cmd_sync() {
    local p="${PROFILE:-$(config_user)}"
    [ -n "$p" ] || die "sync: specify --profile <name>"
    [ "$(kimi_local_refresh_mode)" = owner ] || die "sync: local store is a follower copy, not an owner login"
    if have_http_vault; then
        kimi_read_store "$KIMI_STORE" | vault_http POST "/sync/kimi/$p" /dev/stdin >/dev/null \
            || { say "sync failed; local kimi credentials unchanged (retry: ai-token kimi sync --profile $p)"; log_event sync "$p" failed "http"; return 1; }
    else
        need_cmd ssh
        kimi_read_store "$KIMI_STORE" | ssh_vault "ai-vault sync-receive kimi:$p" >/dev/null \
            || { say "sync failed; local kimi credentials unchanged (retry: ai-token kimi sync --profile $p)"; log_event sync "$p" failed "ssh"; return 1; }
    fi
    say "synced kimi:$p to the vault; local kimi credentials unchanged"
    log_event sync "$p" ok "local-unchanged"
}

# keepfresh [--profile P] [interval]: follower-side pull loop. Kimi access
# tokens live 900s; the vault refreshes-on-serve, so pulling every 300s keeps
# the local file fresh and the CLI never attempts its own (sentinel) refresh.
kimi_cmd_keepfresh() {
    local p="${PROFILE:-$(config_user)}" interval="${1:-300}"
    [ -n "$p" ] || die "keepfresh: specify --profile <name>"
    case "$interval" in ''|*[!0-9]*) die "keepfresh: interval must be seconds (default 300)" ;; esac
    [ "$interval" -ge 60 ] || die "keepfresh: interval must be >= 60s"
    say "keepfresh kimi:$p every ${interval}s (pid $$)"
    while true; do
        PROFILE="$p" kimi_cmd_pull >/dev/null 2>&1 \
            || log_event keepfresh "$p" failed "pull"
        sleep "$interval"
    done
}

# run [kimi args...]: follower launcher — pull at launch, spawn keepfresh,
# blackhole the OAuth host (never rotate the leader's RT), exec kimi.
kimi_cmd_run() {
    local p; p="$(config_user)"
    [ -n "$p" ] || exec "$(kimi_resolve_bin)" "$@"   # unpaired: standalone
    local mode; mode="$(config_mode)"
    if [ "$mode" != follower ] && [ "$(kimi_local_refresh_mode)" = owner ]; then
        exec "$(kimi_resolve_bin)" "$@"              # owner: native path
    fi
    PROFILE="$p" kimi_cmd_pull || die "run: no fresh follower token for kimi:$p"
    PROFILE="$p" kimi_cmd_keepfresh >/dev/null 2>&1 &
    local keepfresh_pid=$!
    export KIMI_CODE_OAUTH_HOST="$BLACKHOLE_URL"
    local bin; bin="$(kimi_resolve_bin)"
    "$bin" "$@"
    local rc=$?
    kill "$keepfresh_pid" 2>/dev/null || true
    wait "$keepfresh_pid" 2>/dev/null || true
    return $rc
}

kimi_resolve_bin() {
    local cands="${KIMI_BIN:-}:$AI_TOKEN_REAL_HOME/.local/bin/kimi:$(command -v kimi 2>/dev/null)" d
    local IFS=':'
    for d in $cands; do
        [ -n "$d" ] && [ -x "$d" ] || continue
        case "$d" in "$AI_TOKEN_REAL_HOME/bin/kimi") continue ;; esac
        echo "$d"; return
    done
    return 1
}

kimi_cmd_login() {
    local bin; bin="$(kimi_resolve_bin)"; [ -n "$bin" ] || die "login: kimi binary not found"
    say "starting native kimi login..."
    "$bin" auth login "$@" || "$bin" login "$@" || die "login: kimi login failed"
    [ -f "$KIMI_STORE" ] || die "login completed, but no credentials at $KIMI_STORE"
    if [ "$(kimi_local_refresh_mode)" = owner ]; then
        ( kimi_cmd_sync ) || say "login succeeded; vault sync deferred (retry: ai-token kimi sync)"
        say "native kimi login is active locally"
    else
        say "logged in (follower token installed; no refresh token to sync)"
    fi
    log_event login "$(config_user)" ok "kimi"
}

kimi_cmd_maintain() {
    # Leader-side cron: publish if we hold owner creds (the live kimi CLI also
    # refreshes the store natively every ~15 min; publish just copies it out).
    if [ "$(kimi_local_refresh_mode)" = owner ]; then
        kimi_cmd_publish && log_event maintain "$(config_user)" ok "kimi-publish" && return 0
        log_event maintain "$(config_user)" failed "kimi-publish"; return 1
    fi
    log_event maintain "$(config_user)" ok "kimi-follower-noop"
}

kimi_dispatch() {
    [ $# -eq 0 ] && { kimi_cmd_print; exit 0; }
    case "$1" in
        print) shift; kimi_cmd_print "$@";;
        check) kimi_cmd_check;;
        status) kimi_cmd_status;;
        publish) shift; while [ $# -gt 0 ]; do case "$1" in --profile|-p) PROFILE="$2"; shift 2;; *) PROFILE="$1"; shift;; esac; done; kimi_cmd_publish;;
        serve) shift; [ $# -eq 1 ] || die "serve: specify one profile name"; kimi_cmd_serve "$1";;
        serve-access) shift; [ $# -eq 1 ] || die "serve-access: specify one profile name"; kimi_cmd_serve_access "$1";;
        pull) shift; while [ $# -gt 0 ]; do case "$1" in --profile|-p) PROFILE="$2"; shift 2;; *) PROFILE="$1"; shift;; esac; done; kimi_cmd_pull;;
        push) shift; while [ $# -gt 0 ]; do case "$1" in --profile|-p) PROFILE="$2"; shift 2;; *) PROFILE="$1"; shift;; esac; done; kimi_cmd_push;;
        sync) shift; while [ $# -gt 0 ]; do case "$1" in --profile|-p) PROFILE="$2"; shift 2;; *) PROFILE="$1"; shift;; esac; done; kimi_cmd_sync;;
        run) shift; kimi_cmd_run "$@";;
        keepfresh) shift; kimi_cmd_keepfresh "$@";;
        login) shift; kimi_cmd_login "$@";;
        maintain) kimi_cmd_maintain;;
        pair|setup) shift; cmd_pair_generic kimi "$@";;
        install) shift; cmd_install_generic kimi "$@";;
        set-url) shift; [ -n "${1:-}" ] || die "set-url: specify URL"; set_config url "$1"; say "vault URL = $1";;
        set-token) shift; [ -n "${1:-}" ] || die "set-token: specify token"; set_config token "$1"; say "vault token stored";;
        set-mode) shift; case "${1:-}" in auto|owner|follower) set_config mode "$1"; say "mode = $1" ;; *) die "set-mode: expected auto, owner, or follower" ;; esac;;
        --diagnose|--diagnostics|--debug) say "ai-token $VERSION backend=kimi"; say "KIMI_STORE=$KIMI_STORE"; say "SHARED_DIR=$KIMI_SHARED_DIR"; say "LEADER_HOST=$LEADER_HOST"; say "oauth_host=$(kimi_oauth_host)"; [ -f "$KIMI_STORE" ] && say "local creds: present" || say "local creds: none";;
        --version|-v) echo "ai-token $VERSION";;
        --help|-h) sed -n '2,/^set -euo/p' "$0" | sed 's/^# \{0,1\}//;s/^#$//';;
        *) die "unknown kimi command: $1 (see --help)";;
    esac
    exit 0
}

# ---- generic pairing / install (shared by all backends) ----
cmd_pair_generic() { # tool [--user U]
    local tool="$1"; shift
    local user="${CODEX_USER:-}"
    while [ $# -gt 0 ]; do case "$1" in --user|-u) user="$2"; shift 2;; *) user="$1"; shift;; esac; done
    while [ -z "$user" ]; do read -rp "Your username on the vault: " user; done
    mkdir -p "$VAULT_DIR_CLIENT"
    if [ ! -f "$VAULT_KEY" ]; then
        ssh-keygen -q -t ed25519 -N "" -C "$user@$(short_host)" -f "$VAULT_KEY"
        say "generated vault key: $VAULT_KEY"
    fi
    set_config user "$user"; set_config leader "$LEADER_HOST"
    local pub=""; [ -f "$VAULT_KEY.pub" ] && pub="$(cat "$VAULT_KEY.pub")"
    cat <<EOF

Pairing as '$user' ($tool).

OPTION A — HTTPS vault (recommended):
  Ask the operator to approve you on the leader:
    ai-vault token $user
  Then here, ONE command:
    ai-token $tool install --token <the-token> --user $user

OPTION B — SSH (Tailscale + approved key). Send this line to the operator:
--------------------------------------------------------------------------------
command="ai-vault shell $user",no-pty,no-port-forwarding,no-X11-forwarding,no-agent-forwarding $pub
--------------------------------------------------------------------------------
  They run: ai-vault approve $user '<that line>'

Then run:  ai-token $tool login
EOF
}

cmd_install_generic() { # tool [--token T] [--user U]
    local tool="$1"; shift
    local user="${CODEX_USER:-}" token=""
    while [ $# -gt 0 ]; do
        case "$1" in
            --token) token="$2"; shift 2;;
            --user)  user="$2";  shift 2;;
            *) die "install: unknown arg: $1";;
        esac
    done
    [ -n "$user" ] || die "install: specify --user NAME"
    [ -n "$token" ] || die "install: specify --token (ask the operator: ai-vault token $user)"
    set_config user "$user"; set_config token "$token"
    say "vault: user=$user url=$(vault_url)"
    local probe; probe="$(vault_http GET "/pull/$tool/$user" 2>&1 || true)"
    case "$probe" in *401*|*denied*|*Denied*) say "NOTE: vault has no $tool token for '$user' yet — run 'ai-token $tool login' to push yours" ;; esac
    say "install complete. Verify with: ai-token $tool status"
}

