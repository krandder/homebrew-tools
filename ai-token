PY
}
codex_file_is_fresh() {
    local exp now
    exp="$(codex_access_exp "$1")"
    now="$(now_epoch)"
    [ "$exp" -gt $((now + 60)) ]
}
codex_tokens_get() { python3 - "$1" "$2" <<'PY'
import json,sys
try:
    with open(sys.argv[1]) as fh:
        d=json.load(fh)
    print((d.get("tokens") or {}).get(sys.argv[2]) or "")
except Exception:
    print("")
PY
}
codex_rt_is_real() { local rt; rt="$(codex_tokens_get "$1" refresh_token)"; [ -n "$rt" ] && [ "$rt" != "$SENTINEL_RT" ]; }
codex_revert_sentinel() { python3 - "$1" "$SENTINEL_RT" <<'PY'
import json,sys,os
af,s=sys.argv[1],sys.argv[2]
with open(af) as fh: d=json.load(fh)
d.setdefault("tokens",{})["refresh_token"]=s
with open(af,"w") as fh: json.dump(d,fh,indent=2)
os.chmod(af,0o600)
PY
}

codex_refresh_profile() { # profile -> updates its auth.json with fresh tokens
    local p="$1" af lock output rc retry_after; af="$(codex_auth_file "$p")"
    [ -f "$af" ] || die "refresh: missing auth.json for '$p' at $af"
    local rt; rt="$(codex_tokens_get "$af" refresh_token)"
    [ -n "$rt" ] || die "refresh: '$p' has no refresh_token"
    [ "$rt" = "$SENTINEL_RT" ] && die "refresh: '$p' is a follower (sentinel token); nothing to refresh"
    refresh_cooldown_guard "$af" "$p" || return 1
    lock="$(acquire_provider_refresh_lock)" || { say "could not acquire codex refresh lock"; return 1; }
    if ! refresh_cooldown_guard "$af" "$p"; then
        release_provider_refresh_lock "$lock"
        return 1
    fi
    if codex_file_is_fresh "$af"; then
        release_provider_refresh_lock "$lock"
        return 0
    fi
    set +e
    output="$(python3 - "$af" "$rt" "$CODEX_CLIENT_ID" "$CODEX_TOKEN_EP" 2>&1 <<'PY'
import datetime, email.utils, json, os, sys, urllib.error, urllib.parse, urllib.request
af, refresh_token, client_id, endpoint = sys.argv[1:5]
body = urllib.parse.urlencode({"grant_type": "refresh_token", "client_id": client_id,
                               "refresh_token": refresh_token}).encode()
request = urllib.request.Request(endpoint, data=body,
    headers={"Content-Type": "application/x-www-form-urlencoded"}, method="POST")
try:
    with urllib.request.urlopen(request, timeout=30) as response:
        token = json.loads(response.read())
except urllib.error.HTTPError as error:
    retry = error.headers.get("Retry-After") or ""
    retry_seconds = 60
    try:
        retry_seconds = int(retry)
    except (TypeError, ValueError):
        try:
            when = email.utils.parsedate_to_datetime(retry)
            retry_seconds = max(1, int((when - datetime.datetime.now(datetime.timezone.utc)).total_seconds()))
        except (TypeError, ValueError, OverflowError):
            pass
    sys.stderr.write(f"codex refresh FAILED: HTTP {error.code} retry-after-seconds={retry_seconds} ")
    sys.stderr.write(error.read().decode(errors="replace")[:200] + "\n")
    sys.exit(1)
if "access_token" not in token:
    error = token.get("error_description") or token.get("error") or json.dumps(token)
    sys.stderr.write(f"codex refresh FAILED: {error}\n")
    sys.exit(1)
with open(af) as fh:
    credential = json.load(fh)
credential.setdefault("tokens", {})
credential["tokens"]["access_token"] = token["access_token"]
credential["tokens"]["refresh_token"] = token.get("refresh_token") or refresh_token
if "id_token" in token:
    credential["tokens"]["id_token"] = token["id_token"]
credential["last_refresh"] = datetime.datetime.now(datetime.timezone.utc).isoformat()
tmp = af + ".tmp"
with open(tmp, "w") as fh:
    json.dump(credential, fh, indent=2)
    fh.flush()
    os.fsync(fh.fileno())
os.chmod(tmp, 0o600)
os.replace(tmp, af)
print("refreshed")
PY
    )"
    rc=$?
    set -e
    if [ "$rc" -ne 0 ] && printf '%s' "$output" | grep -q 'HTTP 429'; then
        retry_after="$(retry_after_from_error "$output")"
        mark_refresh_cooldown "$af" "$retry_after"
        log_event refresh "$p" rate-limited "cooldown=${retry_after}s"
    fi
    release_provider_refresh_lock "$lock"
    if [ "$rc" -eq 0 ]; then
        [ -z "$output" ] || printf '%s\n' "$output"
    else
        printf '%s\n' "$output" >&2
    fi
    return "$rc"
}

codex_publish_profile() { # profile -> refresh + write shared file with sentinel RT
    local p="$1" af sf email
    af="$(codex_auth_file "$p")"; sf="$(codex_shared_file "$p")"
    [ -f "$af" ] || die "publish: missing auth.json for '$p'"
    if ! codex_file_is_fresh "$af"; then
        codex_refresh_profile "$p" >/dev/null || die "publish: could not refresh '$p' (refresh token invalid or rate limited)"
    fi
    email="$(codex_email_of "$af")"
    mkdir -p "$CODEX_SHARED_DIR"
    python3 - "$af" "$sf" "$p" "$email" "$SENTINEL_RT" "$LEADER_HOST" <<'PY'
import json,sys,os
from datetime import datetime,timezone
af,sf,profile,email,sentinel,leader=sys.argv[1:7]
d=json.load(open(af))
out=dict(d)
out.setdefault("tokens",{})
out["tokens"]["refresh_token"]=sentinel
out["email"]=email
out["profile"]=profile
out["leader"]=leader
out["published_at"]=datetime.now(timezone.utc).isoformat()
json.dump(out,open(sf,"w"),indent=2); os.chmod(sf,0o600)
print(f"published {profile} ({email}) -> {sf}")
PY
}

codex_pull_profile() { # profile -> local canonical auth from shared file or vault
    local p="$1" sf af
    sf="$(codex_shared_file "$p")"; af="$(codex_auth_file "$p")"
    mkdir -p "$(dirname "$af")"
    if [ -f "$sf" ]; then
        codex_file_is_fresh "$sf" || die "pull: published token is stale for codex:$p"
        codex_copy_token "$sf" "$af"
        echo "pulled"
    else
        local tmp="$af.tmp"
        if have_http_vault; then
            vault_http GET "/pull/codex/$p" > "$tmp" || { rm -f "$tmp"; die "pull: vault denied/unavailable for codex:$p"; }
        else
            need_cmd ssh
            ssh_vault "ai-vault serve codex:$p" > "$tmp" || { rm -f "$tmp"; die "pull: leader denied/unavailable for codex:$p"; }
        fi
        codex_file_is_fresh "$tmp" || { rm -f "$tmp"; die "pull: vault served a stale token for codex:$p"; }
        codex_copy_token "$tmp" "$af"
        rm -f "$tmp"
        echo "pulled (via vault)"
    fi
}

codex_push_profile() { # profile -> vault receive, then revert local to follower
    local p="$1" af rt
    af="$(codex_auth_file "$p")"
    [ -f "$af" ] || die "push: no local auth.json for '$p' (log in first)"
    rt="$(codex_tokens_get "$af" refresh_token)"
    [ -n "$rt" ] || die "push: '$p' has no refresh_token to push"
    [ "$rt" = "$SENTINEL_RT" ] && die "push: '$p' only has a sentinel token (already a follower)"
    if have_http_vault; then
        say "pushing '$p' to $(vault_url) (HTTPS)..."
        vault_http POST "/push/codex/$p" "$af" >/dev/null || die "push: leader rejected '$p'"
    else
        need_cmd ssh
        say "pushing '$p' to leader $LEADER_HOST (vault/SSH)..."
        ssh_vault "ai-vault receive codex:$p" < "$af" || die "push: leader rejected '$p'"
    fi
    codex_revert_sentinel "$af"
    codex_set_role "$p" follower
    codex_pull_profile "$p" >/dev/null 2>&1 || true
    say "reverted '$p' to follower (sentinel token)"
}

codex_sync_profile() { # profile -> role-aware one-shot
    local p="$1" role rt
    role="$(codex_role_of "$p")"
    if [ "$role" = "leader" ]; then
        [ -f "$(codex_auth_file "$p")" ] || die "sync: leader '$p' has no auth.json to publish"
        codex_publish_profile "$p"
    else
        rt="$(codex_tokens_get "$(codex_auth_file "$p")" refresh_token)"
        if [ -n "$rt" ] && [ "$rt" != "$SENTINEL_RT" ]; then
            codex_push_profile "$p"
        else
            codex_pull_profile "$p"
        fi
    fi
}

codex_fmt_remaining() { local delta=$(( $1 - $(date +%s) )); if [ "$delta" -le 0 ]; then echo expired; else printf '%dd %dh' $((delta/86400)) $(((delta%86400)/3600)); fi; }
codex_status_profile() {
    local p="$1" af role email exp rt_state
    af="$(codex_auth_file "$p")"
    if [ ! -f "$af" ]; then printf '  %-12s (no auth)\n' "$p"; return; fi
    role="$(codex_role_of "$p")"
    email="$(codex_email_of "$af")"; [ -n "$email" ] || email="?"
    exp="$(codex_access_exp "$af")"
    if [ "$exp" -le 0 ]; then exp="age unknown"; elif [ "$exp" -le "$(date +%s)" ]; then exp="expired"; else exp="valid $(codex_fmt_remaining "$exp")"; fi
    if [ "$(codex_tokens_get "$af" refresh_token)" = "$SENTINEL_RT" ]; then rt_state="sentinel"; else rt_state="REAL"; fi
    printf '  %-12s %-8s %-28s token %s  rt=%s\n' "$p" "$role" "$email" "$exp" "$rt_state"
}

codex_cmd_print() {
    local p; p="$(codex_resolve_profile)"; [ -n "$p" ] || die "print: no active profile (set CODEX_PROFILE)"
    cat "$(codex_auth_file "$p")"
}
codex_cmd_status() {
    say "machine: $(short_host)   leader: $LEADER_HOST   backend: codex"
    if [ "${ALL:-0}" = 1 ]; then local p; for p in $(codex_all_profiles); do codex_status_profile "$p"; done
    else local p; p="$(codex_resolve_profile)"; [ -n "$p" ] || die "status: no active profile (or use --all)"; codex_status_profile "$p"; fi
    return 0
}
codex_cmd_publish() {
    if [ "${ALL:-0}" = 1 ]; then local p; for p in $(codex_all_profiles); do ( codex_publish_profile "$p" ) || say "  (skipped $p)"; done; return 0; fi
    local p="${PROFILE:-$(codex_resolve_profile)}"; [ -n "$p" ] || die "publish: specify --profile <name> or --all"
    codex_publish_profile "$p"
}
codex_cmd_pull() {
    if [ "${ALL:-0}" = 1 ]; then local p; for p in $(codex_all_profiles); do ( codex_pull_profile "$p" ) || say "  (skipped $p)"; done; return 0; fi
    local p="${PROFILE:-$(codex_resolve_profile)}"; [ -n "$p" ] || die "pull: specify --profile <name> or --all"
    codex_pull_profile "$p"
}
codex_cmd_push() {
    local p="${PROFILE:-$(codex_resolve_profile)}"; [ -n "$p" ] || die "push: specify --profile <name>"
    codex_push_profile "$p"
}
codex_cmd_sync() {
    if [ "${ALL:-0}" = 1 ]; then local p; for p in $(codex_all_profiles); do ( codex_sync_profile "$p" ) || say "  (skipped $p)"; done; return 0; fi
    local p="${PROFILE:-$(codex_resolve_profile)}"; [ -n "$p" ] || die "sync: specify --profile <name> or --all"
    codex_sync_profile "$p"
}

codex_cmd_login() {
    local user; user="$(config_user)"
    [ -n "$user" ] || die "login: no user configured. Run 'ai-token codex pair --user <name>' first."
    local bin; bin="$(codex_resolve_bin)"
    [ -n "$bin" ] || die "login: codex binary not found (install the OpenAI Codex CLI first)."
    say "starting browser login (sign in as $user's account)..."
    "$bin" login "$@"
    [ -f "$CODEX_LEGACY_AUTH" ] || die "login: codex login did not create $CODEX_LEGACY_AUTH"
    local rt; rt="$(codex_tokens_get "$CODEX_LEGACY_AUTH" refresh_token)"
    if [ -n "$rt" ] && [ "$rt" != "$SENTINEL_RT" ]; then
        if have_http_vault; then
            say "pushing your token to $(vault_url) as '$user'..."
            vault_http POST "/push/codex/$user" "$CODEX_LEGACY_AUTH" >/dev/null || die "login: leader rejected push for '$user'"
        else
            need_cmd ssh
            say "pushing your token to the leader as '$user'..."
            ssh_vault "ai-vault receive codex:$user" < "$CODEX_LEGACY_AUTH" || die "login: leader rejected push for '$user'"
        fi
        codex_revert_sentinel "$CODEX_LEGACY_AUTH"
    fi
    codex_cmd_run --refresh-only 2>/dev/null || true
    say "paired. Use 'codex' (or 'ai-token codex run') to work as $user."
}

codex_cmd_run() { # [args...] follower launcher: freshen ~/.codex then exec codex (refresh blackholed)
    local refresh_only=0
    [ "${1:-}" = "--refresh-only" ] && { refresh_only=1; shift; }
    local user; user="$(config_user)"
    [ -n "$user" ] || die "run: no user configured. Run 'ai-token codex pair' first."
    local sf="$CODEX_SHARED_DIR/$user.json"
    mkdir -p "$(dirname "$CODEX_LEGACY_AUTH")"
    if [ -f "$sf" ]; then
        codex_file_is_fresh "$sf" || die "run: published token is stale for codex:$user"
        codex_copy_token "$sf" "$CODEX_LEGACY_AUTH"
    elif have_http_vault; then
        vault_http GET "/pull/codex/$user" > "$CODEX_LEGACY_AUTH.tmp" || { rm -f "$CODEX_LEGACY_AUTH.tmp"; die "run: cannot reach/authorized for codex:$user"; }
        codex_file_is_fresh "$CODEX_LEGACY_AUTH.tmp" || { rm -f "$CODEX_LEGACY_AUTH.tmp"; die "run: vault served a stale token for codex:$user"; }
        codex_copy_token "$CODEX_LEGACY_AUTH.tmp" "$CODEX_LEGACY_AUTH"; rm -f "$CODEX_LEGACY_AUTH.tmp"
    else
        need_cmd ssh
        ssh_vault "ai-vault serve codex:$user" > "$CODEX_LEGACY_AUTH.tmp" || { rm -f "$CODEX_LEGACY_AUTH.tmp"; die "run: cannot reach/authorized for codex:$user"; }
        codex_file_is_fresh "$CODEX_LEGACY_AUTH.tmp" || { rm -f "$CODEX_LEGACY_AUTH.tmp"; die "run: vault served a stale token for codex:$user"; }
        codex_copy_token "$CODEX_LEGACY_AUTH.tmp" "$CODEX_LEGACY_AUTH"; rm -f "$CODEX_LEGACY_AUTH.tmp"
    fi
    [ "$refresh_only" = "1" ] && return 0
    local bin; bin="$(codex_resolve_bin)"
    [ -n "$bin" ] || die "run: codex binary not found."
    export CODEX_REFRESH_TOKEN_URL_OVERRIDE="$BLACKHOLE_URL"
    exec "$bin" "$@"
}

codex_cmd_install_wrapper() {
    mkdir -p "$AI_TOKEN_REAL_HOME/bin"
    local w="$AI_TOKEN_REAL_HOME/bin/codex" bin
    bin="$(shell_quote "$AI_TOKEN_SELF")"
    if [ -e "$w" ] && [ ! -e "$w.pre-codex-token" ]; then mv "$w" "$w.pre-codex-token"; say "backed up existing wrapper -> $w.pre-codex-token"; fi
    cat > "$w" <<EOF
#!/usr/bin/env bash
exec $bin codex run "\$@"
EOF
    chmod +x "$w"
    say "installed $w -> ai-token codex run"
    case ":$PATH:" in *":$AI_TOKEN_REAL_HOME/bin:"*) ;; *) say "NOTE: add \$HOME/bin to your PATH for 'codex' to resolve to the wrapper." ;; esac
}

codex_cmd_maintain() {
    # Leader cron: publish all leader-role profiles.
    local p rc=0
    for p in $(codex_all_profiles); do
        [ "$(codex_role_of "$p")" = leader ] || continue
        ( codex_publish_profile "$p" ) || { say "  (skipped $p)"; rc=1; }
    done
    return $rc
}

codex_dispatch() {
    [ $# -eq 0 ] && { codex_cmd_print; exit 0; }
    case "$1" in
        print) shift; codex_cmd_print "$@";;
        status) shift; while [ $# -gt 0 ]; do case "$1" in --all|-a) ALL=1; shift;; --profile|-p) CODEX_PROFILE="$2"; shift 2;; *) CODEX_PROFILE="$1"; shift;; esac; done; codex_cmd_status;;
        check) shift; p="$(codex_resolve_profile)"; [ -n "$p" ] && [ -f "$(codex_auth_file "$p")" ] && echo "ok: auth.json present for '$p' (rt=$(codex_tokens_get "$(codex_auth_file "$p")" refresh_token | grep -q "$SENTINEL_RT" && echo sentinel || echo real))" || { echo "missing: no codex auth"; exit 1; };;
        publish) shift; while [ $# -gt 0 ]; do case "$1" in --profile|-p) PROFILE="$2"; shift 2;; --all|-a) ALL=1; shift;; *) PROFILE="$1"; shift;; esac; done; codex_cmd_publish;;
        pull) shift; while [ $# -gt 0 ]; do case "$1" in --profile|-p) PROFILE="$2"; shift 2;; --all|-a) ALL=1; shift;; *) PROFILE="$1"; shift;; esac; done; codex_cmd_pull;;
        push) shift; while [ $# -gt 0 ]; do case "$1" in --profile|-p) PROFILE="$2"; shift 2;; *) PROFILE="$1"; shift;; esac; done; codex_cmd_push;;
        sync) shift; while [ $# -gt 0 ]; do case "$1" in --profile|-p) PROFILE="$2"; shift 2;; --all|-a) ALL=1; shift;; *) PROFILE="$1"; shift;; esac; done; codex_cmd_sync;;
        login) shift; codex_cmd_login "$@";;
        run) shift; codex_cmd_run "$@";;
        maintain) codex_cmd_maintain;;
        pair|setup) shift; cmd_pair_generic codex "$@";;
        install) shift; cmd_install_generic codex "$@";;
        install-wrapper) codex_cmd_install_wrapper;;
        set-url) shift; [ -n "${1:-}" ] || die "set-url: specify URL"; set_config url "$1"; say "vault URL = $1";;
        set-token) shift; [ -n "${1:-}" ] || die "set-token: specify token"; set_config token "$1"; say "vault token stored";;
        --diagnose|--diagnostics|--debug) say "ai-token $VERSION backend=codex"; say "PROFILES_DIR=$CODEX_PROFILES_DIR"; say "SHARED_DIR=$CODEX_SHARED_DIR"; say "LEGACY_AUTH=$CODEX_LEGACY_AUTH"; say "LEADER_HOST=$LEADER_HOST"; say "profiles: $(codex_all_profiles | tr '\n' ' ')";;
        --version|-v) echo "ai-token $VERSION";;
        --help|-h) sed -n '2,/^set -euo/p' "$0" | sed 's/^# \{0,1\}//;s/^#$//';;
        *) die "unknown codex command: $1 (see --help)";;
    esac
    exit 0
}


