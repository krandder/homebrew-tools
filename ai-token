        echo "$d"; return
    done
    command -v codex
}
codex_profile_path() { echo "$CODEX_PROFILES_DIR/$1"; }
codex_auth_file()    { echo "$CODEX_PROFILES_DIR/$1/.codex/auth.json"; }
codex_role_file()    { echo "$CODEX_PROFILES_DIR/$1/.role"; }
codex_shared_file()  { echo "$CODEX_SHARED_DIR/$1.json"; }
codex_role_of() {
    local p="$1"
    if [ -f "$(codex_role_file "$p")" ]; then cat "$(codex_role_file "$p")"; return; fi
    if [ "$(short_host)" = farol ]; then echo leader; else echo follower; fi
}
codex_set_role() { mkdir -p "$(codex_profile_path "$1")"; printf '%s' "$2" > "$(codex_role_file "$1")"; }
codex_all_profiles() {
    [ -d "$CODEX_PROFILES_DIR" ] || return 0
    local d name
    for d in "$CODEX_PROFILES_DIR"/*/; do
        [ -d "$d" ] || continue
        name="$(basename "$d")"
        [ -L "$CODEX_PROFILES_DIR/$name" ] && continue
        echo "$name"
    done
}
codex_resolve_profile() {
    if [ -n "${CODEX_PROFILE:-}" ]; then echo "$CODEX_PROFILE"; return; fi
    if [ -L "$CODEX_PROFILES_DIR/active" ]; then basename "$(readlink "$CODEX_PROFILES_DIR/active")"; return; fi
    local found=() p
    while IFS= read -r p; do found+=("$p"); done < <(codex_all_profiles || true)
    if [ "${#found[@]}" -eq 1 ]; then echo "${found[0]}"; return; fi
    echo ""
}
codex_email_of() { python3 - "$1" <<'PY'
import json,sys,base64
try:
    with open(sys.argv[1]) as fh:
        d=json.load(fh)
    t=d.get("tokens",{}).get("id_token","")
    p=t.split(".")[1]; p+="="*(-len(p)%4)
    print(json.loads(base64.b64decode(p)).get("email",""))
except Exception:
    print("")
