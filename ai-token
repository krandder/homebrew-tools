claude_publish_profile() { # profile
    local p="$1" af sf
    af="$(claude_canonical_file "$p")"; sf="$(claude_shared_file "$p")"
    log_event publish "$p" start "canonical=$af shared=$sf"
    [ -f "$af" ] || die "publish: missing canonical creds at $af"
    if [ "$(claude_needs_relogin_marker "$af")" = yes ]; then
        log_event publish "$p" skipped "needs-relogin"
        die "publish: '$p' is marked needs_relogin; waiting for the owner to sync fresh credentials"
    fi
    # Check if the existing access token is still valid; only refresh if needed.
    mkdir -p "$CLAUDE_SHARED_DIR" "$(dirname "$af")"
    local needs_refresh
    needs_refresh="$(claude_profile_needs_refresh "$af")"
    if [ "$needs_refresh" = "yes" ]; then
        [ "$(claude_profile_refresh_authority "$af")" != owner ] \
            || [ "${CLAUDE_TOKEN_VAULT_AUTHORITY:-no}" = yes ] \
            || die "publish: '$p' is owner-managed; the owner must sync fresh credentials (or force a vault takeover: CLAUDE_TOKEN_VAULT_AUTHORITY=yes claude-token publish --profile $p)"
        local rt resp lock rc
        rt="$(python3 -c 'import json,sys;o=json.load(open(sys.argv[1]));o=o.get("claudeAiOauth",o);print(o.get("refreshToken",""))' "$af")"
        [ -n "$rt" ] || die "publish: no refreshToken for '$p'"
        [ "$rt" = "$SENTINEL_RT" ] && die "publish: '$p' is a follower (sentinel)"
        refresh_cooldown_guard "$af" "$p" || die "publish: '$p' refresh cooldown active"
        log_event refresh "$p" start "threshold=9000s shape=json"
        lock="$(acquire_oauth_refresh_lock)" || { log_event refresh "$p" failed "lock"; die "publish: could not acquire OAuth refresh lock"; }
        log_event refresh_lock "$p" acquired "$lock"
        if ! refresh_cooldown_guard "$af" "$p"; then
            rm -f "$lock"
            log_event refresh_lock "$p" released "$lock"
            die "publish: '$p' refresh cooldown active"
        fi
        needs_refresh="$(claude_profile_needs_refresh "$af")"
        if [ "$needs_refresh" != "yes" ]; then
            rm -f "$lock"
            log_event refresh "$p" skipped "fresh-after-lock"
            claude_publish_profile "$p"
            return $?
        fi
        set +e
        resp="$(refresh_claude "$af" 2>&1)"
        rc=$?
        set -e
        if [ "$rc" -ne 0 ]; then
            case "$resp" in
                *invalid_grant*)
                    rm -f "$lock"
                    # Permanent: the RT is dead server-side. Mark + skip + alert;
                    # only a fresh owner login (synced) revives this profile.
                    claude_mark_needs_relogin "$af" "invalid_grant"
                    claude_alert_relogin "$p" "refresh token rejected (invalid_grant)"
                    log_event refresh "$p" needs-relogin "invalid_grant"
                    die "publish: '$p' needs re-login (invalid_grant); marked needs_relogin and skipped until the owner syncs fresh credentials"
                    ;;
                *)
