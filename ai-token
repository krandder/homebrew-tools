# ═══════════════════════════════════════════════════════════════════════════
CODEX_CLIENT_ID="app_EMoamEEZ73f0CkXaXp7hrann"
CODEX_TOKEN_EP="${CODEX_TOKEN_EP:-https://auth.openai.com/oauth/token}"
CODEX_PROFILES_DIR="${CODEX_PROFILES_DIR:-$AI_TOKEN_REAL_HOME/.codex-profiles}"
