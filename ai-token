# ---- Claude credential store (read/write flat oauth JSON) ----
KC_SVC="Claude Code-credentials"
kc_account() {
    if is_mac; then security find-generic-password -s "$KC_SVC" 2>/dev/null | sed -n 's/.*"acct"<blob>="\([^"]*\)".*/\1/p' | head -1; fi
}
read_oauth_json() {  # -> stdout flat oauth JSON
    if is_mac; then
        security find-generic-password -s "$KC_SVC" -w 2>/dev/null | python3 -c 'import json,sys
d=json.load(sys.stdin); o=d.get("claudeAiOauth",d) if isinstance(d,dict) else {}
print(json.dumps(o))'
    else
        local f
        for f in "$HOME/.claude/.credentials.json" "$HOME/.claude/credentials.json"; do
            [ -f "$f" ] || continue
            python3 -c 'import json,sys;d=json.load(open(sys.argv[1]));o=d.get("claudeAiOauth",d) if isinstance(d,dict) else {};print(json.dumps(o))' "$f" && return
        done
        return 1
    fi
}
claude_local_refresh_mode() {
    local oauth rt
    oauth="$(read_oauth_json 2>/dev/null)" || { echo missing; return; }
    rt="$(printf '%s' "$oauth" | python3 -c 'import json,sys;print(json.load(sys.stdin).get("refreshToken", ""))' 2>/dev/null)"
    case "$rt" in
        "$SENTINEL_RT"|vlt:*) echo follower ;;
        "") echo missing ;;
        *) echo owner ;;
    esac
}
write_oauth_json() { # oauth_str  -> keychain (wrapped) or file (flat)
    local oauth="$1"
    if is_mac; then
        local acct; acct="$(kc_account || true)"; [ -n "$acct" ] || acct="$(whoami)"
        local wrapped; wrapped="$(python3 -c 'import json,sys;print(json.dumps({"claudeAiOauth":json.loads(sys.argv[1])}))' "$oauth")"
        security add-generic-password -U -s "$KC_SVC" -a "$acct" -w "$wrapped" >/dev/null
    else
        mkdir -p "$HOME/.claude"; printf '%s\n' "$oauth" > "$HOME/.claude/.credentials.json"; chmod 600 "$HOME/.claude/.credentials.json"
    fi
}
oauth_get() { python3 -c 'import json,sys;o=json.load(open(sys.argv[1]));print(o.get(sys.argv[2],"") or "")' "$1" "$2"; }


acquire_oauth_refresh_lock() {
    local lock_dir="${CLAUDE_OAUTH_LOCK_DIR:-$HOME/.claude}" lock i now mt age delay
    lock="$lock_dir/.oauth_refresh.lock"
    mkdir -p "$lock_dir"
    for i in 1 2 3 4 5; do
        if ( set -C; printf '%s %s\n' "$$" "$(date +%s)" > "$lock" ) 2>/dev/null; then
            printf '%s\n' "$lock"
            return 0
        fi
        now="$(date +%s)"
        mt="$(stat_mtime "$lock" 2>/dev/null || echo 0)"
        age=$((now - mt))
        if [ "$age" -ge 10 ]; then
            rm -f "$lock"
            continue
        fi
        delay="$(python3 -c 'import random; print("%.3f" % (1 + random.random()))')"
        sleep "$delay"
    done
    return 1
}

