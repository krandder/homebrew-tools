                        local retry_after
                        retry_after="$(retry_after_from_error "$resp")"
                        mark_refresh_cooldown "$af" "$retry_after"
                        log_event refresh "$p" rate-limited "cooldown=${retry_after}s"
                    else
                        log_event refresh "$p" failed "transient"
                    fi
                    rm -f "$lock"
                    die "publish: refresh failed for '$p' (transient)"
                    ;;
            esac
        fi
        local profile_status
        profile_status="$(printf '%s' "$resp" | python3 -c 'import json,sys; print((json.load(sys.stdin).get("_profile_fetch") or {}).get("status","unknown"))' 2>/dev/null || echo unknown)"
        log_event profile "$p" "$profile_status" "api/oauth/profile"
