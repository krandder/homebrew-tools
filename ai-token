# refresh a Claude credentials file -> json {access_token,refresh_token,expires_in,...}
refresh_claude() { # auth_file -> stdout json
    local af="$1"
    python3 - "$af" "$CLAUDE_CLIENT_ID" "$CLAUDE_TOKEN_EP" "$CLAUDE_DEFAULT_SCOPE" "$CLAUDE_PROFILE_EP" <<'PY'
import datetime, email.utils, json, sys, urllib.request, urllib.error

af, default_cid, url, default_scope, profile_url = sys.argv[1:6]
with open(af) as fh:
    d = json.load(fh)
o = d.get("claudeAiOauth", d) if isinstance(d, dict) else {}
rt = o.get("refreshToken", "")
if not rt:
    sys.stderr.write("refresh FAILED: no refreshToken in credential file\n")
    sys.exit(1)

cid = o.get("clientId") or o.get("client_id") or d.get("clientId") or d.get("client_id") or default_cid
scope = o.get("scope") or o.get("scopes") or d.get("scope") or d.get("scopes") or default_scope
if isinstance(scope, list):
    scope = " ".join(scope)

payload = {
    "grant_type": "refresh_token",
    "refresh_token": rt,
    "client_id": cid,
}
if scope:
    payload["scope"] = scope

body = json.dumps(payload, separators=(",", ":")).encode()
req = urllib.request.Request(
    url,
    data=body,
    method="POST",
    headers={
        "Content-Type": "application/json",
        "Accept": "application/json, text/plain, */*",
        "User-Agent": "axios/1.15.2",
    },
)
try:
    with urllib.request.urlopen(req, timeout=30) as r:
        token = json.loads(r.read().decode())
except urllib.error.HTTPError as e:
    retry = e.headers.get("Retry-After") or e.headers.get("retry-after") or ""
    retry_seconds = 60
    try:
        retry_seconds = int(retry)
    except (TypeError, ValueError):
        try:
            when = email.utils.parsedate_to_datetime(retry)
            retry_seconds = max(1, int((when - datetime.datetime.now(datetime.timezone.utc)).total_seconds()))
        except (TypeError, ValueError, OverflowError):
            pass
    cf_ray = e.headers.get("CF-RAY") or e.headers.get("cf-ray") or "none"
    sys.stderr.write(f"refresh FAILED: HTTP {e.code} retry-after-seconds={retry_seconds} cf-ray={cf_ray} ")
    sys.stderr.write(e.read().decode(errors="replace")[:200] + "\n")
    sys.exit(1)

access = token.get("access_token") or ""
token["_profile_fetch"] = {"status": "skipped", "reason": "missing_access_token"}
if access:
    profile_req = urllib.request.Request(
        profile_url,
        method="GET",
        headers={
            "Authorization": f"Bearer {access}",
            "Content-Type": "application/json",
            "Cache-Control": "no-cache",
            "Accept": "application/json, text/plain, */*",
            "User-Agent": "axios/1.15.2",
        },
    )
    try:
        with urllib.request.urlopen(profile_req, timeout=10) as pr:
            token["_profile"] = json.loads(pr.read().decode())
        token["_profile_fetch"] = {"status": "ok"}
    except urllib.error.HTTPError as e:
        retry = e.headers.get("Retry-After") or e.headers.get("retry-after") or "none"
        cf_ray = e.headers.get("CF-RAY") or e.headers.get("cf-ray") or "none"
        token["_profile_fetch"] = {"status": "failed", "http": e.code, "retry_after": retry, "cf_ray": cf_ray}
        sys.stderr.write(f"profile GET failed: HTTP {e.code} retry-after={retry} cf-ray={cf_ray} ")
        sys.stderr.write(e.read().decode(errors="replace")[:200] + "\n")
    except Exception as e:
        token["_profile_fetch"] = {"status": "failed", "error": type(e).__name__}
        sys.stderr.write(f"profile GET failed: {type(e).__name__}: {e}\n")

print(json.dumps(token, separators=(",", ":")))
sys.exit(0)
PY
}

