#!/usr/bin/env bash
# ai-vault — leader-side token vault with per-user ACL and audit.
#
# Runs on farol. Enforces who may PUSH (the profile owner) and PULL (granted
# pullers / admins), publishes follower tokens, and keeps an append-only audit
# log. Claude owner snapshots are accepted without rotating their credentials;
# legacy Codex profiles retain the vault-managed refresh path.
#
# Identity: $CODEX_VAULT_USER (set by the `shell` forced-command from the SSH
# key, or by a trusted client). Falls back to $CODEX_USER, then "admin".
#
# Subcommands:
#   ai-vault receive <profile>          validate and store token JSON from
#                                          stdin, then legacy refresh+publish.
#   ai-vault sync-receive <profile>     receive a Claude owner snapshot without
#                                          refreshing or changing its authority.
#   ai-vault serve <profile>            write the follower token JSON for
#                                          <profile> to stdout. (puller/admin)
#   ai-vault enroll <profile> <owner>   register a new profile. (admin)
#   ai-vault grant  <profile> <user>    allow <user> to pull <profile>. (admin/owner)
#   ai-vault revoke <profile> <user>    remove <user>'s pull right. (admin/owner)
#   ai-vault list                       show the ACL. (admin)
#   ai-vault show-audit [N]             last N audit entries. (admin)
#   ai-vault whoami                     print identity + admin flag.
#   ai-vault shell <identity> -- <cmd>  SSH forced-command wrapper: binds the
#                                          connection to <identity> and only
#                                          allows `receive`/`serve`.

set -euo pipefail

if [ -n "${CODEX_VAULT_DIR:-}" ]; then
    VAULT_DIR="$CODEX_VAULT_DIR"
elif [ -d "$HOME/.codex-vault" ] || [ ! -d "$HOME/.ai-vault" ]; then
    VAULT_DIR="$HOME/.codex-vault"
else
    VAULT_DIR="$HOME/.ai-vault"
fi
ACL_FILE="$VAULT_DIR/acl.json"
AUDIT_FILE="$VAULT_DIR/audit.jsonl"
PROFILES_DIR="${CODEX_PROFILES_DIR:-$HOME/.codex-profiles}"
CLAUDE_PROFILES_DIR="${CLAUDE_PROFILES_DIR:-$HOME/.claude-profiles}"
SHARED_DIR="${CODEX_SHARED_DIR:-$HOME/shared/codex-tokens}"
CLAUDE_SHARED_DIR="${CLAUDE_SHARED_DIR:-$HOME/shared/claude-tokens}"
CLIENT_ID="app_EMoamEEZ73f0CkXaXp7hrann"

die() { echo "ai-vault: error: $*" >&2; exit 1; }
say() { echo "ai-vault: $*" >&2; }    # status -> stderr (stdout reserved for token data)

mkdir -p "$VAULT_DIR" "$PROFILES_DIR" "$CLAUDE_PROFILES_DIR" "$SHARED_DIR" "$CLAUDE_SHARED_DIR"
[ -f "$ACL_FILE" ] || printf '{"profiles":{},"admins":["admin"]}' > "$ACL_FILE"

current_user() { echo "${CODEX_VAULT_USER:-${CODEX_USER:-$OPERATOR}}"; }

# Operator = who runs the vault directly on the leader (admin). Forced-command
# connections override this with the key-bound identity via `shell`.
OPERATOR="$(python3 -c 'import json,sys; print(json.load(open(sys.argv[1])).get("operator","admin"))' "$ACL_FILE" 2>/dev/null || echo admin)"

# Profile ids are composite "<kind>:<name>" (e.g. "codex:operator", "claude:operator") so
# the same name can exist for both tools. ACL is keyed by the composite id.
kind_of() { local id="$1"; echo "${id%%:*}"; }
name_of() { local id="$1"; echo "${id#*:}"; }
auth_file_for() {
    local k n; k="$(kind_of "$1")"; n="$(name_of "$1")"
    case "$k" in
        claude) echo "$CLAUDE_PROFILES_DIR/$n/.claude/credentials.json" ;;
        *)      echo "$PROFILES_DIR/$n/.codex/auth.json" ;;
    esac
}
shared_file_for() {
    local k n; k="$(kind_of "$1")"; n="$(name_of "$1")"
    case "$k" in
        claude) echo "$CLAUDE_SHARED_DIR/$n.json" ;;
        *)      echo "$SHARED_DIR/$n.json" ;;
    esac
}
publish_tool_for() { case "$(kind_of "$1")" in claude) echo claude-token ;; *) echo codex-token ;; esac; }

# ---- ACL predicates ----
is_admin() { python3 - "$ACL_FILE" "$(current_user)" <<'PY'
import json,sys
d=json.load(open(sys.argv[1])); u=sys.argv[2]
sys.exit(0 if u in d.get("admins",[]) else 1)
PY
}
can_push() { python3 - "$ACL_FILE" "$1" "$(current_user)" <<'PY'
import json,sys
d=json.load(open(sys.argv[1])); p,u=sys.argv[2],sys.argv[3]
prof=d.get("profiles",{}).get(p,{})
sys.exit(0 if (u in d.get("admins",[]) or u==prof.get("owner","")) else 1)
PY
}
can_pull() { python3 - "$ACL_FILE" "$1" "$(current_user)" <<'PY'
import json,sys
d=json.load(open(sys.argv[1])); p,u=sys.argv[2],sys.argv[3]
prof=d.get("profiles",{}).get(p,{})
ok = u in d.get("admins",[]) or u==prof.get("owner","") or u in prof.get("pullers",[])
sys.exit(0 if ok else 1)
PY
}

audit() { # profile action status [detail]
    local p="$1" action="$2" status="$3" detail="${4:-}"
    python3 - "$AUDIT_FILE" "$(current_user)" "$p" "$action" "$status" "$detail" "${SSH_CONNECTION:-}" <<'PY'
import json,sys,os,datetime
f,actor,p,action,status,detail,conn=sys.argv[1:8]
with open(f,"a") as fh:
    fh.write(json.dumps({"ts":datetime.datetime.now(datetime.timezone.utc).isoformat(),
                         "actor":actor,"profile":p,"action":action,"status":status,
                         "detail":detail,"from":conn})+"\n")
PY
}

require_admin() { is_admin || die "'$(current_user)' is not an admin (need: $*)"; }

# ---- core ops ----
cmd_receive() { # profile   (stdin = token JSON)
    local p="$1" af sf tmp rc kind
    can_push "$p" || { audit "$p" push denied "not owner"; die "receive: '$(current_user)' may not push '$p' (not the owner)"; }
    kind="$(kind_of "$p")"
    af="$(auth_file_for "$p")"; sf="$(shared_file_for "$p")"; mkdir -p "$(dirname "$af")" "$(dirname "$sf")"
    tmp="$(mktemp)"; cat > "$tmp"            # capture pushed token from stdin

    # Claude owner machines keep native refresh authority. Receive their fresh
    # snapshot transactionally, but never rotate it on the vault.
    if [ "$kind" = claude ] && [ "${CLAUDE_OWNER_SYNC:-0}" = 1 ]; then
        set +e
        python3 - "$tmp" "$af" "$sf" "$(name_of "$p")" <<'PY'
import datetime, fcntl, json, os, sys, tempfile, time

incoming_path, auth_path, shared_path, profile = sys.argv[1:5]
sentinel = "__follower_no_refresh__"

try:
    incoming = json.load(open(incoming_path))
except Exception as exc:
    sys.exit("ai-vault: invalid token JSON: " + str(exc))
oauth = incoming.get("claudeAiOauth", incoming) if isinstance(incoming, dict) else {}
refresh = oauth.get("refreshToken", "")
access = oauth.get("accessToken", "")
try:
    expires = int(float(oauth.get("expiresAt") or 0))
except Exception:
    expires = 0
if not refresh or refresh == sentinel or refresh.startswith("vlt:"):
    sys.exit("ai-vault: Claude sync requires a real owner refresh token")
if not access or expires <= int((time.time() + 60) * 1000):
    sys.exit("ai-vault: Claude sync requires a fresh access token")

def atomic_json(path, value):
    directory = os.path.dirname(path)
    fd, temporary = tempfile.mkstemp(prefix=".token-", dir=directory)
    try:
        with os.fdopen(fd, "w") as handle:
            json.dump(value, handle, indent=2)
            handle.write("\n")
            handle.flush()
            os.fsync(handle.fileno())
        os.chmod(temporary, 0o600)
        os.replace(temporary, path)
    finally:
        if os.path.exists(temporary):
            os.unlink(temporary)

lock_path = auth_path + ".lock"
with open(lock_path, "a+") as lock:
    os.chmod(lock_path, 0o600)
    fcntl.flock(lock, fcntl.LOCK_EX)
    existing_oauth = {}
    if os.path.exists(auth_path):
        try:
            existing = json.load(open(auth_path))
            existing_oauth = existing.get("claudeAiOauth", existing)
        except Exception:
            existing_oauth = {}
    try:
        current_expires = int(float(existing_oauth.get("expiresAt") or 0))
    except Exception:
        current_expires = 0
    current_refresh = existing_oauth.get("refreshToken", "")
    if expires < current_expires:
        sys.exit("ai-vault: stale Claude credential snapshot rejected")
    if expires == current_expires and current_refresh and refresh != current_refresh:
        sys.exit("ai-vault: conflicting Claude credential rotation rejected")

    stored = dict(incoming)
    if "claudeAiOauth" not in stored:
        stored = {"claudeAiOauth": dict(oauth)}
    stored["claudeTokenSync"] = {
        "refreshAuthority": "owner",
        "receivedAt": datetime.datetime.now(datetime.timezone.utc).isoformat(),
    }
    atomic_json(auth_path, stored)
    published = dict(oauth)
    published["refreshToken"] = sentinel
    atomic_json(shared_path, {
        "claudeAiOauth": published,
        "profile": profile,
        "published_at": datetime.datetime.now(datetime.timezone.utc).isoformat(),
        "note": "owner-synced; vault did not refresh",
    })
PY
        rc=$?
        set -e
        rm -f "$tmp"
        [ "$rc" -eq 0 ] || { audit "$p" sync rejected "stale/invalid/conflicting"; return "$rc"; }
        audit "$p" sync ok "by $(current_user); owner remains refresh authority"
        say "synced '$p' from $(current_user); local owner remains refresh authority"
        return 0
    fi

    set +e
    python3 - "$tmp" "$af" <<'PY'
import json,sys,os
tmp,af=sys.argv[1],sys.argv[2]
try: data=json.load(open(tmp))
except Exception as e: sys.exit("ai-vault: invalid token JSON: "+str(e))
# accept codex ({tokens:{refresh_token}}) or claude ({refreshToken} / {claudeAiOauth:{refreshToken}})
def rt(o):
    return ((o.get("tokens") or {}).get("refresh_token") or o.get("refreshToken")
            or (o.get("claudeAiOauth") or {}).get("refreshToken") or "")
if not rt(data): sys.exit("ai-vault: token has no refresh_token")
json.dump(data,open(af,"w"),indent=2); os.chmod(af,0o600)
PY
    rc=$?
    set -e
    rm -f "$tmp"
    [ "$rc" -eq 0 ] || { audit "$p" push failed "bad token"; exit "$rc"; }
    "$(publish_tool_for "$p")" publish --profile "$(name_of "$p")" >/dev/null 2>&1 \
        || { audit "$p" publish deferred "rate-limited/pending"; say "received '$p' ($kind) — token stored; publish deferred (cron will refresh)."; return 0; }
    audit "$p" push ok "by $(current_user) ($kind)"
    say "received '$p' ($kind) from $(current_user); refreshed + published"
}

cmd_serve() { # profile -> stdout follower token JSON
    local p="$1" sf
    sf="$(shared_file_for "$p")"
    can_pull "$p" || { audit "$p" pull denied "not authorized"; die "serve: '$(current_user)' is not authorized to pull '$p'"; }
    [ -f "$sf" ] || { audit "$p" pull failed "no published token"; die "serve: no published token for '$p' (owner must push first)"; }
    if [ "$(kind_of "$p")" = claude ] && ! cmd_access "$p" >/dev/null 2>&1; then
        audit "$p" pull failed "stale published token"
        die "serve: no fresh published token for '$p' (owner must sync again)"
    fi
    audit "$p" pull ok "by $(current_user)"
    cat "$sf"
}

# access: print ONLY the current access token (no refresh token) for a profile.
# Used by transparent followers (ANTHROPIC_AUTH_TOKEN) so they never hold/refresh.
cmd_access() { # id -> stdout: access token (plain text)
    local p="$1" sf kind
    can_pull "$p" || { audit "$p" access denied "not authorized"; die "access: '$(current_user)' is not authorized for '$p'"; }
    sf="$(shared_file_for "$p")"
    kind="$(kind_of "$p")"
    [ -f "$sf" ] || die "access: no published token for '$p'"
    python3 - "$sf" "$kind" <<'PY'
import json, sys, time

d=json.load(open(sys.argv[1])); o=d.get("claudeAiOauth",d)
token=o.get("accessToken") or (d.get("tokens") or {}).get("access_token") or ""
if sys.argv[2] == "claude":
    try:
        fresh=float(o.get("expiresAt") or 0)/1000 > time.time()+60
    except Exception:
        fresh=False
    if not token or not fresh:
        sys.exit("ai-vault: access token is missing or stale")
sys.stdout.write(token)
PY
}

cmd_enroll() { # kind name [owner]
    require_admin enroll
    local kind="$1" p="$2" owner="${3:-$2}"
    case "$kind" in codex|claude) ;; *) die "enroll: first arg must be kind (codex|claude)" ;; esac
    local id="$kind:$p"
    python3 - "$ACL_FILE" "$id" "$owner" "$kind" <<'PY'
import json,sys
f,id,owner,kind=sys.argv[1],sys.argv[2],sys.argv[3],sys.argv[4]
d=json.load(open(f))
d.setdefault("profiles",{})[id]={"owner":owner,"pullers":[owner],"kind":kind}
json.dump(d,open(f,"w"),indent=2)
print(f"enrolled {id} (owner={owner})")
PY
    audit "$id" enroll ok "owner=$owner"
}

# Issue a per-user API token for the HTTPS front-end (ai-vault-http).
# Stores sha256(token) -> user in tokens.json; prints the plaintext token once.
cmd_token() { # user
    require_admin token
    local user="$1" plain
    [ -n "$user" ] || die "token: specify a user"
    plain="$(python3 -c 'import secrets;print(secrets.token_urlsafe(32))')"
    python3 - "$VAULT_DIR" "$user" "$plain" <<'PY'
import json,sys,hashlib,os
vd,user,plain=sys.argv[1],sys.argv[2],sys.argv[3]
f=os.path.join(vd,"tokens.json")
d=json.load(open(f)) if os.path.exists(f) else {}
d[hashlib.sha256(plain.encode()).hexdigest()]=user
json.dump(d,open(f,"w"),indent=2); os.chmod(f,0o600)
PY
    audit "$user" token ok "issued by $(current_user)"
    printf '%s\n' "$plain"
}

# approve <user> <pubkey-line>: enroll the user and install their SSH key with a
# forced command that binds their identity (no shell). Idempotent.
cmd_approve() { # user pubkey-line   (enrolls codex:<user> + claude:<user>, installs forced-command key)
    require_admin approve
    local user="$1" line="${2:-}" authkeys="${CODEX_VAULT_AUTH_KEYS:-$HOME/.ssh/authorized_keys}"
    [ -n "$line" ] || die "approve: pass the pubkey line printed by '*-token pair' (as one quoted arg)"
    cmd_enroll codex "$user" "$user" >/dev/null || true
    cmd_enroll claude "$user" "$user" >/dev/null || true
    local entry
    case "$line" in
        *ai-vault\ shell\ "$user"*) entry="$line" ;;
        ssh-*) entry="command=\"ai-vault shell $user\",no-pty,no-port-forwarding,no-X11-forwarding,no-agent-forwarding $line" ;;
        *) die "approve: unrecognized pubkey line (expected 'ssh-...' or a full command=... line)" ;;
    esac
    mkdir -p "$(dirname "$authkeys")"; touch "$authkeys"
    grep -qF "$entry" "$authkeys" 2>/dev/null || printf '%s\n' "$entry" >> "$authkeys"
    audit "$user" approve ok "by $(current_user)"
    say "approved '$user' (codex+claude enrolled + forced-command key installed in $authkeys)"
}

# onboard <user>: HTTPS onboarding in one command — enroll codex+claude and
# print a one-time API token (the user runs: codex-token install --token ... --user <user>).
cmd_onboard() {
    require_admin onboard
    local user="$1"
    [ -n "$user" ] || die "onboard: specify a user handle (e.g. fred)"
    cmd_enroll codex "$user" "$user" >/dev/null 2>&1 || true
    cmd_enroll claude "$user" "$user" >/dev/null 2>&1 || true
    audit "$user" onboard ok "by $(current_user)"
    say "onboarded '$user' (codex:$user + claude:$user). One-time API token — send it securely; it is shown once:" >&2
    cmd_token "$user"
}

# ---- pairing flow (magical onboarding) ----
# Follower posts {user,code,secret_hash} (POST /pair); operator runs
# `pair-approve <code>`; follower polls (POST /pair/<code>/poll) with the long
# secret and receives the API token. Records expire after 10 min.
PAIRING_FILE="$VAULT_DIR/pairings.json"
PAIR_TTL=600

cmd_pair_create() { # user code secret_hash   (no auth — pairing entry point)
    local user="$1" code="$2" sh="$3"
    [ -n "$user" ] && [ -n "$code" ] && [ -n "$sh" ] || die "pair-create: need user code secret_hash"
    python3 - "$PAIRING_FILE" "$user" "$code" "$sh" "$PAIR_TTL" <<'PY'
import json,sys,os,time
f,user,code,sh,ttl=sys.argv[1],sys.argv[2],sys.argv[3],sys.argv[4],int(sys.argv[5])
d=json.load(open(f)) if os.path.exists(f) else {}
now=time.time()
d={k:v for k,v in d.items() if now-float(v.get("created_at",0))<ttl}   # expire old
d[code]={"user":user,"secret_hash":sh,"status":"pending","created_at":now}
json.dump(d,open(f,"w"),indent=2); os.chmod(f,0o600)
PY
    say "pairing request: code=$code user=$user"
}

cmd_pair_poll() { # code secret  -> stdout JSON {status[,token,user]}  (no auth)
    local code="$1" secret="$2"
    python3 - "$PAIRING_FILE" "$code" "$secret" "$PAIR_TTL" <<'PY'
import json,sys,os,time,hashlib
f,code,secret,ttl=sys.argv[1],sys.argv[2],sys.argv[3],int(sys.argv[4])
d=json.load(open(f)) if os.path.exists(f) else {}
rec=d.get(code)
if not rec: print(json.dumps({"status":"unknown"})); sys.exit()
if time.time()-float(rec.get("created_at",0))>ttl: print(json.dumps({"status":"expired"})); sys.exit()
if rec.get("status")!="approved": print(json.dumps({"status":"pending"})); sys.exit()
if hashlib.sha256(secret.encode()).hexdigest()!=rec.get("secret_hash"): print(json.dumps({"status":"forbidden"})); sys.exit()
print(json.dumps({"status":"approved","token":rec.get("token",""),"user":rec.get("user","")}))
PY
}

ensure_pair_profile() { # kind user -> create once, otherwise preserve ACL
    local kind="$1" user="$2" id="$1:$2" owner
    owner="$(profile_owner "$id")"
    if [ -z "$owner" ]; then
        cmd_enroll "$kind" "$user" "$user" >/dev/null
    else
        [ "$owner" = "$user" ] || die "pair-approve: '$id' is owned by '$owner', not '$user'"
    fi
}

cmd_pair_approve() { # code   (admin) — enroll codex+claude, issue token, mark approved
    require_admin pair-approve
    local code="$1" user token
    [ -n "$code" ] || die "pair-approve: specify the pairing code"
    user="$(python3 - "$PAIRING_FILE" "$code" "$PAIR_TTL" <<'PY'
import json,sys,os,time
f,code,ttl=sys.argv[1],sys.argv[2],int(sys.argv[3])
d=json.load(open(f)) if os.path.exists(f) else {}
rec=d.get(code)
if rec and time.time()-float(rec.get("created_at",0))<ttl: print(rec.get("user",""))
PY
)"
    [ -n "$user" ] || die "pair-approve: unknown or expired code '$code'"
    ensure_pair_profile codex "$user"
    ensure_pair_profile claude "$user"
    token="$(cmd_token "$user")"
    python3 - "$PAIRING_FILE" "$code" "$token" <<'PY'
import json,sys,os
f,code,token=sys.argv[1],sys.argv[2],sys.argv[3]
d=json.load(open(f)); d[code]["status"]="approved"; d[code]["token"]=token
json.dump(d,open(f,"w"),indent=2); os.chmod(f,0o600)
PY
    audit "$user" pair-approve ok "code=$code"
    say "approved pairing code '$code' for user '$user' (codex+claude enrolled); the follower will auto-complete." >&2
}

cmd_grant() { # profile user
    local p="$1" u="$2"
    { is_admin || [ "$(profile_owner "$p")" = "$(current_user)" ]; } || die "grant: only admin/owner may grant '$p'"
    python3 - "$ACL_FILE" "$p" "$u" <<'PY'
import json,sys
f,p,u=sys.argv[1],sys.argv[2],sys.argv[3]
d=json.load(open(f)); prof=d.setdefault("profiles",{}).setdefault(p,{"owner":"","pullers":[]})
if u not in prof["pullers"]: prof["pullers"].append(u)
json.dump(d,open(f,"w"),indent=2); print(f"granted {u} pull on {p}")
PY
    audit "$p" grant ok "to $u"
}

cmd_revoke() { # profile user
    local p="$1" u="$2"
    { is_admin || [ "$(profile_owner "$p")" = "$(current_user)" ]; } || die "revoke: only admin/owner may revoke"
    python3 - "$ACL_FILE" "$p" "$u" <<'PY'
import json,sys
f,p,u=sys.argv[1],sys.argv[2],sys.argv[3]
d=json.load(open(f)); prof=d.get("profiles",{}).get(p,{})
prof["pullers"]=[x for x in prof.get("pullers",[]) if x!=u]
d["profiles"][p]=prof; json.dump(d,open(f,"w"),indent=2); print(f"revoked {u} on {p}")
PY
    audit "$p" revoke ok "from $u"
}

profile_owner() { python3 - "$ACL_FILE" "$1" <<'PY'
import json,sys
print(json.load(open(sys.argv[1])).get("profiles",{}).get(sys.argv[2],{}).get("owner",""))
PY
}

cmd_list() {
    require_admin list
    python3 - "$ACL_FILE" <<'PY'
import json,sys
d=json.load(open(sys.argv[1]))
print("admins:", ", ".join(d.get("admins",[])))
for p,info in sorted(d.get("profiles",{}).items()):
    print(f"  {p:14} {info.get('kind','codex'):6} owner={info.get('owner','?'):10} pullers={','.join(info.get('pullers',[]))}")
PY
}

cmd_show_audit() {
    require_admin audit
    local n="${1:-50}"
    [ -f "$AUDIT_FILE" ] || { echo "(no audit entries)"; return; }
    tail -n "$n" "$AUDIT_FILE"
}

cmd_whoami() { echo "identity: $(current_user)   admin: $(is_admin && echo yes || echo no)"; }
cmd_authorize_pull() {
    can_pull "$1" || die "authorize-pull: '$(current_user)' is not authorized for '$1'"
}

# SSH forced-command wrapper: binds the connection to <identity> and only allows
# receive/sync-receive/serve. Put in authorized_keys as:
#   command="ai-vault shell stale-a",no-pty,no-port-forwarding,... ssh-ed25519 AAA... stale-a@laptop
cmd_shell() {
    local ident="$1"; shift
    [ "${1:-}" = "--" ] && shift
    export CODEX_VAULT_USER="$ident"
    local cmd="${SSH_ORIGINAL_COMMAND:-${*:-}}"
    cmd="${cmd#ai-vault }"   # tolerate "ai-vault receive X" form
    [ -n "$cmd" ] || die "shell: no command (interactive logins are not permitted)"
    case "$cmd" in
        receive\ *|sync-receive\ *|serve\ *) exec ai-vault $cmd ;;
        whoami) cmd_whoami ;;
        *) die "shell: disallowed command (only receive/sync-receive/serve): $cmd" ;;
    esac
}

usage() { sed -n '2,/^$/p' "$0" | sed 's/^# \?//' >&2; }

# ---- dispatch ----
[ $# -ge 1 ] || { usage; exit 1; }
cmd="$1"; shift || true
case "$cmd" in
    receive)    cmd_receive "$@" ;;
    sync-receive) CLAUDE_OWNER_SYNC=1 cmd_receive "$@" ;;
    serve)      cmd_serve "$@" ;;
    access)     cmd_access "$1" ;;
    authorize-pull) cmd_authorize_pull "$1" ;;
    enroll)      cmd_enroll "$@" ;;
    onboard)     cmd_onboard "$1" ;;
    pair-create) cmd_pair_create "$@" ;;
    pair-poll)   cmd_pair_poll "$@" ;;
    pair-approve) cmd_pair_approve "$1" ;;
    approve)     cmd_approve "$@" ;;
    token)       cmd_token "$1" ;;
    grant)      cmd_grant "$@" ;;
    revoke)     cmd_revoke "$@" ;;
    list)       cmd_list ;;
    show-audit) cmd_show_audit "$@" ;;
    whoami)     cmd_whoami ;;
    shell)      cmd_shell "$@" ;;
    -h|--help)  usage ;;
    *)          die "unknown command: $cmd (see --help)" ;;
esac
