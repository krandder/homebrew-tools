#!/usr/bin/env python3
"""ai-vault-http — HTTPS front-end for the codex-vault.

Authenticates each request with a per-user bearer API token (sha256-hashed at
rest in tokens.json -> user), then dispatches to `codex-vault` with that
identity, reusing all the existing ACL / audit / refresh+publish logic.

Run it behind Cloudflare Tunnel (+ Caddy) at e.g. https://vault.ekelvin.com.
Bind to localhost only; the tunnel terminates TLS and Caddy routes by Host.

Routes:
  GET  /healthz                 (no auth) liveness
  POST /push/<profile>          (owner)   body = token JSON -> receive+refresh+publish
  GET  /pull/<profile>          (puller)  -> follower token JSON
  POST /debug-logs/<tool>       (auth)    body = redacted debug bundle -> vault storage
  GET  /status                  (admin)   -> ACL listing

Env:
  CODEX_VAULT_DIR     default ~/.codex-vault      (tokens.json lives here)
  CODEX_VAULT_LISTEN  default 127.0.0.1:8231
"""
import hashlib
import http.server
import json
import os
import datetime
import socketserver
import subprocess
import sys
from pathlib import Path

VAULT_DIR = Path(os.environ.get("CODEX_VAULT_DIR", str(Path.home() / ".codex-vault")))
TOKENS_FILE = VAULT_DIR / "tokens.json"
HTTP_EVENTS_FILE = VAULT_DIR / "http-events.jsonl"
DEBUG_LOG_DIR = VAULT_DIR / "debug-logs"
LISTEN = os.environ.get("CODEX_VAULT_LISTEN", "127.0.0.1:8231")
ALLOWED_PROFILE = set("abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789-_.")
ALLOWED_TOOL = set("abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789-_.")


def load_tokens():
    if TOKENS_FILE.exists():
        try:
            return json.loads(TOKENS_FILE.read_text())
        except Exception:
            return {}
    return {}


def identity_for(auth_header):
    if not auth_header or not auth_header.startswith("Bearer "):
        return None
    h = hashlib.sha256(auth_header[7:].strip().encode()).hexdigest()
    return load_tokens().get(h)


def run_vault(user, args, body=None):
    env = dict(os.environ)
    env["CODEX_VAULT_USER"] = user
    env["CODEX_VAULT_DIR"] = str(VAULT_DIR)
    return subprocess.run(
        ["ai-vault", *args],
        input=body, capture_output=True, text=True, env=env,
    )


def run_vault_anon(args, body=None):
    # pairing routes run without a bound identity (no CODEX_VAULT_USER)
    env = dict(os.environ)
    env["CODEX_VAULT_DIR"] = str(VAULT_DIR)
    return subprocess.run(["ai-vault", *args], input=body, capture_output=True, text=True, env=env)


def valid_profile(p):
    return bool(p) and all(c in ALLOWED_PROFILE for c in p)

def valid_tool(p):
    return bool(p) and all(c in ALLOWED_TOOL for c in p)

def server_event(event, user="", profile="", status="", detail=""):
    try:
        HTTP_EVENTS_FILE.parent.mkdir(parents=True, exist_ok=True)
        rec = {
            "ts": datetime.datetime.now(datetime.timezone.utc).isoformat(),
            "event": event,
            "user": user,
            "profile": profile,
            "status": status,
            "detail": detail,
        }
        with HTTP_EVENTS_FILE.open("a") as fh:
            fh.write(json.dumps(rec, separators=(",", ":")) + "\n")
        os.chmod(HTTP_EVENTS_FILE, 0o600)
    except Exception as e:
        sys.stderr.write("server_event failed: %s\n" % e)

def parse_id(rest):  # "codex/kas" -> ("codex", "kas") or None
    parts = rest.split("/", 1)
    if len(parts) != 2 or parts[0] not in ("codex", "claude") or not valid_profile(parts[1]):
        return None
    return parts[0], parts[1]


# ---- Transparent OAuth refresh broker (single owner) ----
# Claude Code on a follower refreshes NORMALLY (real refresh-on-expiry), but its
# refresh is routed here by a local transparent proxy. We hold the canonical
# refresh token, perform the rotation with Anthropic, store the rotated token,
# and hand the follower back a fresh access token + a DUMMY refresh token
# ("vlt:<account>:<nonce>") so the follower can never rotate/invalidate us.
CLAUDE_TOKEN_EP = "https://platform.claude.com/v1/oauth/token"
CLAUDE_PROFILE_EP = "https://api.anthropic.com/api/oauth/profile"
CLAUDE_CLIENT_ID = "9d1c250a-e61b-44d9-88ed-5944d1962f5e"
CLAUDE_DEFAULT_SCOPE = "user:profile user:inference user:sessions:claude_code user:mcp_servers user:file_upload"


def broker_refresh(account):
    """Refresh using the canonical refresh token for <account>; return (access, expires_in).
    Stores the rotated refresh token as the new canonical."""
    import urllib.request, urllib.error, time
    af = os.path.expanduser(f"~/.claude-profiles/{account}/.claude/credentials.json")
    d = json.load(open(af))
    o = d.get("claudeAiOauth", d)
    rt = o.get("refreshToken", "")
    if not rt or rt.startswith("vlt:"):
        raise RuntimeError("no canonical refresh token for " + account)
    scope = o.get("scope") or o.get("scopes") or CLAUDE_DEFAULT_SCOPE
    if isinstance(scope, list):
        scope = " ".join(scope)
    body = json.dumps({
        "grant_type": "refresh_token",
        "client_id": o.get("clientId") or o.get("client_id") or CLAUDE_CLIENT_ID,
        "refresh_token": rt,
        "scope": scope,
    }, separators=(",", ":")).encode()
    req = urllib.request.Request(
        CLAUDE_TOKEN_EP, data=body, method="POST",
        headers={"Content-Type": "application/json",
                 "Accept": "application/json, text/plain, */*", "User-Agent": "axios/1.15.2"})
    server_event("broker-refresh", account, "claude:" + account, "start", "shape=json")
    try:
        resp = urllib.request.urlopen(req, timeout=30)
    except urllib.error.HTTPError as e:
        retry = e.headers.get("Retry-After") or e.headers.get("retry-after") or "none"
        cf_ray = e.headers.get("CF-RAY") or e.headers.get("cf-ray") or "none"
        server_event("broker-refresh", account, "claude:" + account, "failed", f"http={e.code} retry-after={retry} cf-ray={cf_ray}")
        raise
    j = json.loads(resp.read())
    profile = None
    profile_req = urllib.request.Request(
        CLAUDE_PROFILE_EP,
        method="GET",
        headers={
            "Authorization": f"Bearer {j['access_token']}",
            "Content-Type": "application/json",
            "Cache-Control": "no-cache",
            "Accept": "application/json, text/plain, */*",
            "User-Agent": "axios/1.15.2",
        },
    )
    try:
        profile_resp = urllib.request.urlopen(profile_req, timeout=10)
        profile = json.loads(profile_resp.read())
        server_event("broker-profile", account, "claude:" + account, "ok", "api/oauth/profile")
    except urllib.error.HTTPError as e:
        retry = e.headers.get("Retry-After") or e.headers.get("retry-after") or "none"
        cf_ray = e.headers.get("CF-RAY") or e.headers.get("cf-ray") or "none"
        server_event("broker-profile", account, "claude:" + account, "failed", f"http={e.code} retry-after={retry} cf-ray={cf_ray}")
    except Exception as e:
        server_event("broker-profile", account, "claude:" + account, "failed", type(e).__name__)

    # store rotated refresh token as the new canonical (we are the sole owner)
    o["accessToken"] = j["access_token"]
    o["refreshToken"] = j["refresh_token"]
    o["expiresAt"] = int(time.time() * 1000) + int(j.get("expires_in", 28800)) * 1000
    if j.get("scope"):
        o["scopes"] = [s for s in str(j.get("scope")).split(" ") if s]
    if isinstance(profile, dict):
        account_info = profile.get("account") or {}
        org = profile.get("organization") or {}
        org_type = org.get("organization_type")
        o["profile"] = profile
        o["profileFetchedAt"] = int(time.time() * 1000)
        o["subscriptionType"] = {
            "claude_max": "max",
            "claude_pro": "pro",
            "claude_enterprise": "enterprise",
            "claude_team": "team",
        }.get(org_type)
        o["rateLimitTier"] = org.get("rate_limit_tier")
        o["seatTier"] = org.get("seat_tier")
        o["hasExtraUsageEnabled"] = org.get("has_extra_usage_enabled")
        o["billingType"] = org.get("billing_type")
        o["ccOnboardingFlags"] = org.get("cc_onboarding_flags") or {}
        o["claudeCodeTrialEndsAt"] = org.get("claude_code_trial_ends_at")
        o["claudeCodeTrialDurationDays"] = org.get("claude_code_trial_duration_days")
        if account_info.get("display_name") is not None:
            o["displayName"] = account_info.get("display_name")
        if account_info.get("created_at") is not None:
            o["accountCreatedAt"] = account_info.get("created_at")
        if org.get("subscription_created_at") is not None:
            o["subscriptionCreatedAt"] = org.get("subscription_created_at")
    d["claudeAiOauth"] = o
    json.dump(d, open(af, "w"), indent=2)
    os.chmod(af, 0o600)
    server_event("broker-refresh", account, "claude:" + account, "ok", "updated-canonical")
    return j["access_token"], int(j.get("expires_in", 28800))


class Handler(http.server.BaseHTTPRequestHandler):
    protocol_version = "HTTP/1.1"

    def _send(self, code, body="", ctype="application/json"):
        if isinstance(body, str):
            body = body.encode()
        self.send_response(code)
        self.send_header("Content-Type", ctype)
        self.send_header("Content-Length", str(len(body)))
        self.end_headers()
        if self.command != "HEAD" and body:
            self.wfile.write(body)

    def log_message(self, fmt, *a):
        sys.stderr.write("%s - %s\n" % (self.address_string(), fmt % a))

    def _identity(self):
        user = identity_for(self.headers.get("Authorization", ""))
        if not user:
            self._send(401, '{"error":"unauthorized"}')
        return user

    def do_GET(self):
        if self.path == "/healthz":
            return self._send(200, '{"ok":true}')
        user = self._identity()
        if not user:
            return
        if self.path == "/status":
            p = run_vault(user, ["list"])
            return self._send(200 if p.returncode == 0 else 500, p.stdout or p.stderr)
        if self.path.startswith("/access/"):
            pid = parse_id(self.path[len("/access/"):])
            if not pid:
                return self._send(400, '{"error":"bad profile; use /access/<kind>/<name>"}')
            p = run_vault(user, ["access", pid[0] + ":" + pid[1]])
            if p.returncode == 0 and p.stdout:
                server_event("access", user, pid[0] + ":" + pid[1], "ok", "")
                return self._send(200, p.stdout, ctype="text/plain")
            server_event("access", user, pid[0] + ":" + pid[1], "failed", p.stderr.strip().splitlines()[-1] if p.stderr.strip() else "")
            return self._send(403 if "authorized" in p.stderr else 404,
                              '{"error":"' + (p.stderr.strip().splitlines()[-1] or 'failed') + '"}')
        if self.path.startswith("/pull/"):
            pid = parse_id(self.path[len("/pull/"):])
            if not pid:
                return self._send(400, '{"error":"bad profile; use /pull/<kind>/<name>"}')
            p = run_vault(user, ["serve", pid[0] + ":" + pid[1]])
            if p.returncode == 0:
                server_event("pull", user, pid[0] + ":" + pid[1], "ok", "")
                return self._send(200, p.stdout)
            server_event("pull", user, pid[0] + ":" + pid[1], "failed", p.stderr.strip().splitlines()[-1] if p.stderr.strip() else "")
            return self._send(403 if "authorized" in p.stderr else 404,
                              '{"error":"' + (p.stderr.strip().splitlines()[-1] or 'failed') + '"}')
        return self._send(404, '{"error":"not found"}')

    def do_POST(self):
        length = int(self.headers.get("Content-Length", 0) or 0)
        body = self.rfile.read(length).decode() if length else ""
        # ---- unauthenticated pairing routes ----
        if self.path == "/pair":
            try:
                j = json.loads(body) if body else {}
                user, code, sh = j.get("user", ""), j.get("code", ""), j.get("secret_hash", "")
            except Exception:
                return self._send(400, '{"error":"bad json"}')
            if not (user and code and sh):
                return self._send(400, '{"error":"need user, code, secret_hash"}')
            p = run_vault_anon(["pair-create", user, code, sh])
            return self._send(200 if p.returncode == 0 else 500, p.stdout or p.stderr or '{"ok":true}')
        if self.path.startswith("/pair/") and self.path.endswith("/poll"):
            code = self.path[len("/pair/"):-len("/poll")]
            try:
                secret = (json.loads(body) if body else {}).get("secret", "")
            except Exception:
                secret = ""
            p = run_vault_anon(["pair-poll", code, secret])
            out = (p.stdout or "").strip()
            http = 200
            if '"pending"' in out:
                http = 202
            elif '"unknown"' in out or '"expired"' in out:
                http = 404
            elif '"forbidden"' in out:
                http = 403
            return self._send(http, out or '{"error":"failed"}')
        # ---- authenticated routes ----
        user = self._identity()
        if not user:
            return
        if self.path.startswith("/debug-logs/"):
            tool = self.path[len("/debug-logs/"):]
            if not valid_tool(tool):
                return self._send(400, '{"error":"bad tool name"}')
            if length > 1000000:
                return self._send(413, '{"error":"debug log bundle too large"}')
            ts = datetime.datetime.now(datetime.timezone.utc).strftime("%Y%m%dT%H%M%SZ")
            out_dir = DEBUG_LOG_DIR / user
            out_dir.mkdir(parents=True, exist_ok=True)
            out = out_dir / f"{ts}-{tool}.json"
            out.write_text(body)
            os.chmod(out, 0o600)
            server_event("debug-logs", user, "", "ok", str(out))
            return self._send(200, json.dumps({"ok": True, "stored": str(out)}))
        # Transparent OAuth refresh broker: a follower's refresh (routed here by
        # its local proxy) is fulfilled with the canonical refresh token.
        if self.path in ("/v1/oauth/token", "/oauth/token"):
            from urllib.parse import parse_qs
            import secrets as _sec
            form = parse_qs(body)
            grant = (form.get("grant_type") or [""])[0]
            dummy = (form.get("refresh_token") or [""])[0]
            if grant != "refresh_token":
                return self._send(400, '{"error":"unsupported_grant_type"}')
            account = dummy.split(":", 2)[1] if dummy.startswith("vlt:") else user
            try:
                access, exp = broker_refresh(account)
            except Exception as e:
                sys.stderr.write("broker refresh failed: %s\n" % e)
                return self._send(502, '{"error":"invalid_grant","error_description":"broker refresh failed"}')
            new_dummy = "vlt:" + account + ":" + _sec.token_urlsafe(12)
            return self._send(200, json.dumps(
                {"access_token": access, "refresh_token": new_dummy,
                 "token_type": "Bearer", "expires_in": exp}))
        if self.path.startswith("/push/"):
            pid = parse_id(self.path[len("/push/"):])
            if not pid:
                return self._send(400, '{"error":"bad profile; use /push/<kind>/<name>"}')
            p = run_vault(user, ["receive", pid[0] + ":" + pid[1]], body=body)
            if p.returncode == 0:
                server_event("push", user, pid[0] + ":" + pid[1], "ok", p.stderr.strip().splitlines()[-1] if p.stderr.strip() else "")
                return self._send(200, '{"ok":true,"detail":"' + (p.stderr.strip().splitlines()[-1] or "ok") + '"}')
            server_event("push", user, pid[0] + ":" + pid[1], "failed", p.stderr.strip().splitlines()[-1] if p.stderr.strip() else "")
            return self._send(403 if "owner" in p.stderr or "may not" in p.stderr else 400,
                              '{"error":"' + (p.stderr.strip().splitlines()[-1] or 'failed') + '"}')
        return self._send(404, '{"error":"not found"}')


class ThreadingHTTPServer(socketserver.ThreadingMixIn, http.server.HTTPServer):
    daemon_threads = True


def main():
    host, port = LISTEN.rsplit(":", 1)
    httpd = ThreadingHTTPServer((host, int(port)), Handler)
    sys.stderr.write(f"ai-vault-http listening on {LISTEN} (tokens: {TOKENS_FILE})\n")
    sys.stderr.flush()
    try:
        httpd.serve_forever()
    except KeyboardInterrupt:
        pass


if __name__ == "__main__":
    main()
