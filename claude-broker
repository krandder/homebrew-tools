#!/usr/bin/env bash
# claude-broker — deploy the transparent OAuth refresh proxy on a follower.
# No Tailscale, no SSH tunnel — talks to the public broker at vault.ekelvin.com.
#
#   claude-broker install [--user NAME]   proxy launchd service + wrapper
#   claude-broker seed    [--user NAME]   seed keychain with dummy refresh + fresh access
#   claude-broker status
#   claude-broker uninstall

set -euo pipefail
DIR="${CLAUDE_BROKER_DIR:-$HOME/.claude-broker}"
PROXY_PORT="${CLAUDE_BROKER_PROXY_PORT:-8443}"
BROKER_URL="${CLAUDE_BROKER_URL:-https://vault.ekelvin.com}"
PROXY="$(command -v claude-broker-proxy || echo "")"
REAL_CLAUDE="$(for d in /opt/homebrew/bin /usr/local/bin; do [ -x "$d/claude" ] && echo "$d/claude" && break; done)"
LABEL_PROXY="com.claudebroker.proxy"
LDIR="$HOME/Library/LaunchAgents"

say(){ echo "claude-broker: $*"; }
vault_token(){ awk -F= '/^token=/{print $2}' "$HOME/.codex-token/config" 2>/dev/null || true; }

cmd_install(){
  local user="${1:-}"; [ -n "$user" ] || user="$(awk -F= '/^user=/{print $2}' "$HOME/.codex-token/config" 2>/dev/null)"
  mkdir -p "$DIR" "$LDIR"
  [ -n "$PROXY" ] || { say "claude-broker-proxy not found; brew install krandder/tools/claude-broker-proxy"; exit 1; }
  local TOK; TOK="$(vault_token)"
  [ -n "$TOK" ] || { say "no vault token; run 'claude-token setup' first"; exit 1; }
  # proxy launchd service (talks directly to vault.ekelvin.com — no tunnel/Tailscale)
  cat > "$LDIR/$LABEL_PROXY.plist" <<EOF
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0"><dict>
  <key>Label</key><string>$LABEL_PROXY</string>
  <key>ProgramArguments</key><array><string>$PROXY</string></array>
  <key>EnvironmentVariables</key><dict>
    <key>CLAUDE_BROKER_URL</key><string>$BROKER_URL</string>
    <key>CLAUDE_BROKER_TOKEN</key><string>$TOK</string>
  </dict>
  <key>RunAtLoad</key><true/>
  <key>KeepAlive</key><true/>
  <key>StandardOutPath</key><string>$DIR/proxy.log</string>
  <key>StandardErrorPath</key><string>$DIR/proxy.log</string>
</dict></plist>
EOF
  launchctl unload "$LDIR/$LABEL_PROXY.plist" >/dev/null 2>&1 || true
  launchctl load -w "$LDIR/$LABEL_PROXY.plist"
  sleep 1
  # wrapper: check proxy first; fall back to standalone if it's down
  if [ ! -e "$HOME/bin/claude.pre-broker" ] && [ -e "$HOME/bin/claude" ]; then mv "$HOME/bin/claude" "$HOME/bin/claude.pre-broker"; fi
  mkdir -p "$HOME/bin"
  cat > "$HOME/bin/claude" <<EOF
#!/usr/bin/env bash
# Transparent broker wrapper — falls back to standalone if the proxy is down.
if ! nc -z 127.0.0.1 $PROXY_PORT 2>/dev/null; then
  echo "⚠ claude-broker: proxy not responding on :$PROXY_PORT — running claude standalone" >&2
  exec "$REAL_CLAUDE" "\$@"
fi
exec env HTTPS_PROXY=http://127.0.0.1:$PROXY_PORT NODE_EXTRA_CA_CERTS=$DIR/ca.pem "$REAL_CLAUDE" "\$@"
EOF
  chmod +x "$HOME/bin/claude"
  say "installed: proxy (-> $BROKER_URL) + wrapper."
  say "Next: claude-broker seed --user ${user:-<name>}"
}

cmd_seed(){
  local user="$1"
  [ -n "$user" ] || { say "seed: specify --user <name>"; exit 1; }
  local access="" TOK; TOK="$(vault_token)"
  [ -n "$TOK" ] || { say "seed: ✗ no vault token — run 'claude-token setup' first"; exit 1; }
  say "fetching fresh access token from $BROKER_URL for claude:$user..."
  for i in 1 2 3 4 5; do
    access="$(curl -fsS -H "Authorization: Bearer $TOK" "$BROKER_URL/access/claude/$user" 2>/dev/null || true)"
    [ -n "$access" ] && break; sleep 1
  done
  [ -n "$access" ] || { say "seed: ✗ no token from broker after 5 tries. Run 'claude-broker doctor' to diagnose."; exit 1; }
  local kc="Claude Code-credentials"
  local acct; acct="$(security find-generic-password -s "$kc" 2>/dev/null | sed -n 's/.*"acct"<blob>="\([^"]*\)".*/\1/p' | head -1)"; [ -n "$acct" ] || acct="$(whoami)"
  local seed; seed="$(python3 -c 'import json,sys,time;print(json.dumps({"claudeAiOauth":{"accessToken":sys.argv[1],"refreshToken":"vlt:'"$user"':seed","expiresAt":int(time.time()*1000)+3600000,"scopes":[],"subscriptionType":"max"}}))' "$access")"
  security add-generic-password -U -s "$kc" -a "$acct" -w "$seed" >/dev/null
  say "seeded '$user' ✓ (dummy refresh + fresh access in keychain). Try: claude"
}

cmd_doctor(){
  echo "=== claude-broker diagnostics ==="
  local TOK; TOK="$(vault_token)"
  local user; user="$(awk -F= '/^user=/{print $2}' "$HOME/.codex-token/config" 2>/dev/null)"
  local needs_fix=0

  # --- check + auto-fix ---
  check_proxy_service(){
    local pid; pid="$(launchctl list 2>/dev/null | awk -v l=$LABEL_PROXY '$3==l{print $2}')"
    if [ -n "$pid" ] && [ "$pid" != "-" ]; then
      echo "  proxy service: ✓ running (pid $pid)"; return 0
    fi
    echo "  proxy service: ✗ NOT RUNNING"
    if [ -f "$LDIR/$LABEL_PROXY.plist" ]; then
      echo "    → restarting..."
      launchctl unload "$LDIR/$LABEL_PROXY.plist" 2>/dev/null || true
      launchctl load -w "$LDIR/$LABEL_PROXY.plist" 2>/dev/null && echo "    → restarted ✓" || { echo "    → restart FAILED"; return 1; }
      sleep 1; return 0
    else
      echo "    → no plist — run: claude-broker install"; return 1
    fi
  }

  check_port(){
    if nc -z 127.0.0.1 $PROXY_PORT 2>/dev/null; then
      echo "  proxy port :$PROXY_PORT: ✓ listening"; return 0
    fi
    echo "  proxy port :$PROXY_PORT: ✗ NOT LISTENING"
    echo "    → check $DIR/proxy.log for errors (claude-broker logs)"; return 1
  }

  check_ca(){
    if [ -f "$DIR/ca.pem" ]; then
      echo "  CA cert: ✓ present"; return 0
    fi
    echo "  CA cert: ✗ MISSING"
    if [ -f "$LDIR/$LABEL_PROXY.plist" ]; then
      echo "    → restarting proxy (it generates the CA on startup)..."
      launchctl unload "$LDIR/$LABEL_PROXY.plist" 2>/dev/null || true
      launchctl load -w "$LDIR/$LABEL_PROXY.plist" 2>/dev/null && sleep 1
      [ -f "$DIR/ca.pem" ] && echo "    → CA generated ✓" || echo "    → CA still missing (proxy may be crashing — check $DIR/proxy.log)"
    fi
    return 1
  }

  check_token(){
    [ -n "$TOK" ] && { echo "  vault token: ✓ present"; return 0; }
    echo "  vault token: ✗ MISSING — run: claude-token setup"; return 1
  }

  check_broker(){
    [ -z "$TOK" ] && return 1
    local h; h="$(curl -fsS --max-time 5 -o /dev/null -w '%{http_code}' "$BROKER_URL/healthz" 2>/dev/null || echo 'fail')"
    [ "$h" = "200" ] && { echo "  broker ($BROKER_URL): ✓ reachable"; return 0; }
    echo "  broker ($BROKER_URL): ✗ NOT REACHABLE (HTTP $h) — check network"; return 1
  }

  check_user_token(){
    [ -z "$TOK" ] || [ -z "$user" ] && return 1
    local acc; acc="$(curl -fsS --max-time 5 -H "Authorization: Bearer $TOK" "$BROKER_URL/access/claude/$user" 2>/dev/null || echo '')"
    if [ -n "$acc" ] && [ "${acc:0:1}" != "{" ]; then
      echo "  token claude:$user: ✓ available (len ${#acc})"; return 0
    fi
    echo "  token claude:$user: ✗ NOT AVAILABLE — leader needs to publish (cron handles it)"; return 1
  }

  check_wrapper(){
    if [ -x "$HOME/bin/claude" ]; then
      echo "  wrapper: ✓ present"; return 0
    fi
    echo "  wrapper: ✗ MISSING — reinstalling..."
    mkdir -p "$HOME/bin"
    cat > "$HOME/bin/claude" <<EOF
#!/usr/bin/env bash
if ! nc -z 127.0.0.1 $PROXY_PORT 2>/dev/null; then
  echo "⚠ claude-broker: proxy not responding — running claude standalone" >&2
  exec "$REAL_CLAUDE" "\$@"
fi
exec env HTTPS_PROXY=http://127.0.0.1:$PROXY_PORT NODE_EXTRA_CA_CERTS=$DIR/ca.pem "$REAL_CLAUDE" "\$@"
EOF
    chmod +x "$HOME/bin/claude"
    echo "    → wrapper reinstalled ✓"
    return 0
  }

  echo "  broker URL:  $BROKER_URL"
  echo ""

  check_proxy_service || needs_fix=1
  check_port          || needs_fix=1
  check_ca            || needs_fix=1
  check_token         || needs_fix=1
  check_broker        || needs_fix=1
  check_user_token    || needs_fix=1
  check_wrapper       || needs_fix=1

  if [ -f "$DIR/proxy.log" ]; then
    echo ""
    echo "  proxy log (last 3 lines):"
    tail -3 "$DIR/proxy.log" 2>/dev/null | sed 's/^/    /'
  fi

  echo ""
  if [ "$needs_fix" = "0" ]; then
    echo "  ✓ all checks passed — claude-broker is healthy"
  else
    echo "  ⚠ some checks failed — auto-fixed what was fixable; for the rest, follow the suggestions above."
    echo "  If claude still fails, run: claude-broker uninstall  (restores standalone claude)"
  fi
  echo "=== end ==="
}

cmd_status(){
  say "proxy: $(launchctl list 2>/dev/null | awk -v l=$LABEL_PROXY '$3==l{print "running pid "$2}')"
  say "wrapper: $([ -x "$HOME/bin/claude" ] && echo present || echo missing)"
  say "broker: $BROKER_URL"
}

cmd_uninstall(){
  launchctl unload "$LDIR/$LABEL_PROXY.plist" >/dev/null 2>&1 || true
  rm -f "$LDIR/$LABEL_PROXY.plist"
  [ -e "$HOME/bin/claude.pre-broker" ] && mv "$HOME/bin/claude.pre-broker" "$HOME/bin/claude" || rm -f "$HOME/bin/claude"
  say "uninstalled (proxy stopped + wrapper removed; real claude restored)."
}

case "${1:-}" in
  install)   shift; cmd_install "${1:-}";;
  seed)      shift; cmd_seed "${1:-}";;
  doctor|-d) cmd_doctor;;
  logs)      tail -f "$DIR/proxy.log" 2>/dev/null || echo "no proxy log";;
  status)    cmd_status;;
  uninstall) cmd_uninstall;;
  *) echo "usage: claude-broker {install|seed|doctor|logs|status|uninstall}" >&2; exit 1;;
esac
