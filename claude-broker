#!/usr/bin/env bash
# claude-broker — deploy the transparent OAuth refresh proxy on a follower.
# No Tailscale, no SSH tunnel — talks to the public broker at vault.ekelvin.com.
#
#   claude-broker install [--user NAME]   proxy launchd service + wrapper
#   claude-broker seed    [--user NAME]   seed keychain with dummy refresh + fresh access
#   claude-broker status
#   claude-broker uninstall

set -euo pipefail
DIR="${CLAUDE_BROKER_DIR:-$HOME/.claude-broker}"
PROXY_PORT="${CLAUDE_BROKER_PROXY_PORT:-8443}"
BROKER_URL="${CLAUDE_BROKER_URL:-https://vault.ekelvin.com}"
PROXY="$(command -v claude-broker-proxy || echo "")"
REAL_CLAUDE="$(for d in /opt/homebrew/bin /usr/local/bin; do [ -x "$d/claude" ] && echo "$d/claude" && break; done)"
LABEL_PROXY="com.claudebroker.proxy"
LDIR="$HOME/Library/LaunchAgents"

say(){ echo "claude-broker: $*"; }
vault_token(){ awk -F= '/^token=/{print $2}' "$HOME/.codex-token/config" 2>/dev/null || true; }

cmd_install(){
  local user="${1:-}"; [ -n "$user" ] || user="$(awk -F= '/^user=/{print $2}' "$HOME/.codex-token/config" 2>/dev/null)"
  mkdir -p "$DIR" "$LDIR"
  [ -n "$PROXY" ] || { say "claude-broker-proxy not found; brew install krandder/tools/claude-broker-proxy"; exit 1; }
  local TOK; TOK="$(vault_token)"
  [ -n "$TOK" ] || { say "no vault token; run 'claude-token setup' first"; exit 1; }
  # proxy launchd service (talks directly to vault.ekelvin.com — no tunnel/Tailscale)
  cat > "$LDIR/$LABEL_PROXY.plist" <<EOF
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0"><dict>
  <key>Label</key><string>$LABEL_PROXY</string>
  <key>ProgramArguments</key><array><string>$PROXY</string></array>
  <key>EnvironmentVariables</key><dict>
    <key>CLAUDE_BROKER_URL</key><string>$BROKER_URL</string>
    <key>CLAUDE_BROKER_TOKEN</key><string>$TOK</string>
  </dict>
  <key>RunAtLoad</key><true/>
  <key>KeepAlive</key><true/>
  <key>StandardOutPath</key><string>$DIR/proxy.log</string>
  <key>StandardErrorPath</key><string>$DIR/proxy.log</string>
</dict></plist>
EOF
  launchctl unload "$LDIR/$LABEL_PROXY.plist" >/dev/null 2>&1 || true
  launchctl load -w "$LDIR/$LABEL_PROXY.plist"
  sleep 1
  # wrapper: HTTPS_PROXY + CA -> real claude (normal OAuth mode; refreshes through proxy)
  if [ ! -e "$HOME/bin/claude.pre-broker" ] && [ -e "$HOME/bin/claude" ]; then mv "$HOME/bin/claude" "$HOME/bin/claude.pre-broker"; fi
  mkdir -p "$HOME/bin"
  cat > "$HOME/bin/claude" <<EOF
#!/usr/bin/env bash
exec env HTTPS_PROXY=http://127.0.0.1:$PROXY_PORT NODE_EXTRA_CA_CERTS=$DIR/ca.pem "$REAL_CLAUDE" "\$@"
EOF
  chmod +x "$HOME/bin/claude"
  say "installed: proxy (-> $BROKER_URL) + wrapper."
  say "Next: claude-broker seed --user ${user:-<name>}"
}

cmd_seed(){
  local user="$1"
  [ -n "$user" ] || { say "seed: specify --user <name>"; exit 1; }
  local access="" TOK; TOK="$(vault_token)"
  for i in 1 2 3 4 5; do
    access="$(curl -fsS -H "Authorization: Bearer $TOK" "$BROKER_URL/access/claude/$user" 2>/dev/null || true)"
    [ -n "$access" ] && break; sleep 1
  done
  [ -n "$access" ] || { say "seed: no token from broker (is the leader publishing?)"; exit 1; }
  local kc="Claude Code-credentials"
  local acct; acct="$(security find-generic-password -s "$kc" 2>/dev/null | sed -n 's/.*"acct"<blob>="\([^"]*\)".*/\1/p' | head -1)"; [ -n "$acct" ] || acct="$(whoami)"
  local seed; seed="$(python3 -c 'import json,sys,time;print(json.dumps({"claudeAiOauth":{"accessToken":sys.argv[1],"refreshToken":"vlt:'"$user"':seed","expiresAt":int(time.time()*1000)+3600000,"scopes":[],"subscriptionType":"max"}}))' "$access")"
  security add-generic-password -U -s "$kc" -a "$acct" -w "$seed" >/dev/null
  say "seeded '$user'. Claude Code will refresh through the broker. Try: claude"
}

cmd_status(){
  say "proxy: $(launchctl list 2>/dev/null | awk -v l=$LABEL_PROXY '$3==l{print "running pid "$2}')"
  say "wrapper: $([ -x "$HOME/bin/claude" ] && echo present || echo missing)"
  say "broker: $BROKER_URL"
}

cmd_uninstall(){
  launchctl unload "$LDIR/$LABEL_PROXY.plist" >/dev/null 2>&1 || true
  rm -f "$LDIR/$LABEL_PROXY.plist"
  [ -e "$HOME/bin/claude.pre-broker" ] && mv "$HOME/bin/claude.pre-broker" "$HOME/bin/claude" || rm -f "$HOME/bin/claude"
  say "uninstalled (proxy stopped + wrapper removed; real claude restored)."
}

case "${1:-}" in
  install)   shift; cmd_install "${1:-}";;
  seed)      shift; cmd_seed "${1:-}";;
  status)    cmd_status;;
  uninstall) cmd_uninstall;;
  *) echo "usage: claude-broker {install|seed|status|uninstall}" >&2; exit 1;;
esac
