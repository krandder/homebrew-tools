#!/usr/bin/env python3
"""claude-broker-proxy — local transparent proxy that routes Claude Code's OAuth
refresh to the leader's single-owner broker.

Claude Code runs COMPLETELY NORMALLY (OAuth mode, real refresh-on-expiry). This
proxy intercepts ONLY the OAuth token endpoint on platform.claude.com (and
console.anthropic.com) and forwards it to the broker, which owns the canonical
refresh token. The follower holds a DUMMY refresh token (issued by the broker),
so it can never rotate/invalidate the leader. All other HTTPS traffic is plain
tunneled, untouched.

Configure Claude Code (via a wrapper or settings env):
  HTTPS_PROXY=http://127.0.0.1:8443
  NODE_EXTRA_CA_CERTS=~/.claude-broker/ca.pem
  (broker reached via an SSH tunnel: ssh -L 8231:127.0.0.1:8231 farol-ts)
"""
import os, sys, ssl, socket, threading, subprocess, tempfile, urllib.request, urllib.parse, urllib.error

STATE_DIR = os.path.expanduser("~/.claude-broker")
CA_CERT = os.path.join(STATE_DIR, "ca.pem")
CA_KEY = os.path.join(STATE_DIR, "ca-key.pem")
LISTEN_HOST = os.environ.get("CLAUDE_BROKER_PROXY_HOST", "127.0.0.1")
LISTEN_PORT = int(os.environ.get("CLAUDE_BROKER_PROXY_PORT", "8443"))
OAUTH_HOSTS = {"platform.claude.com", "console.anthropic.com"}
TOKEN_PATHS = ("/v1/oauth/token", "/oauth/token")
_cert_cache = {}


def log(m):
    sys.stderr.write("[claude-broker-proxy] " + m + "\n"); sys.stderr.flush()


def _run(args):
    subprocess.run(args, check=True, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)


def ensure_ca():
    os.makedirs(STATE_DIR, exist_ok=True)
    if os.path.exists(CA_CERT) and os.path.exists(CA_KEY):
        return
    _run(["openssl", "req", "-x509", "-newkey", "rsa:2048", "-keyout", CA_KEY,
          "-out", CA_CERT, "-days", "3650", "-nodes", "-subj", "/CN=claude-broker-proxy CA"])


def cert_for(host):
    if host in _cert_cache:
        return _cert_cache[host]
    d = tempfile.mkdtemp(dir=STATE_DIR)
    key, csr, crt, ext = (os.path.join(d, x) for x in ("k.pem", "c.pem", "cert.pem", "ext"))
    open(ext, "w").write("subjectAltName=DNS:%s\nextendedKeyUsage=serverAuth\nbasicConstraints=CA:FALSE\n" % host)
    _run(["openssl", "req", "-newkey", "rsa:2048", "-keyout", key, "-out", csr, "-nodes", "-subj", "/CN=%s" % host])
    _run(["openssl", "x509", "-req", "-in", csr, "-CA", CA_CERT, "-CAkey", CA_KEY,
          "-CAcreateserial", "-out", crt, "-days", "365", "-extfile", ext])
    _cert_cache[host] = (crt, key)
    return crt, key


def broker_token():
    tok = os.environ.get("CLAUDE_BROKER_TOKEN", "")
    if tok:
        return tok
    cfg = os.path.expanduser("~/.codex-token/config")
    if os.path.exists(cfg):
        for ln in open(cfg):
            if ln.startswith("token="):
                return ln.strip()[6:]
    return ""


def broker_forward(method, path, headers, body):
    broker = os.environ.get("CLAUDE_BROKER_URL", "http://127.0.0.1:8231").rstrip("/")
    tok = broker_token()
    h = {"Content-Type": headers.get("content-type", "application/x-www-form-urlencoded"),
         "User-Agent": headers.get("user-agent", "claude-code/2.1.195")}
    if tok:
        h["Authorization"] = "Bearer " + tok
    req = urllib.request.Request(broker + path, data=body, method=method, headers=h)
    try:
        r = urllib.request.urlopen(req, timeout=25)
        return r.status, r.read()
    except urllib.error.HTTPError as e:
        return e.code, e.read()
    except Exception as e:
        log("broker_forward error: %s" % e)
        return 502, b'{"error":"invalid_grant","error_description":"broker unreachable"}'


def forward_real(host, method, path, headers, body):
    h = {k: v for k, v in headers.items() if k.lower() not in ("host", "content-length")}
    req = urllib.request.Request("https://" + host + path, data=body or None, method=method, headers=h)
    try:
        r = urllib.request.urlopen(req, timeout=25)
        return r.status, r.read()
    except urllib.error.HTTPError as e:
        return e.code, e.read()
    except Exception as e:
        log("forward_real error: %s" % e)
        return 502, b'{"error":"upstream error"}'


def handle_mitm(conn, host):
    conn.settimeout(30)
    rfile = conn.makefile("rb")
    wfile = conn.makefile("wb")
    try:
        while True:
            line = rfile.readline()
            if not line:
                break
            parts = line.decode(errors="replace").split()
            if len(parts) < 2:
                break
            method, path = parts[0], parts[1]
            headers = {}
            while True:
                hl = rfile.readline()
                if hl in (b"\r\n", b"\n", b""):
                    break
                k, _, v = hl.decode(errors="replace").partition(":")
                headers[k.strip().lower()] = v.strip()
            length = int(headers.get("content-length", 0) or 0)
            body = rfile.read(length) if length else b""
            if method == "POST" and path.rstrip("/") in TOKEN_PATHS:
                # Only route refresh_token grants to the broker.
                # Login (authorization_code etc.) passes through to real Anthropic.
                if b"grant_type=refresh_token" in body:
                    log("routing refresh -> broker")
                    status, b = broker_forward(method, path, headers, body)
                else:
                    log("passthrough non-refresh (%s) -> real %s" % (method, host))
                    status, b = forward_real(host, method, path, headers, body)
            else:
                status, b = forward_real(host, method, path, headers, body)
            wfile.write(("HTTP/1.1 %d OK\r\n" % status).encode())
            wfile.write(("Content-Length: %d\r\n" % len(b)).encode())
            wfile.write(b"Content-Type: application/json\r\n\r\n")
            wfile.write(b)
            wfile.flush()
    except Exception as e:
        log("mitm handler: %s" % e)
    finally:
        try:
            conn.shutdown(socket.SHUT_RDWR)
        except Exception:
            pass


def relay(a, b):
    def pipe(x, y):
        try:
            while True:
                d = x.recv(4096)
                if not d:
                    break
                y.sendall(d)
        except Exception:
            pass
        finally:
            try:
                y.shutdown(socket.SHUT_WR)
            except Exception:
                pass
    t = threading.Thread(target=pipe, args=(a, b)); t.start(); pipe(b, a); t.join()


def handle(conn, addr):
    conn.settimeout(30)
    f = conn.makefile("rb")
    line = f.readline()
    if not line:
        return
    parts = line.decode(errors="replace").split()
    if len(parts) >= 2 and parts[0] == "CONNECT":
        host = parts[1].partition(":")[0]
        while f.readline() not in (b"\r\n", b"\n", b""):
            pass
        if host in OAUTH_HOSTS:
            crt, key = cert_for(host)
            ctx = ssl.SSLContext(ssl.PROTOCOL_TLS_SERVER); ctx.load_cert_chain(crt, key)
            try:
                conn.sendall(b"HTTP/1.1 200 Connection established\r\n\r\n")
                tls = ctx.wrap_socket(conn, server_side=True)
            except Exception as e:
                log("tls wrap %s: %s" % (host, e)); return
            handle_mitm(tls, host)
        else:
            try:
                upstream = socket.create_connection((host, 443), timeout=10)
                conn.sendall(b"HTTP/1.1 200 Connection established\r\n\r\n")
                relay(conn, upstream)
            except Exception:
                conn.sendall(b"HTTP/1.1 502 Bad Gateway\r\n\r\n")
    else:
        log("non-CONNECT request not supported: %s" % line.strip())


def main():
    ensure_ca()
    log("CA: %s" % CA_CERT)
    log("listening on %s:%d (MITM hosts: %s)" % (LISTEN_HOST, LISTEN_PORT, ", ".join(OAUTH_HOSTS)))
    s = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
    s.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
    s.bind((LISTEN_HOST, LISTEN_PORT)); s.listen(50)
    while True:
        c, a = s.accept()
        threading.Thread(target=handle, args=(c, a), daemon=True).start()


if __name__ == "__main__":
    main()
