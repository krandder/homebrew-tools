#!/usr/bin/env python3
import os, json, subprocess, sys

h = os.path.expanduser
t = os.getenv("CLAUDE_CODE_OAUTH_TOKEN")

if t:
    print(t)
    sys.exit(0)

if sys.platform == "darwin":
    try:
        r = subprocess.run(
            ["security", "find-generic-password", "-s", "Claude Code-credentials", "-w"],
            capture_output=True, text=True
        )
        t = json.loads(r.stdout)["claudeAiOauth"]["accessToken"]
    except:
        pass

if not t:
    try:
        f = open(h("~/.claude/.credentials.json"))
        t = json.load(f)["claudeAiOauth"]["accessToken"]
    except:
        pass

if t:
    print(t)
else:
    print("No Claude auth found", file=sys.stderr)
    sys.exit(1)
