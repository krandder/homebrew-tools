#!/usr/bin/env bash
set -euo pipefail

here="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
canonical="$here/ai-token"
[ -x "$canonical" ] || canonical="$(command -v ai-token 2>/dev/null || true)"
[ -x "$canonical" ] || { echo "claude-token: ai-token is not installed" >&2; exit 127; }
exec "$canonical" claude "$@"
