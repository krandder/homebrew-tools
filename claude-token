#!/usr/bin/env bash
# Extract Claude Code OAuth credentials - outputs full JSON object

# 1. Check environment variable
if [[ -n "$CLAUDE_CODE_OAUTH_TOKEN" ]]; then
    echo '{"accessToken":"'$CLAUDE_CODE_OAUTH_TOKEN'"}'
    exit 0
fi

# 2. Try macOS Keychain
if [[ "$(uname)" == "Darwin" ]]; then
    KEYCHAIN=$(security find-generic-password -s "Claude Code-credentials" -w 2>/dev/null)
    if [[ -n "$KEYCHAIN" ]]; then
        # Extract full claudeAiOauth object
        OAUTH=$(echo "$KEYCHAIN" | sed -n 's/.*"claudeAiOauth":{\([^}]*\)}.*/\1/p')
        if [[ -n "$OAUTH" ]]; then
            echo "{$OAUTH}"
            exit 0
        fi
        # Fallback: return full JSON if we can't extract just oauth
        echo "$KEYCHAIN"
        exit 0
    fi
fi

# 3. Try credentials file
CREDS_FILE="${CLAUDE_CONFIG_DIR:-$HOME/.claude}/.credentials.json"
if [[ -f "$CREDS_FILE" ]]; then
    # Extract claudeAiOauth object
    OAUTH=$(sed -n 's/.*"claudeAiOauth":{\([^}]*\)}.*/\1/p' "$CREDS_FILE")
    if [[ -n "$OAUTH" ]]; then
        echo "{$OAUTH}"
        exit 0
    fi
    # Fallback: full file
    cat "$CREDS_FILE"
    exit 0
fi

echo '{"error":"No Claude auth found - run '\''claude login'\'' first"}' >&2
exit 1
