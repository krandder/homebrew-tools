#!/usr/bin/env bash
# Extract Claude Code auth token - pure Bash, no dependencies

# 1. Check environment variable
if [[ -n "$CLAUDE_CODE_OAUTH_TOKEN" ]]; then
    echo "$CLAUDE_CODE_OAUTH_TOKEN"
    exit 0
fi

# 2. Try macOS Keychain
if [[ "$(uname)" == "Darwin" ]]; then
    KEYCHAIN=$(security find-generic-password -s "Claude Code-credentials" -w 2>/dev/null)
    if [[ -n "$KEYCHAIN" ]]; then
        # Extract accessToken from JSON using sed
        TOKEN=$(echo "$KEYCHAIN" | sed -n 's/.*"accessToken":"\([^"]*\)".*/\1/p')
        if [[ -n "$TOKEN" ]]; then
            echo "$TOKEN"
            exit 0
        fi
    fi
fi

# 3. Try credentials file
CREDS_FILE="${CLAUDE_CONFIG_DIR:-$HOME/.claude}/.credentials.json"
if [[ -f "$CREDS_FILE" ]]; then
    # Extract accessToken using sed
    TOKEN=$(sed -n 's/.*"accessToken":"\([^"]*\)".*/\1/p' "$CREDS_FILE")
    if [[ -n "$TOKEN" ]]; then
        echo "$TOKEN"
        exit 0
    fi
fi

echo "No Claude auth found - run 'claude login' first" >&2
exit 1
