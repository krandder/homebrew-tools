#!/usr/bin/env bash
# claude-token — print Claude Code OAuth credentials and sync them across
# machines via the vault (leader/follower), analogous to codex-token.
#
# Default (no args): print the active Claude OAuth object (backward compatible).
#
# Subcommands:
#   claude-token                           print active account tokens (default)
#   claude-token status                    account, token age, sync health
#   claude-token pair --user NAME          generate a vault key + print approve line
#   claude-token set-url <url>             configure the HTTPS vault endpoint
#   claude-token set-token <token>         store the API token the operator issued
#   claude-token login                     browser OAuth -> push to leader -> follower
#   claude-token run [claude args...]      follower launcher: freshen store, exec claude
#   claude-token install-wrapper           make plain `claude` run via `claude-token run`
#   claude-token publish [--profile P|--all]  LEADER: refresh + publish follower token(s)
#   claude-token pull   [--profile P]      FOLLOWER: pull a published token into the store
#   claude-token push   [--profile P]      push local real token to leader (owner-gated)
#   claude-token --diagnose | --version | --help
#
# Claude store: macOS Keychain ("Claude Code-credentials") on Darwin;
# ~/.claude/.credentials.json on Linux. Token shape: {accessToken,refreshToken,
# expiresAt,scopes,subscriptionType,rateLimitTier} (flat internally; wrapped in
# {"claudeAiOauth":...} when written to the macOS Keychain).
#
# Model: one leader owns the real refresh token and publishes fresh access
# tokens (~hours TTL). Followers run with a sentinel refresh token so they can
# never rotate/invalidate the leader. Refresh endpoint override for Claude is
# not exposed, so followers re-pull on each launch (access token stays fresh).

set -euo pipefail
VERSION="2.3.3"

CLIENT_ID="9d1c250a-e61b-44d9-88ed-5944d1962f5e"
TOKEN_EP="https://platform.claude.com/v1/oauth/token"
SENTINEL_RT="__follower_no_refresh__"
BLACKHOLE_URL="http://127.0.0.1:9/oauth/token"

CLAUDE_PROFILES_DIR="${CLAUDE_PROFILES_DIR:-$HOME/.claude-profiles}"
SHARED_DIR="${CLAUDE_SHARED_DIR:-$HOME/shared/claude-tokens}"
LEADER_HOST="${CLAUDE_LEADER:-farol-ts}"

# Reuse codex-token's pairing config if present (pair once for both tools).
if [ -d "$HOME/.codex-token" ]; then VAULT_DIR_CLIENT="$HOME/.codex-token"; else VAULT_DIR_CLIENT="$HOME/.claude-token"; fi
VAULT_DIR_CLIENT="${CLAUDE_VAULT_DIR:-$VAULT_DIR_CLIENT}"
VAULT_KEY="${CLAUDE_VAULT_KEY:-$VAULT_DIR_CLIENT/id_ed25519}"
CONFIG_FILE="$VAULT_DIR_CLIENT/config"
[ -f "$CONFIG_FILE" ] && while IFS='=' read -r _k _v; do
    case "$_k" in
        user)   CODEX_USER="${CODEX_USER:-$_v}" ;;
        leader) LEADER_HOST="${CLAUDE_LEADER:-$_v}" ;;
    esac
done < "$CONFIG_FILE" 2>/dev/null || true

die() { echo "claude-token: error: $*" >&2; exit 1; }
say() { echo "claude-token: $*" >&2; }
need_cmd() { command -v "$1" >/dev/null 2>&1 || die "missing required command: $1"; }
need_cmd python3
short_host() { hostname -s 2>/dev/null || hostname; }
is_mac() { [ "$(uname)" = Darwin ]; }

# ---- vault transport (HTTPS if configured, else SSH) ----
have_http_vault() { [ -n "${CLAUDE_VAULT_URL:-}${CODEX_VAULT_URL:-}" ] || grep -q '^url=' "$CONFIG_FILE" 2>/dev/null; }
vault_url()   { echo "${CLAUDE_VAULT_URL:-${CODEX_VAULT_URL:-$(awk -F= '/^url=/{print $2;exit}' "$CONFIG_FILE" 2>/dev/null)}}"; }
vault_token() { echo "${CLAUDE_VAULT_TOKEN:-${CODEX_VAULT_TOKEN:-$(sed -n 's/^token=//p' "$CONFIG_FILE" 2>/dev/null)}}"; }
ssh_vault() {
    if [ -f "$VAULT_KEY" ]; then ssh -i "$VAULT_KEY" -o IdentitiesOnly=yes "$LEADER_HOST" "$@";
    else ssh "$LEADER_HOST" "$@"; fi
}
vault_http() { # method path [data_file]
    local method="$1" path="$2" data="${3:-}" url tok
    url="$(vault_url)"; tok="$(vault_token)"
    [ -n "$url" ] || die "no vault URL (run 'claude-token set-url <url>')"
    [ -n "$tok" ] || die "no vault token (ask operator, then 'claude-token set-token <token>')"
    if [ -n "$data" ]; then curl -fsS -X "$method" "$url$path" -H "Authorization: Bearer $tok" --data-binary @"$data";
    else curl -fsS -X "$method" "$url$path" -H "Authorization: Bearer $tok"; fi
}
config_user() {
    if [ -n "${CODEX_USER:-}" ]; then echo "$CODEX_USER"
    elif [ -f "$CONFIG_FILE" ]; then awk -F= '/^user=/{print $2;exit}' "$CONFIG_FILE"; fi
}
set_config() {
    mkdir -p "$VAULT_DIR_CLIENT"
    python3 - "$CONFIG_FILE" "$1" "$2" <<'PY'
import sys,os
f,k,v=sys.argv[1],sys.argv[2],sys.argv[3]
lines=[]; found=False
if os.path.exists(f):
    for line in open(f):
        if line.rstrip("\n").startswith(k+"="): lines.append(f"{k}={v}"); found=True
        else: lines.append(line.rstrip("\n"))
if not found: lines.append(f"{k}={v}")
open(f,"w").write("\n".join(lines)+"\n"); os.chmod(f,0o600)
PY
}
resolve_claude_bin() {
    local cands="$HOME/bin/claude.real:/opt/homebrew/bin/claude:/usr/local/bin/claude:$(command -v claude 2>/dev/null)" d
    local IFS=':'
    for d in $cands; do [ -n "$d" ] && [ -x "$d" ] || continue; case "$d" in *"$HOME/bin"*) continue ;; esac; echo "$d"; return; done
    command -v claude
}

# ---- Claude credential store (read/write flat oauth JSON) ----
KC_SVC="Claude Code-credentials"
kc_account() {
    if is_mac; then security find-generic-password -s "$KC_SVC" 2>/dev/null | sed -n 's/.*"acct"<blob>="\([^"]*\)".*/\1/p' | head -1; fi
}
read_oauth_json() {  # -> stdout flat oauth JSON
    if is_mac; then
        security find-generic-password -s "$KC_SVC" -w 2>/dev/null | python3 -c 'import json,sys
d=json.load(sys.stdin); o=d.get("claudeAiOauth",d) if isinstance(d,dict) else {}
print(json.dumps(o))'
    else
        local f
        for f in "$HOME/.claude/.credentials.json" "$HOME/.claude/credentials.json"; do
            [ -f "$f" ] || continue
            python3 -c 'import json,sys;d=json.load(open(sys.argv[1]));o=d.get("claudeAiOauth",d) if isinstance(d,dict) else {};print(json.dumps(o))' "$f" && return
        done
        return 1
    fi
}
write_oauth_json() { # oauth_str  -> keychain (wrapped) or file (flat)
    local oauth="$1"
    if is_mac; then
        local acct; acct="$(kc_account)"; [ -n "$acct" ] || acct="$(whoami)"
        local wrapped; wrapped="$(python3 -c 'import json,sys;print(json.dumps({"claudeAiOauth":json.loads(sys.argv[1])}))' "$oauth")"
        security add-generic-password -U -s "$KC_SVC" -a "$acct" -w "$wrapped" >/dev/null
    else
        mkdir -p "$HOME/.claude"; printf '%s\n' "$oauth" > "$HOME/.claude/.credentials.json"; chmod 600 "$HOME/.claude/.credentials.json"
    fi
}
oauth_get() { python3 -c 'import json,sys;o=json.load(open(sys.argv[1]));print(o.get(sys.argv[2],"") or "")' "$1" "$2"; }

# refresh a Claude refresh_token -> json {access_token,refresh_token,expires_in,...}
refresh_claude() { # rt  -> stdout json
    local rt="$1"
    python3 - "$rt" "$CLIENT_ID" "$TOKEN_EP" <<'PY'
import json,sys,urllib.request,urllib.error
rt,cid,url=sys.argv[1],sys.argv[2],sys.argv[3]
body=urllib.parse.urlencode({"grant_type":"refresh_token","client_id":cid,"refresh_token":rt}).encode()
req=urllib.request.Request(url,data=body,method="POST",headers={"Content-Type":"application/x-www-form-urlencoded","Accept":"application/json","User-Agent":"claude-code/2.1.195"})
try:
    r=urllib.request.urlopen(req,timeout=20); print(r.read().decode()); sys.exit(0)
except urllib.error.HTTPError as e:
    sys.stderr.write("refresh FAILED: "+e.read().decode()[:200]+"\n"); sys.exit(1)
PY
}

# ---- LEADER: publish ----
canonical_file() { echo "$CLAUDE_PROFILES_DIR/$1/.claude/credentials.json"; }
shared_file()    { echo "$SHARED_DIR/$1.json"; }

publish_profile() { # profile
    local p="$1" af sf
    af="$(canonical_file "$p")"; sf="$(shared_file "$p")"
    [ -f "$af" ] || die "publish: missing canonical creds at $af"
    # Check if the existing access token is still valid; only refresh if needed.
    mkdir -p "$SHARED_DIR" "$(dirname "$af")"
    local needs_refresh
    needs_refresh="$(python3 - "$af" <<'PY'
import json,sys,time
o=json.load(open(sys.argv[1])); o=o.get("claudeAiOauth",o)
rt=o.get("refreshToken","")
# need refresh if: no RT, sentinel RT, or access token expired
exp=o.get("expiresAt",0)/1000
if not rt or rt.startswith("vlt:") or rt=="__follower_no_refresh__":
    print("yes")  # can't use existing
elif exp < time.time() + 600:  # less than 10 min left
    print("yes")  # about to expire
else:
    print("no")   # still valid — publish as-is
PY
)"
    if [ "$needs_refresh" = "yes" ]; then
        local rt resp
        rt="$(python3 -c 'import json,sys;o=json.load(open(sys.argv[1]));o=o.get("claudeAiOauth",o);print(o.get("refreshToken",""))' "$af")"
        [ -n "$rt" ] || die "publish: no refreshToken for '$p'"
        [ "$rt" = "$SENTINEL_RT" ] && die "publish: '$p' is a follower (sentinel)"
        resp="$(refresh_claude "$rt")" || die "publish: refresh failed for '$p'"
        python3 - "$af" "$sf" "$p" "$resp" "$SENTINEL_RT" "$LEADER_HOST" <<'PY'
import json,sys,os,time,datetime
af,sf,profile,resp,sentinel,leader=sys.argv[1:7]
r=json.loads(resp); ts=int(time.time()*1000)
d=json.load(open(af)); o=d.get("claudeAiOauth",d)
o["accessToken"]=r["access_token"]; o["refreshToken"]=r["refresh_token"]
o["expiresAt"]=ts+int(r.get("expires_in",28800))*1000
d=dict(d); d["claudeAiOauth"]=o
json.dump(d,open(af,"w"),indent=2); os.chmod(af,0o600)
pub=dict(o); pub["refreshToken"]=sentinel
out={"claudeAiOauth":pub,"profile":profile,"leader":leader,
     "published_at":datetime.datetime.now(datetime.timezone.utc).isoformat()}
json.dump(out,open(sf,"w"),indent=2); os.chmod(sf,0o600)
print(f"published {profile} -> {sf} (refreshed, ttl {r.get('expires_in')}s)")
PY
    else
        # Access token still valid — publish it directly (NO refresh needed!)
        python3 - "$af" "$sf" "$p" "$SENTINEL_RT" "$LEADER_HOST" <<'PY'
import json,sys,os,datetime
af,sf,profile,sentinel,leader=sys.argv[1:6]
d=json.load(open(af)); o=d.get("claudeAiOauth",d)
pub=dict(o); pub["refreshToken"]=sentinel
out={"claudeAiOauth":pub,"profile":profile,"leader":leader,
     "published_at":datetime.datetime.now(datetime.timezone.utc).isoformat(),
     "note":"published existing access token (no refresh needed)"}
json.dump(out,open(sf,"w"),indent=2); os.chmod(sf,0o600)
print(f"published {profile} -> {sf} (existing token, no refresh)")
PY
    fi
}

# ---- FOLLOWER: pull / push ----
pull_profile() { # profile -> local store
    local p="$1" sf
    sf="$(shared_file "$p")"
    if [ -f "$sf" ]; then
        : # fast path: syncthing mesh
    elif have_http_vault; then
        say "pulling '$p' from $(vault_url) (HTTPS, ACL-gated)..."
        local tmp; tmp="$(mktemp)"; vault_http GET "/pull/claude/$p" > "$tmp" || { rm -f "$tmp"; die "pull: leader denied/unavailable for '$p'"; }
        sf="$tmp"
    else
        need_cmd ssh; local tmp; tmp="$(mktemp)"
        say "pulling '$p' from leader $LEADER_HOST (vault, ACL-gated)..."
        ssh_vault "codex-vault serve claude:$p" > "$tmp" || { rm -f "$tmp"; die "pull: leader denied/unavailable for '$p'"; }
        sf="$tmp"
    fi
    python3 - "$sf" <<'PY'
import json,sys
d=json.load(open(sys.argv[1])); o=d.get("claudeAiOauth",d)
if not o.get("accessToken"): sys.exit("pull: no accessToken in published token")
print(json.dumps(o))
PY
}

push_profile() { # profile -> leader (then revert local to sentinel)
    local p="$1" oauth rt
    oauth="$(read_oauth_json)" || die "push: no local Claude creds found"
    rt="$(echo "$oauth" | python3 -c 'import json,sys;print(json.load(sys.stdin).get("refreshToken",""))')"
    [ -n "$rt" ] || die "push: no refreshToken locally"
    [ "$rt" = "$SENTINEL_RT" ] && die "push: only sentinel token present (already a follower). Run 'claude-token login' first."
    if have_http_vault; then
        say "pushing '$p' to $(vault_url) (HTTPS)..."
        printf '%s' "$oauth" | vault_http POST "/push/claude/$p" /dev/stdin >/dev/null || die "push: leader rejected '$p'"
    else
        need_cmd ssh
        say "pushing '$p' to leader $LEADER_HOST (vault/SSH)..."
        printf '%s\n' "$oauth" | ssh_vault "codex-vault receive claude:$p" || die "push: leader rejected '$p'"
    fi
    # revert local store to follower (sentinel RT), then pull fresh
    local follower; follower="$(echo "$oauth" | python3 -c 'import json,sys;o=json.load(sys.stdin);o["refreshToken"]="'$SENTINEL_RT'";print(json.dumps(o))')"
    write_oauth_json "$follower"
    local fresh; fresh="$(pull_profile "$p" 2>/dev/null || true)"; [ -n "$fresh" ] && write_oauth_json "$fresh"
    say "reverted '$p' to follower (sentinel token)"
}

# ---- commands ----
cmd_print() {
    read_oauth_json 2>/dev/null || { echo '{"error":"No Claude auth found - run '\''claude login'\'' or '\''claude-token login'\''"}' >&2; exit 1; }
}

cmd_status() {
    say "machine: $(short_host)   leader: $LEADER_HOST"
    local oauth email exp
    if oauth="$(read_oauth_json 2>/dev/null)"; then
        email="$(echo "$oauth" | python3 -c 'import json,sys;print(json.load(sys.stdin).get("subscriptionType","?"))' 2>/dev/null)"
        exp="$(echo "$oauth" | python3 -c 'import json,sys,time;o=json.load(sys.stdin);e=o.get("expiresAt",0);print(round((e/1000-time.time())/3600,1),"h" if e else "?")' 2>/dev/null)"
        local rt; rt="$(echo "$oauth" | python3 -c 'import json,sys;print(json.load(sys.stdin).get("refreshToken",""))')"
        local state; [ "$rt" = "$SENTINEL_RT" ] && state="sentinel (follower)" || state="REAL (leader/standalone)"
        echo "  active: plan=$email  access valid: $exp  rt=$state"
    else
        echo "  active: (no creds)"
    fi
    local p
    for p in $(ls "$CLAUDE_PROFILES_DIR" 2>/dev/null); do echo "  profile: $p"; done
}

cmd_pair() {  # [--user NAME] — magical onboarding: print a code, poll until approved, auto-configure
    local user="${CODEX_USER:-}"
    while [ -z "$user" ]; do read -rp "Your username on the vault: " user; done
    mkdir -p "$VAULT_DIR_CLIENT"
    local url; url="${CLAUDE_VAULT_URL:-$(vault_url 2>/dev/null)}"
    [ -n "$url" ] || url="https://vault.ekelvin.com"
    set_config url "$url"; set_config user "$user"
    need_cmd curl
    # generate a short pairing code + a long secret
    local code secret sh
    code="$(python3 -c 'import secrets,string;print("".join(secrets.choice(string.ascii_uppercase+string.digits) for _ in range(8)))')"
    secret="$(python3 -c 'import secrets;print(secrets.token_urlsafe(32))')"
    sh="$(python3 -c 'import hashlib,sys;print(hashlib.sha256(sys.argv[1].encode()).hexdigest())' "$secret")"
    # post the pairing request
    curl -fsS -X POST "$url/pair" -H "Content-Type: application/json" \
        -d "{\"user\":\"$user\",\"code\":\"$code\",\"secret_hash\":\"$sh\"}" >/dev/null \
        || die "pair: cannot reach $url (is it correct?)"
    cat <<EOF

Pairing as '$user' against $url

   Pairing code:  $code

Ask the operator to approve it on the leader (farol):

   codex-vault pair-approve $code

Waiting for approval — this auto-completes (timeout 5 min)...
EOF
    # poll until approved / timeout
    local i status token
    for i in $(seq 1 60); do
        sleep 5
        local resp; resp="$(curl -fsS -X POST "$url/pair/$code/poll" -H "Content-Type: application/json" \
            -d "{\"secret\":\"$secret\"}" 2>/dev/null || echo '{}')"
        status="$(printf '%s' "$resp" | python3 -c 'import json,sys;print(json.load(sys.stdin).get("status",""))' 2>/dev/null)"
        [ "$status" = "approved" ] && { token="$(printf '%s' "$resp" | python3 -c 'import json,sys;print(json.load(sys.stdin).get("token",""))' 2>/dev/null)"; break; }
        { [ "$status" = "unknown" ] || [ "$status" = "expired" ]; } && die "pair: pairing $status before approval — please retry."
        printf "." >&2
    done
    [ "$status" = "approved" ] || die "pair: timed out waiting for approval. Re-run when the operator is ready."
    set_config token "$token"
    cmd_install_wrapper
    # if there's a local refresh token (e.g. prior login), push it to the leader now
    local oauth rt
    oauth="$(read_oauth_json 2>/dev/null || true)"
    rt="$(printf '%s' "$oauth" | python3 -c 'import json,sys;print(json.load(sys.stdin).get("refreshToken",""))' 2>/dev/null || true)"
    if [ -n "$rt" ] && [ "$rt" != "$SENTINEL_RT" ]; then
        say "local token found — pushing to leader..."
        printf '%s' "$oauth" | vault_http POST "/push/claude/$user" /dev/stdin >/dev/null || say "  (push deferred — leader will retry)"
    else
        say "no local token yet — run 'claude login' to login + push automatically."
    fi
    echo >&2
    say "paired as '$user'! 'claude' now runs via $url. Try: claude"
}

cmd_login() {
    local user; user="$(config_user)"; [ -n "$user" ] || die "login: run 'claude-token setup --user <name>' first"
    local bin; bin="$(resolve_claude_bin)"; [ -n "$bin" ] || die "login: claude binary not found"
    say "starting browser login..."
    "$bin" login "$@" || "$bin" auth login "$@" || true
    local oauth rt
    oauth="$(read_oauth_json 2>/dev/null)" || { say "login: no creds after login"; return 0; }
    rt="$(printf '%s' "$oauth" | python3 -c 'import json,sys;print(json.load(sys.stdin).get("refreshToken",""))')"
    if [ -n "$rt" ] && [ "$rt" != "$SENTINEL_RT" ]; then
        say "pushing your Claude token to the leader as '$user'..."
        if have_http_vault; then
            printf '%s' "$oauth" | vault_http POST "/push/claude/$user" /dev/stdin >/dev/null || say "  (push deferred — leader will retry)"
        else
            need_cmd ssh; printf '%s\n' "$oauth" | ssh_vault "codex-vault receive claude:$user" || say "  (push deferred)"
        fi
        say "logged in + pushed to leader. 'claude' works (standalone); follower mode activates when the broker serves."
    else
        say "logged in (no refresh token to push)."
    fi
}

cmd_run() { # [claude args...]  — follower launcher; falls back to normal claude if no fresh broker token
    # `claude login` -> login (browser) + auto-push the refresh token to the leader
    [ "${1:-}" = "login" ] && { shift; cmd_login "$@"; return $?; }
    local user; user="$(config_user)"
    local bin; bin="$(resolve_claude_bin)"; [ -n "$bin" ] || die "run: claude binary not found"
    # If no user configured, just run claude normally (standalone).
    [ -n "$user" ] || exec "$bin" "$@"

    local sf="$SHARED_DIR/$user.json" access=""
    # 1. syncthing shared file — only if the access token is still fresh
    if [ -f "$sf" ]; then
        access="$(python3 -c '
import json,sys,base64,time
d=json.load(open(sys.argv[1])); o=d.get("claudeAiOauth",d); t=o.get("accessToken","")
try:
    p=t.split(".")[1]; p+="="*(-len(p)%4); exp=json.loads(base64.b64decode(p)).get("exp",0)
    sys.stdout.write(t if exp>time.time() else "")
except: sys.stdout.write("")
' "$sf" 2>/dev/null)"
    fi
    # 2. broker /access/ (HTTPS)
    if [ -z "$access" ] && have_http_vault; then
        access="$(vault_http GET "/access/claude/$user" 2>/dev/null || true)"
    fi
    # If we have a fresh broker/shared token -> follower mode (ANTHROPIC_AUTH_TOKEN).
    # Otherwise -> fall through to normal claude (uses the local keychain/login).
    if [ -n "$access" ]; then
        export ANTHROPIC_AUTH_TOKEN="$access"
        exec "$bin" "$@"
    fi
    # Fallback: run claude normally (keychain OAuth mode — connectors work, standalone).
    exec "$bin" "$@"
}

cmd_install_wrapper() {
    mkdir -p "$HOME/bin"
    local w="$HOME/bin/claude"
    [ -e "$w" ] && [ ! -e "$w.pre-claude-token" ] && { mv "$w" "$w.pre-claude-token"; say "backed up existing -> $w.pre-claude-token"; }
    cat > "$w" <<'EOF'
#!/usr/bin/env bash
exec claude-token run "$@"
EOF
    chmod +x "$w"
    say "installed $w -> claude-token run"
}

cmd_set_url()   { [ -n "${1:-}" ] || die "set-url: specify URL"; set_config url "$1"; say "vault URL = $1"; }
cmd_set_token() { [ -n "${1:-}" ] || die "set-token: specify token"; set_config token "$1"; say "vault token stored"; }

# One-shot bootstrap to "go live" on this machine: push the local real refresh
# token to the leader (making the leader the sole owner), then install the
# wrapper so plain `claude` runs transparently via the broker. After this, the
# local keychain refresh token is inert (sentinel) and Claude Code runs on
# broker-served access tokens — install-and-forget.
cmd_go_live() {
    local user; user="$(config_user)"; [ -n "$user" ] || die "go-live: run 'claude-token pair --user <name>' first"
    local oauth rt
    oauth="$(read_oauth_json 2>/dev/null)" || die "go-live: no local Claude creds — run 'claude login' first"
    rt="$(printf '%s' "$oauth" | python3 -c 'import json,sys;print(json.load(sys.stdin).get("refreshToken",""))' 2>/dev/null)"
    [ -n "$rt" ] && [ "$rt" != "$SENTINEL_RT" ] || die "go-live: no real refresh token locally (already a follower?) — run 'claude login' first"
    say "go-live: pushing your Claude token to the leader as '$user'..."
    push_profile "$user" || die "go-live: push failed (leader unreachable or rate-limited — retry later)"
    cmd_install_wrapper
    say "go-live complete. Plain 'claude' now runs via the broker. Leader: $LEADER_HOST"
}

cmd_publish() {
    local p="${PROFILE:-}"
    if [ "${ALL:-0}" = 1 ]; then
        for p in $(ls "$CLAUDE_PROFILES_DIR" 2>/dev/null); do ( publish_profile "$p" ) || say "  (skipped $p)"; done
    else
        [ -n "$p" ] || p="$(config_user)"; [ -n "$p" ] || die "publish: specify --profile <name> or --all"
        publish_profile "$p"
    fi
}
cmd_pull() { local p="${PROFILE:-$(config_user)}"; [ -n "$p" ] || die "pull: specify --profile <name>"; local o; o="$(pull_profile "$p")"; write_oauth_json "$o"; say "pulled '$p' into store"; }
cmd_push() { local p="${PROFILE:-$(config_user)}"; [ -n "$p" ] || die "push: specify --profile <name>"; push_profile "$p"; }

cmd_diagnose() {
    say "claude-token $VERSION"; say "VAULT_DIR_CLIENT=$VAULT_DIR_CLIENT"; say "LEADER_HOST=$LEADER_HOST"; say "SHARED_DIR=$SHARED_DIR"
    say "is_mac=$(is_mac && echo yes || echo no)  kc_account=$(kc_account)"
    read_oauth_json >/dev/null 2>&1 && say "local creds: present" || say "local creds: none"
}

# ---- dispatch ----
[ $# -eq 0 ] && { cmd_print; exit 0; }
case "$1" in
    publish) shift; while [ $# -gt 0 ]; do case "$1" in --profile|-p) PROFILE="$2"; shift 2;; --all|-a) ALL=1; shift;; *) die "unknown arg: $1";; esac; done; cmd_publish;;
    pull)    shift; while [ $# -gt 0 ]; do case "$1" in --profile|-p) PROFILE="$2"; shift 2;; *) PROFILE="$1"; shift;; esac; done; cmd_pull;;
    push)    shift; while [ $# -gt 0 ]; do case "$1" in --profile|-p) PROFILE="$2"; shift 2;; *) PROFILE="$1"; shift;; esac; done; cmd_push;;
    status)  cmd_status;;
    pair|setup) shift; while [ $# -gt 0 ]; do case "$1" in --user|-u) CODEX_USER="$2"; shift 2;; *) CODEX_USER="$1"; shift;; esac; done; cmd_pair;;
    login)   shift; cmd_login "$@";;
    run)     shift; cmd_run "$@";;
    go-live) shift; cmd_go_live "$@";;
    install-wrapper) cmd_install_wrapper;;
    set-url)   shift; cmd_set_url "$@";;
    set-token) shift; cmd_set_token "$@";;
    --diagnose|--diagnostics|--debug) cmd_diagnose;;
    --version|-v) echo "claude-token $VERSION";;
    --help|-h) sed -n '2,22p' "$0" | sed 's/^# \?//';;
    *) die "unknown command: $1 (see --help)";;
esac
exit 0
