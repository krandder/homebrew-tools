#!/usr/bin/env bash
# codex-token — print Codex CLI credentials and sync them across machines.
#
# Subcommands:
#   codex-token [print] [--profile P]      Print active/given profile tokens (default).
#   codex-token status [--profile P|--all] Show roles, token age, sync health (no secrets).
#   codex-token publish [--profile P|--all] LEADER: refresh + publish token to shared dir.
#   codex-token pull [--profile P|--all]   FOLLOWER: pull published token into local profile.
#   codex-token push [--profile P|--all]   FOLLOWER: push a freshly-logged-in token to the leader.
#   codex-token sync [--profile P|--all]   Role-aware: publish / push / pull as appropriate.
#   codex-token --version | --help | --diagnose
#
# Model: exactly ONE machine is the "leader" per profile and owns the real
# refresh_token. Followers run with a sentinel refresh_token plus the refresh
# endpoint overridden to a blackhole (set by ai-as), so they can never rotate
# the leader's token. The leader publishes a fresh access_token (~10d life) to
# a Syncthing-shared folder; followers read it.
#
# When you (re)login on a follower: `codex-<profile> login` then `codex-token sync`
# (ai-as auto-runs sync after a follower login). sync pushes the new real token to
# the leader and reverts the local machine to follower.

set -euo pipefail

VERSION="2.6.0"

CLIENT_ID="app_EMoamEEZ73f0CkXaXp7hrann"
TOKEN_EP="https://auth.openai.com/oauth/token"
SENTINEL_RT="__follower_no_refresh__"
BLACKHOLE_URL="http://127.0.0.1:9/oauth/token"

PROFILES_DIR="${CODEX_PROFILES_DIR:-$HOME/.codex-profiles}"
SHARED_DIR="${CODEX_SHARED_DIR:-$HOME/shared/codex-tokens}"
LEADER_HOST="${CODEX_LEADER:-farol-ts}"
LEGACY_AUTH="${CODEX_CONFIG_DIR:-$HOME/.codex}/auth.json"

# Per-user vault key + identity config (created by `pair`).
VAULT_DIR_CLIENT="$HOME/.codex-token"
VAULT_KEY="${CODEX_VAULT_KEY:-$VAULT_DIR_CLIENT/id_ed25519}"
CONFIG_FILE="$VAULT_DIR_CLIENT/config"
[ -f "$CONFIG_FILE" ] && while IFS='=' read -r _k _v; do
    case "$_k" in
        user)   CODEX_USER="${CODEX_USER:-$_v}" ;;
        leader) LEADER_HOST="${CODEX_LEADER:-$_v}" ;;
    esac
done < "$CONFIG_FILE" 2>/dev/null || true

# SSH to the leader, using the per-user vault key when present (forced-command
# binds identity server-side); otherwise plain SSH (operator/trusted).
ssh_vault() {
    if [ -f "$VAULT_KEY" ]; then ssh -i "$VAULT_KEY" -o IdentitiesOnly=yes "$LEADER_HOST" "$@";
    else ssh "$LEADER_HOST" "$@"; fi
}
config_user() {
    if [ -n "${CODEX_USER:-}" ]; then echo "$CODEX_USER"
    elif [ -f "$CONFIG_FILE" ]; then awk -F= '/^user=/{print $2; exit}' "$CONFIG_FILE"; fi
}
_copy_token() { python3 - "$1" "$2" <<'PY'
import json,sys,os
s,d=sys.argv[1],sys.argv[2]
data=json.load(open(s))
clean={k:data[k] for k in ("auth_mode","tokens","last_refresh","account_id") if k in data}
json.dump(clean,open(d,"w"),indent=2); os.chmod(d,0o600)
PY
}
resolve_codex_bin() {
    if [ -n "${CODEX_BIN:-}" ] && command -v "${CODEX_BIN:-}" >/dev/null 2>&1; then echo "$CODEX_BIN"; return; fi
    local b cands=""
    cands="$HOME/bin/codex.real:/opt/homebrew/bin/codex:/usr/local/bin/codex:$(command -v codex 2>/dev/null)"
    local IFS=':' d
    for d in $cands; do
        [ -n "$d" ] && [ -x "$d" ] || continue
        case "$d" in *"$HOME/bin"*) continue ;; esac   # skip our own wrapper dir
        echo "$d"; return
    done
    command -v codex
}

# ---- HTTPS vault transport (active once a token is configured; URL defaults) ----
VAULT_URL_DEFAULT="https://vault.ekelvin.com"
have_http_vault() { [ -n "$(vault_token)" ]; }   # HTTPS path is used once a token is set
vault_url()   { local u="${CODEX_VAULT_URL:-$(awk -F= '/^url=/{print $2;exit}' "$CONFIG_FILE" 2>/dev/null)}"; echo "${u:-$VAULT_URL_DEFAULT}"; }
vault_token() { echo "${CODEX_VAULT_TOKEN:-$(sed -n 's/^token=//p' "$CONFIG_FILE" 2>/dev/null)}"; }
vault_http() { # method path [data_file]
    local method="$1" path="$2" data="${3:-}" url tok
    url="$(vault_url)"; tok="$(vault_token)"
    [ -n "$url" ] || die "no vault URL (run 'codex-token set-url <url>')"
    [ -n "$tok" ] || die "no vault token (ask the operator, then 'codex-token set-token <token>')"
    if [ -n "$data" ]; then
        curl -fsS -X "$method" "$url$path" -H "Authorization: Bearer $tok" --data-binary @"$data"
    else
        curl -fsS -X "$method" "$url$path" -H "Authorization: Bearer $tok"
    fi
}
set_config() { # key value
    mkdir -p "$VAULT_DIR_CLIENT"
    python3 - "$CONFIG_FILE" "$1" "$2" <<'PY'
import sys,os
f,k,v=sys.argv[1],sys.argv[2],sys.argv[3]
lines=[]; found=False
if os.path.exists(f):
    for line in open(f):
        if line.rstrip("\n").startswith(k+"="): lines.append(f"{k}={v}"); found=True
        else: lines.append(line.rstrip("\n"))
if not found: lines.append(f"{k}={v}")
open(f,"w").write("\n".join(lines)+"\n"); os.chmod(f,0o600)
PY
}

# ----------------------------------------------------------------------------
# helpers
# ----------------------------------------------------------------------------

die() { echo "codex-token: error: $*" >&2; exit 1; }
say() { echo "codex-token: $*"; }

need_cmd() { command -v "$1" >/dev/null 2>&1 || die "missing required command: $1"; }
need_cmd python3
need_cmd curl

short_host() { hostname -s 2>/dev/null || hostname; }

hostname_is_leader_default() { [ "$(short_host)" = "farol" ]; }

profile_path() { echo "$PROFILES_DIR/$1"; }
auth_file()    { echo "$PROFILES_DIR/$1/.codex/auth.json"; }
role_file()    { echo "$PROFILES_DIR/$1/.role"; }
shared_file()  { echo "$SHARED_DIR/$1.json"; }

role_of() {
    local p="$1"
    if [ -f "$(role_file "$p")" ]; then cat "$(role_file "$p")"; return; fi
    if hostname_is_leader_default; then echo leader; else echo follower; fi
}

set_role() { # profile role
    local p="$1" r="$2"
    mkdir -p "$(profile_path "$p")"
    printf '%s' "$r" > "$(role_file "$p")"
}

all_profiles() {
    [ -d "$PROFILES_DIR" ] || return 0
    local d name
    for d in "$PROFILES_DIR"/*/; do
        [ -d "$d" ] || continue
        name="$(basename "$d")"
        [ -L "$PROFILES_DIR/$name" ] && continue   # skip alias symlinks (e.g. kelvin -> kas)
        echo "$name"
    done
}

is_sentinel() { [ "${1:-}" = "$SENTINEL_RT" ]; }

# Resolve the active profile for `print`/default actions.
resolve_profile() {
    if [ -n "${CODEX_PROFILE:-}" ]; then echo "$CODEX_PROFILE"; return; fi
    if [ -L "$PROFILES_DIR/active" ]; then basename "$(readlink "$PROFILES_DIR/active")"; return; fi
    local found=()
    local p
    while IFS= read -r p; do found+=("$p"); done < <(all_profiles || true)
    if [ "${#found[@]}" -eq 1 ]; then echo "${found[0]}"; return; fi
    echo ""
}

# python readers (never print secrets to stderr)
email_of() { python3 - "$1" <<'PY'
import json,sys,base64
try:
    d=json.load(open(sys.argv[1]))
    t=d.get("tokens",{}).get("id_token","")
    p=t.split(".")[1]; p+="="*(-len(p)%4)
    print(json.loads(base64.b64decode(p)).get("email",""))
except Exception:
    print("")
PY
}

access_exp() { python3 - "$1" <<'PY'
import json,sys,base64
try:
    d=json.load(open(sys.argv[1]))
    t=d.get("tokens",{}).get("access_token","")
    p=t.split(".")[1]; p+="="*(-len(p)%4)
    print(int(json.loads(base64.b64decode(p)).get("exp",0)))
except Exception:
    print(0)
PY
}

tokens_json() { python3 - "$1" <<'PY'
import json,sys
try:
    d=json.load(open(sys.argv[1]))
    print(json.dumps(d.get("tokens") or {}))
except Exception:
    print("{}")
PY
}

tokens_get() { # file key
    python3 - "$1" "$2" <<'PY'
import json,sys
try:
    d=json.load(open(sys.argv[1]))
    print((d.get("tokens") or {}).get(sys.argv[2]) or "")
except Exception:
    print("")
PY
}

# ----------------------------------------------------------------------------
# refresh / publish / pull / push
# ----------------------------------------------------------------------------

refresh_profile() { # profile -> updates its auth.json with fresh tokens
    local p="$1" af; af="$(auth_file "$p")"
    [ -f "$af" ] || die "refresh: missing auth.json for '$p' at $af"
    local rt; rt="$(tokens_get "$af" refresh_token)"
    [ -n "$rt" ] || die "refresh: '$p' has no refresh_token"
    is_sentinel "$rt" && die "refresh: '$p' is a follower (sentinel token); nothing to refresh"
    local resp
    resp="$(curl -s -X POST "$TOKEN_EP" \
        -H "Content-Type: application/x-www-form-urlencoded" \
        -d "grant_type=refresh_token&client_id=${CLIENT_ID}&refresh_token=${rt}")" || die "refresh: curl failed"
    python3 - "$af" "$resp" <<'PY'
import json,sys,os
from datetime import datetime,timezone
af,raw=sys.argv[1],sys.argv[2]
resp=json.loads(raw)
if "access_token" not in resp:
    err=resp.get("error_description") or resp.get("error") or json.dumps(resp)
    print(f"refresh FAILED: {err}",file=sys.stderr); sys.exit(1)
d=json.load(open(af))
d.setdefault("tokens",{})
d["tokens"]["access_token"]=resp["access_token"]
d["tokens"]["refresh_token"]=resp["refresh_token"]
if "id_token" in resp: d["tokens"]["id_token"]=resp["id_token"]
d["last_refresh"]=datetime.now(timezone.utc).isoformat()
json.dump(d,open(af,"w"),indent=2); os.chmod(af,0o600)
print("refreshed")
PY
}

publish_profile() { # profile -> refresh + write shared file with sentinel RT
    local p="$1" af sf email
    af="$(auth_file "$p")"; sf="$(shared_file "$p")"
    [ -f "$af" ] || die "publish: missing auth.json for '$p'"
    refresh_profile "$p" >/dev/null || die "publish: could not refresh '$p' (refresh token invalid — relogin required)"
    email="$(email_of "$af")"
    mkdir -p "$SHARED_DIR"
    python3 - "$af" "$sf" "$p" "$email" "$SENTINEL_RT" "$LEADER_HOST" <<'PY'
import json,sys,os
from datetime import datetime,timezone
af,sf,profile,email,sentinel,leader=sys.argv[1:7]
d=json.load(open(af))
out=dict(d)
out.setdefault("tokens",{})
out["tokens"]["refresh_token"]=sentinel   # strip real refresh_token for followers
out["email"]=email
out["profile"]=profile
out["leader"]=leader
out["published_at"]=datetime.now(timezone.utc).isoformat()
json.dump(out,open(sf,"w"),indent=2); os.chmod(sf,0o600)
print(f"published {profile} ({email}) -> {sf}")
PY
}

pull_profile() { # profile -> local auth: shared file (mesh) or codex-vault serve (ACL)
    local p="$1" sf af
    sf="$(shared_file "$p")"; af="$(auth_file "$p")"
    mkdir -p "$(dirname "$af")"
    if [ -f "$sf" ]; then
        # Fast path: trusted Syncthing mesh (operator machines).
        python3 - "$sf" "$af" <<'PY'
import json,sys,os
sf,af=sys.argv[1],sys.argv[2]
d=json.load(open(sf))
clean={k:d[k] for k in ("auth_mode","tokens","last_refresh","account_id") if k in d}
json.dump(clean,open(af,"w"),indent=2); os.chmod(af,0o600)
PY
        echo "pulled"
    else
        # ACL-gated path: ask the leader (HTTPS if configured, else SSH).
        local tmp="$af.tmp"
    if have_http_vault; then
        say "pushing '$p' to $(vault_url) (HTTPS)..."
        vault_http POST "/push/codex/$p" "$af" >/dev/null || die "push: leader rejected '$p' (not owner, or token invalid)"
    else
        need_cmd ssh
        say "pushing '$p' to leader $LEADER_HOST (vault/SSH)..."
        ssh_vault "codex-vault receive codex:$p" < "$af" \
            || die "push: leader rejected '$p' (not owner, unreachable, or token invalid)"
    fi
        python3 - "$tmp" "$af" <<'PY'
import json,sys,os
src,dst=sys.argv[1],sys.argv[2]
d=json.load(open(src))
clean={k:d[k] for k in ("auth_mode","tokens","last_refresh","account_id") if k in d}
json.dump(clean,open(dst,"w"),indent=2); os.chmod(dst,0o600); os.remove(src)
PY
        echo "pulled (via vault)"
    fi
}

push_profile() { # profile -> vault receive (owner-gated), then revert local to follower
    local p="$1" af rt
    af="$(auth_file "$p")"
    [ -f "$af" ] || die "push: no local auth.json for '$p' (log in first: codex-$p login)"
    rt="$(tokens_get "$af" refresh_token)"
    [ -n "$rt" ] || die "push: '$p' has no refresh_token to push"
    is_sentinel "$rt" && die "push: '$p' only has a sentinel token (already a follower). Log in first: codex-$p login"
    need_cmd ssh
    if have_http_vault; then
        say "pushing '$p' to $(vault_url) (HTTPS)..."
        vault_http POST "/push/$p" "$af" >/dev/null || die "push: leader rejected '$p' (not owner, or token invalid)"
    else
        say "pushing '$p' to leader $LEADER_HOST (vault/SSH)..."
        ssh_vault "codex-vault receive '$p'" < "$af" \
            || die "push: leader rejected '$p' (not owner, unreachable, or token invalid)"
    fi
    # Leader stored + refreshed + published -> safe to revert local to follower.
    python3 - "$af" "$SENTINEL_RT" <<'PY'
import json,sys,os
af,sentinel=sys.argv[1],sys.argv[2]
d=json.load(open(af)); d.setdefault("tokens",{})["refresh_token"]=sentinel
json.dump(d,open(af,"w"),indent=2); os.chmod(af,0o600)
PY
    set_role "$p" follower
    pull_profile "$p" >/dev/null 2>&1 || true
    say "reverted '$p' to follower (sentinel token)"
}

sync_profile() { # profile -> role-aware one-shot
    local p="$1" role rt
    role="$(role_of "$p")"
    if [ "$role" = "leader" ]; then
        [ -f "$(auth_file "$p")" ] || die "sync: leader '$p' has no auth.json to publish"
        publish_profile "$p"
    else
        rt="$(tokens_get "$(auth_file "$p")" refresh_token)"
        if [ -n "$rt" ] && ! is_sentinel "$rt"; then
            push_profile "$p"          # follower holding a real token (just logged in)
        else
            pull_profile "$p"          # follower: read published token (creates local if needed)
        fi
    fi
}

# ----------------------------------------------------------------------------
# status (no secrets)
# ----------------------------------------------------------------------------

fmt_remaining() { # epoch_seconds
    local exp="$1" now delta
    now="$(date +%s)"
    delta=$(( exp - now ))
    if [ "$delta" -le 0 ]; then echo "expired"; return; fi
    printf '%dd %dh' $((delta/86400)) $(((delta%86400)/3600))
}

status_profile() {
    local p="$1" af role email exp rt_state
    af="$(auth_file "$p")"
    if [ ! -f "$af" ]; then printf '  %-12s (no auth)\n' "$p"; return; fi
    role="$(role_of "$p")"
    email="$(email_of "$af")"; [ -n "$email" ] || email="?"
    exp="$(access_exp "$af")"
    if [ "$exp" -gt 0 ]; then exp="valid $(fmt_remaining "$exp")"; else exp="age unknown"; fi
    if is_sentinel "$(tokens_get "$af" refresh_token)"; then rt_state="sentinel"; else rt_state="REAL"; fi
    printf '  %-12s %-8s %-28s token %s  rt=%s\n' "$p" "$role" "$email" "$exp" "$rt_state"
    local sf; sf="$(shared_file "$p")"
    if [ -f "$sf" ]; then
        local pexp; pexp="$(python3 -c 'import json,sys; print(0)' 2>/dev/null)"
        printf '    published: %s (leader=%s)\n' "$(py_json_get "$sf" published_at 2>/dev/null || echo '?')" "$(py_json_get "$sf" leader 2>/dev/null || echo '?')"
    fi
}

py_json_get() { python3 -c 'import json,sys; d=json.load(open(sys.argv[1])); v=d.get(sys.argv[2]); print(v if v is not None else "")' "$1" "$2" 2>/dev/null || echo ""; }

# ----------------------------------------------------------------------------
# commands
# ----------------------------------------------------------------------------

cmd_print() {
    if [ -n "${OPENAI_API_KEY:-}" ]; then
        echo "{\"access_token\":\"$OPENAI_API_KEY\"}"
        return
    fi
    local p="$PROFILE" af
    [ -n "$p" ] || p="$(resolve_profile)"
    if [ -n "$p" ] && [ -f "$(auth_file "$p")" ]; then
        af="$(auth_file "$p")"
    elif [ -f "$LEGACY_AUTH" ]; then
        af="$LEGACY_AUTH"
    else
        die "No Codex auth found - run 'codex login' first"
    fi
    tokens_json "$af"
}

cmd_status() {
    say "machine: $(short_host)  (default role: $(hostname_is_leader_default && echo leader || echo follower))"
    say "profiles dir: $PROFILES_DIR   shared: $SHARED_DIR   leader: $LEADER_HOST"
    echo
    local p
    if [ "$ALL" = "1" ]; then
        for p in $(all_profiles || true); do status_profile "$p"; done
    elif [ -n "$PROFILE" ]; then
        status_profile "$PROFILE"
    else
        for p in $(all_profiles || true); do status_profile "$p"; done
        [ -n "$(all_profiles || true)" ] || say "(no profiles; legacy auth: $LEGACY_AUTH)"
    fi
}

cmd_publish() {
    local p
    if [ "$ALL" = "1" ]; then
        for p in $(all_profiles || true); do ( publish_profile "$p" ) || say "  (skipped $p: failed)"; done
    else
        [ -n "$PROFILE" ] || PROFILE="$(resolve_profile)"
        require_profile "$PROFILE"; publish_profile "$PROFILE"
    fi
}

cmd_pull() {
    local p
    if [ "$ALL" = "1" ]; then
        for p in $(all_profiles || true); do ( pull_profile "$p" ) || say "  (skipped $p: failed)"; done
    else
        [ -n "$PROFILE" ] || PROFILE="$(resolve_profile)"
        [ -n "$PROFILE" ] || die "no profile specified (use --profile <name> or --all)"
        pull_profile "$PROFILE"
    fi
}

cmd_push() {
    local p
    if [ "$ALL" = "1" ]; then
        for p in $(all_profiles || true); do
            local rt; rt="$(tokens_get "$(auth_file "$p")" refresh_token)"
            { [ -n "$rt" ] && ! is_sentinel "$rt"; } && ( push_profile "$p" ) || say "skip '$p' (no real token / failed)"
        done
    else
        [ -n "$PROFILE" ] || PROFILE="$(resolve_profile)"
        require_profile "$PROFILE"; push_profile "$PROFILE"
    fi
}

cmd_sync() {
    local p
    if [ "$ALL" = "1" ]; then
        for p in $(all_profiles || true); do ( sync_profile "$p" ) || say "  (skipped $p: failed)"; done
    else
        [ -n "$PROFILE" ] || PROFILE="$(resolve_profile)"
        require_profile "$PROFILE"; sync_profile "$PROFILE"
    fi
}

require_profile() { [ -n "${1:-}" ] && [ -f "$(auth_file "$1")" ] || die "no profile/auth found. Use --profile <name> or create one (codex-<name> login)."; }

# ---- single-account (homebrew-only) flow: pair / login / run / install-wrapper ----

cmd_pair() {
    local user="${PROFILE:-${CODEX_USER:-}}"
    while [ -z "$user" ]; do read -rp "Your username on the vault: " user; done
    mkdir -p "$VAULT_DIR_CLIENT"
    if [ ! -f "$VAULT_KEY" ]; then
        ssh-keygen -q -t ed25519 -N "" -C "$user@$(short_host)" -f "$VAULT_KEY"
        say "generated vault key: $VAULT_KEY"
    fi
    printf 'user=%s\nleader=%s\n' "$user" "$LEADER_HOST" > "$CONFIG_FILE"
    chmod 600 "$CONFIG_FILE"
    local pub=""; [ -f "$VAULT_KEY" ] && pub="$(cat "$VAULT_KEY.pub")"
    cat <<EOF

Pairing as '$user'.

OPTION A — HTTPS vault (recommended; no SSH/Tailscale needed):
  Ask the operator to approve you. They run, on the leader:
    codex-vault token $user          # prints a one-time API token -> send it to you
  Then on this machine, ONE command (codex + claude, URL defaults to the vault):
    codex-token install --token <the-token> --user $user

OPTION B — SSH (Tailscale + approved SSH key). Send this one line to the operator:
--------------------------------------------------------------------------------
command="codex-vault shell $user",no-pty,no-port-forwarding,no-X11-forwarding,no-agent-forwarding $pub
--------------------------------------------------------------------------------
  They run: codex-vault approve $user '<that line>'

Then run:  codex-token login
EOF
}

cmd_login() {
    local user; user="$(config_user)"
    [ -n "$user" ] || die "login: no user configured. Run 'codex-token pair --user <name>' first."
    local bin; bin="$(resolve_codex_bin)"
    [ -n "$bin" ] || die "login: codex binary not found (install the OpenAI Codex CLI first)."
    need_cmd ssh
    say "starting browser login (sign in as $user's account)..."
    "$bin" login "$@"
    [ -f "$LEGACY_AUTH" ] || die "login: codex login did not create $LEGACY_AUTH"
    # only push if the login produced a real refresh_token
    local rt; rt="$(tokens_get "$LEGACY_AUTH" refresh_token)"
    if [ -n "$rt" ] && ! is_sentinel "$rt"; then
        if have_http_vault; then
            say "pushing your token to $(vault_url) as '$user'..."
            vault_http POST "/push/codex/$user" "$LEGACY_AUTH" >/dev/null || die "login: leader rejected push for '$user' (not approved?)"
        else
            say "pushing your token to the leader as '$user'..."
            ssh_vault "codex-vault receive codex:$user" < "$LEGACY_AUTH" \
                || die "login: leader rejected push for '$user' (not approved yet? wrong user?)"
        fi
        # convert ~/.codex to follower (sentinel RT)
        python3 - "$LEGACY_AUTH" "$SENTINEL_RT" <<'PY'
import json,sys,os
af,s=sys.argv[1],sys.argv[2]; d=json.load(open(af)); d.setdefault("tokens",{})["refresh_token"]=s
json.dump(d,open(af,"w"),indent=2); os.chmod(af,0o600)
PY
    fi
    cmd_run --refresh-only 2>/dev/null || true
    say "paired. Use 'codex' (or 'codex-token run') to work as $user."
}

cmd_run() { # [args...]  -- follower launcher: freshen ~/.codex then exec codex (refresh blackholed)
    local refresh_only=0
    [ "${1:-}" = "--refresh-only" ] && { refresh_only=1; shift; }
    local user; user="$(config_user)"
    [ -n "$user" ] || die "run: no user configured. Run 'codex-token pair' first."
    local sf="$SHARED_DIR/$user.json"
    if [ -f "$sf" ]; then
        _copy_token "$sf" "$LEGACY_AUTH"
    elif have_http_vault; then
        vault_http GET "/pull/codex/$user" > "$LEGACY_AUTH.tmp" \
            || { rm -f "$LEGACY_AUTH.tmp"; die "run: cannot reach/authorized for '$user'"; }
        _copy_token "$LEGACY_AUTH.tmp" "$LEGACY_AUTH"; rm -f "$LEGACY_AUTH.tmp"
    else
        need_cmd ssh
        ssh_vault "codex-vault serve codex:$user" > "$LEGACY_AUTH.tmp" \
            || { rm -f "$LEGACY_AUTH.tmp"; die "run: cannot reach/authorized for '$user' on leader"; }
        _copy_token "$LEGACY_AUTH.tmp" "$LEGACY_AUTH"; rm -f "$LEGACY_AUTH.tmp"
    fi
    [ "$refresh_only" = "1" ] && return 0
    local bin; bin="$(resolve_codex_bin)"
    [ -n "$bin" ] || die "run: codex binary not found."
    export CODEX_REFRESH_TOKEN_URL_OVERRIDE="$BLACKHOLE_URL"
    exec "$bin" "$@"
}

cmd_set_url() {
    [ -n "${1:-}" ] || die "set-url: specify the vault URL (e.g. https://vault.ekelvin.com)"
    set_config url "$1"
    say "vault URL = $1"
}

cmd_set_token() {
    [ -n "${1:-}" ] || die "set-token: specify the API token the operator gave you"
    set_config token "$1"
    say "vault token stored in $CONFIG_FILE"
}

cmd_install_wrapper() {
    mkdir -p "$HOME/bin"
    local w="$HOME/bin/codex"
    if [ -e "$w" ] && [ ! -e "$w.pre-codex-token" ]; then mv "$w" "$w.pre-codex-token"; say "backed up existing wrapper -> $w.pre-codex-token"; fi
    cat > "$w" <<'EOF'
#!/usr/bin/env bash
exec codex-token run "$@"
EOF
    chmod +x "$w"
    say "installed $w -> codex-token run (plain 'codex' now runs as your follower account)."
    case ":$PATH:" in *":$HOME/bin:"*) ;; *) say "NOTE: add \$HOME/bin to your PATH for 'codex' to resolve to the wrapper." ;; esac
}

# ---- unified install (codex + claude) ----
CLAUDE_SHARED_DIR="${CODEX_CLAUDE_SHARED_DIR:-$HOME/shared/claude-tokens}"

codex_rt_is_real() { local rt; rt="$(tokens_get "$1" refresh_token)"; [ -n "$rt" ] && ! is_sentinel "$rt"; }
revert_sentinel() { python3 - "$1" "$SENTINEL_RT" <<'PY'
import json,sys,os
af,s=sys.argv[1],sys.argv[2]; d=json.load(open(af)); d.setdefault("tokens",{})["refresh_token"]=s
json.dump(d,open(af,"w"),indent=2); os.chmod(af,0o600)
PY
}
resolve_claude_bin() {
    local cands="$HOME/bin/claude.real:$(command -v claude 2>/dev/null):/opt/homebrew/bin/claude:/usr/local/bin/claude"
    local IFS=':' d
    for d in $cands; do [ -n "$d" ] && [ -x "$d" ] || continue; case "$d" in *"$HOME/bin"*) continue ;; esac; echo "$d"; return; done
    command -v claude
}
claude_access_token() { python3 - "$1" <<'PY'
import json,sys
try:
    d=json.load(open(sys.argv[1])); o=d.get("claudeAiOauth",d); print(o.get("accessToken",""))
except Exception: print("")
PY
}
# local claude creds (for pushing): macOS Keychain, else credentials file
claude_local_creds() {
    if command -v security >/dev/null 2>&1; then
        security find-generic-password -s "Claude Code-credentials" -w 2>/dev/null
    else
        for f in "$HOME/.claude/.credentials.json" "$HOME/.claude/credentials.json"; do [ -f "$f" ] && { cat "$f"; return; }; done
    fi
}

install_codex_for() {
    local user="$1"
    if [ -f "$LEGACY_AUTH" ] && codex_rt_is_real "$LEGACY_AUTH"; then
        say "  codex: pushing local token to leader..."
        vault_http POST "/push/codex/$user" "$LEGACY_AUTH" >/dev/null || die "  codex: push rejected (not owner?)"
        revert_sentinel "$LEGACY_AUTH"; say "  codex: ✓ pushed (local reverted to follower)"
    else
        say "  codex: pulling follower token..."
        mkdir -p "$(dirname "$LEGACY_AUTH")"
        if vault_http GET "/pull/codex/$user" > "$LEGACY_AUTH.tmp" 2>/dev/null; then
            _copy_token "$LEGACY_AUTH.tmp" "$LEGACY_AUTH"; rm -f "$LEGACY_AUTH.tmp"; say "  codex: ✓ follower token installed"
        else
            rm -f "$LEGACY_AUTH.tmp"; say "  codex: no token on the leader yet — run 'codex login' to push yours"
        fi
    fi
    cmd_install_wrapper >/dev/null 2>&1 || true
    say "  codex: ✓ wrapper installed (plain 'codex' = follower)"
}

cmd_install_claude_wrapper() {
    mkdir -p "$HOME/bin"
    local w="$HOME/bin/claude"
    if [ -e "$w" ] && [ ! -e "$w.pre-codex-token" ]; then mv "$w" "$w.pre-codex-token"; fi
    cat > "$w" <<'EOF'
#!/usr/bin/env bash
if [ "${1:-}" = "login" ]; then exec codex-token claude-login "$@"; fi
exec codex-token claude-run "$@"
EOF
    chmod +x "$w"
}

# install-claude-launcher <user> -> ~/bin/claude-<user> (run claude as claude:<user>)
cmd_install_claude_launcher() {
    local user="$1"
    [ -n "$user" ] || die "install-claude-launcher: specify a user (e.g. adriana)"
    mkdir -p "$HOME/bin"
    local w="$HOME/bin/claude-$user"
    cat > "$w" <<EOF
#!/usr/bin/env bash
exec codex-token claude-run --user $user "\$@"
EOF
    chmod +x "$w"
    say "installed $w -> runs claude as claude:$user (pulls its access token, injects ANTHROPIC_AUTH_TOKEN)"
}

install_claude_for() {
    local user="$1" creds="" tmp
    creds="$(claude_local_creds)" || true
    if [ -n "$creds" ] && printf '%s' "$creds" | grep -q refreshToken; then
        say "  claude: pushing local credentials to leader..."
        tmp="$(mktemp)"; printf '%s' "$creds" > "$tmp"
        vault_http POST "/push/claude/$user" "$tmp" >/dev/null || { rm -f "$tmp"; die "  claude: push rejected"; }
        rm -f "$tmp"; say "  claude: ✓ pushed"
    else
        say "  claude: (no local refresh token — follower will pull access token at runtime)"
    fi
    cmd_install_claude_wrapper
    say "  claude: ✓ wrapper installed (plain 'claude' = follower via ANTHROPIC_AUTH_TOKEN)"
}

cmd_claude_run() { # [--user U] [claude args] -- follower launcher: pull access token, inject, exec
    local user; user="$(config_user)"
    if [ "${1:-}" = "--user" ]; then user="$2"; shift 2; fi
    [ -n "$user" ] || die "claude-run: no user. Run 'codex-token install' or pass --user."
    local sf="$CLAUDE_SHARED_DIR/$user.json" tok=""
    if [ -f "$sf" ]; then tok="$(claude_access_token "$sf")"; fi
    if [ -z "$tok" ] && have_http_vault; then
        local tmp; tmp="$(mktemp)"
        vault_http GET "/pull/claude/$user" > "$tmp" 2>/dev/null && tok="$(claude_access_token "$tmp")"
        rm -f "$tmp"
    fi
    [ -n "$tok" ] || die "claude-run: no access token for claude:$user (not pushed/revived?)"
    local bin; bin="$(resolve_claude_bin)"
    [ -n "$bin" ] || die "claude-run: claude binary not found."
    export ANTHROPIC_AUTH_TOKEN="$tok"
    exec "$bin" "$@"
}

# claude-login [--user U] [login args] -- run `claude login`, then push creds to the vault
cmd_claude_login() {
    local user; user="$(config_user)"
    if [ "${1:-}" = "--user" ]; then user="$2"; shift 2; fi
    [ -n "$user" ] || die "claude-login: no user. Run 'codex-token install' or pass --user."
    local bin; bin="$(resolve_claude_bin)"
    [ -n "$bin" ] || die "claude-login: claude binary not found."
    "$bin" login "$@"
    local creds tmp; creds="$(claude_local_creds)" || true
    if [ -n "$creds" ] && printf '%s' "$creds" | grep -q refreshToken; then
        say "pushing claude credentials to leader as claude:$user..."
        tmp="$(mktemp)"; printf '%s' "$creds" > "$tmp"
        vault_http POST "/push/claude/$user" "$tmp" >/dev/null || { rm -f "$tmp"; die "claude-login: leader rejected push (not approved for claude:$user?)"; }
        rm -f "$tmp"; say "claude: ✓ pushed (leader will refresh + publish)"
    else
        say "claude-login: no refresh token found after login; nothing pushed"
    fi
}

derive_user() {   # default handle from computer name, sanitized
    local u; u="$(hostname -s 2>/dev/null || hostname)"
    u="$(printf '%s' "$u" | tr '[:upper:]' '[:lower:]' | tr -dc 'a-z0-9' | cut -c1-20)"
    [ -n "$u" ] || u="user"; echo "$u"
}
random_code()   { python3 -c 'import secrets;print("".join(secrets.choice("23456789ABCDEFGHJKMNPQRSTVWXYZ") for _ in range(5)))'; }
random_secret() { python3 -c 'import secrets;print(secrets.token_urlsafe(32))'; }

# pair_and_get_token <user>: POST a pairing request, show the code, poll until
# the operator approves; print the resulting API token to stdout.
pair_and_get_token() {
    local user="$1" code secret sh tok
    code="$(random_code)"; secret="$(random_secret)"
    sh="$(printf '%s' "$secret" | shasum -a 256 | cut -d' ' -f1)"
    curl -fsS -X POST "$(vault_url)/pair" -H "Content-Type: application/json" \
        --data "{\"user\":\"$user\",\"code\":\"$code\",\"secret_hash\":\"$sh\"}" >/dev/null \
        || die "pair: cannot reach vault at $(vault_url)"
    cat >&2 <<EOF

  Pairing as '$user'.  Pairing code:  $code
  Tell the operator to run, on the leader:
      codex-vault pair-approve $code
  Waiting for approval (up to ~5 min)…
EOF
    local i
    for i in $(seq 1 60); do
        sleep 5
        tok="$(curl -fsS -X POST "$(vault_url)/pair/$code/poll" -H "Content-Type: application/json" \
            --data "{\"secret\":\"$secret\"}" 2>/dev/null | python3 -c 'import json,sys
d=json.load(sys.stdin)
if d.get("status")=="approved": print(d.get("token",""))
' 2>/dev/null)" || true
        [ -n "$tok" ] && { say "  ✓ paired as '$user'" >&2; printf '%s' "$tok"; return 0; }
    done
    return 1
}

# codex-token install [--token <API_TOKEN>] [--user NAME]
#   no --token  -> magical pairing (user defaults to your computer name)
#   --token T   -> direct (token from `codex-vault onboard/pair-approve`)
cmd_install() {
    local user="${CODEX_USER:-}" token=""
    while [ $# -gt 0 ]; do
        case "$1" in
            --token) token="${2:-}"; shift 2;;
            --user)  user="${2:-}";  shift 2;;
            -h|--help) echo "usage: codex-token install [--token <API_TOKEN>] [--user NAME]"; return 0;;
            *) die "install: unknown arg: $1";;
        esac
    done
    mkdir -p "$VAULT_DIR_CLIENT"
    if [ -z "$token" ]; then
        [ -n "$user" ] || user="$(derive_user)"
        token="$(pair_and_get_token "$user")" || die "install: pairing timed out / failed"
    fi
    [ -n "$user" ] || user="$(derive_user)"
    set_config user "$user"
    set_config token "$token"
    say "vault: user=$user  url=$(vault_url)"
    # verify the token authenticates (/status is admin-only; use the user's own pull endpoint)
    local probe; probe="$(vault_http GET "/pull/codex/$user" 2>&1 || true)"
    case "$probe" in *401*|*unauthorized*) die "install: vault rejected the token (401). url=$(vault_url)" ;; esac
    say "  ✓ authenticated"
    if command -v codex >/dev/null 2>&1 || [ -f "$LEGACY_AUTH" ]; then install_codex_for "$user"; else say "  – codex CLI not found; skipping codex"; fi
    if command -v claude >/dev/null 2>&1; then install_claude_for "$user"; else say "  – claude CLI not found; skipping claude"; fi
    say "install complete. Verify with: codex-token status --all"
}

cmd_diagnose() {
    say "codex-token $VERSION"
    say "PROFILES_DIR=$PROFILES_DIR"
    say "SHARED_DIR=$SHARED_DIR"
    say "LEADER_HOST=$LEADER_HOST"
    say "LEGACY_AUTH=$LEGACY_AUTH"
    say "short_host=$(short_host)  default_role=$(hostname_is_leader_default && echo leader || echo follower)"
    say "profiles: $(all_profiles | tr '\n' ' ')"
    say "shared files: $(ls -1 "$SHARED_DIR"/*.json 2>/dev/null | tr '\n' ' ')"
}

show_help() {
    cat <<'HELP'
codex-token — print and sync Codex/Claude CLI credentials via the leader vault.

NEW MACHINE (one command, codex + claude):
  codex-token install --token <API_TOKEN> [--user NAME]
      Configures the vault (URL defaults to https://vault.ekelvin.com), then for
      each CLI present (codex, claude): pushes any local real token to the leader
      (else pulls a follower token) and installs a follower wrapper. Get the token
      from the operator (on the leader: `codex-vault token <user>`).

Usage:
  codex-token install --token T [--user U]   ONE-command onboarding (codex + claude).
  codex-token login [--user U]               Browser OAuth for codex → push → follower.
  codex-token run [codex args]               Follower launcher for codex (refresh blackholed).
  codex-token claude-run [claude args]       Follower launcher for claude (ANTHROPIC_AUTH_TOKEN).
  codex-token install-wrapper                (re)install the plain `codex` follower wrapper.
  codex-token pair [--user U]                Generate an SSH key + show the approve line.
  codex-token set-url URL                    Override the vault URL (default: https://vault.ekelvin.com).
  codex-token set-token T                    Store an API token (done by `install`).
  codex-token status [--profile P|--all]     Roles, token age, sync health (no secrets).
  codex-token push [--profile P|--all]       Push a local real token to the leader (owner-gated).
  codex-token pull [--profile P|--all]       Pull a published follower token into a local profile.
  codex-token publish [--profile P|--all]    LEADER: refresh + publish token to the shared dir.
  codex-token sync [--profile P|--all]       Role-aware: publish / push / pull as appropriate.
  codex-token [print] [--profile P]          Print active/given profile tokens (default).

Options:
  --profile P        Act on profile P (default: auto-detect active profile).
  --all              Act on every profile.
  --leader HOST      Override leader SSH host (default: farol-ts; env CODEX_LEADER).
  --version, -v      Print version.
  --diagnose         Print config (no secrets).
  --help, -h         This message.

Model: one leader owns each account's real refresh_token and publishes a fresh
(~10d) access token. Followers use a sentinel refresh token (codex: refresh
blackholed) or an injected access token (claude: ANTHROPIC_AUTH_TOKEN), so they
never rotate the leader's token.
HELP

}

# ----------------------------------------------------------------------------
# arg parsing + dispatch
# ----------------------------------------------------------------------------

# Commands that forward their remaining args verbatim to the tool.
case "${1:-}" in
    run)   shift; cmd_run "$@"; exit $? ;;
    login) shift; cmd_login "$@"; exit $? ;;
    claude-run) shift; cmd_claude_run "$@"; exit $? ;;
    claude-login) shift; cmd_claude_login "$@"; exit $? ;;
    install)    shift; cmd_install "$@"; exit $? ;;
    install-claude-launcher) shift; cmd_install_claude_launcher "${1:-}"; exit $? ;;
    set-url)   shift; cmd_set_url "${1:-}"; exit $? ;;
    set-token) shift; cmd_set_token "${1:-}"; exit $? ;;
esac

CMD="print"
PROFILE=""
ALL="0"

while [ $# -gt 0 ]; do
    case "$1" in
        print|status|publish|pull|push|sync|pair|install-wrapper) CMD="$1"; shift;;
        --profile|-p) PROFILE="${2:-}"; shift 2;;
        --user|-u) CODEX_USER="${2:-}"; shift 2;;
        --all|-a) ALL="1"; shift;;
        --leader) LEADER_HOST="${2:-}"; shift 2;;
        --version|-v) echo "codex-token $VERSION"; exit 0;;
        --diagnose) CMD="diagnose"; shift;;
        --help|-h) show_help; exit 0;;
        --) shift; break;;
        -*) die "unknown option: $1 (see --help)";;
        *)  if [ "$CMD" = "print" ] && [ -z "$PROFILE" ]; then PROFILE="$1"; else die "unexpected argument: $1"; fi; shift;;
    esac
done

case "$CMD" in
    print)    cmd_print;;
    status)   cmd_status;;
    publish)  cmd_publish;;
    pull)     cmd_pull;;
    push)     cmd_push;;
    sync)     cmd_sync;;
    diagnose) cmd_diagnose;;
    pair)           cmd_pair;;
    install-wrapper) cmd_install_wrapper;;
    *)        die "unknown command: $CMD";;
esac
