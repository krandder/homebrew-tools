[Unit]
Description=Daily ai-token follower lifecycle canary
After=network-online.target
Wants=network-online.target
OnFailure=ai-token-canary-alert@%n.service

[Service]
Type=oneshot
ExecStart=/home/kas/.ai-token-canary/release/current/tools/run-live-canary --config /home/kas/.ai-token-canary/canary.json --live
