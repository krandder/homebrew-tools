#!/usr/bin/env bash
# kimi-any-mirror — follower-side feed for kimi-any-proxy. Materializes
# vault-published shared files (~/shared/kimi-tokens/<p>.json, via syncthing)
# into the leader layout the proxy reads (~/.kimi-profiles/<p>/credentials.json).
# Strips publish metadata and neuters refresh_token (followers never refresh).
# Usage: kimi-any-mirror [profile]   (no arg = mirror all shared files)
set -euo pipefail
SHARED="${KIMI_SHARED_DIR:-$HOME/shared/kimi-tokens}"
PROFILES="${KIMI_PROFILES_DIR:-$HOME/.kimi-profiles}"
python3 - "$SHARED" "$PROFILES" "${1:-}" <<'PY'
import json, os, sys, glob, tempfile
shared, profiles, only = sys.argv[1], sys.argv[2], sys.argv[3] or None
META = {"profile", "leader", "published_at"}
files = [os.path.join(shared, f"{only}.json")] if only else glob.glob(os.path.join(shared, "*.json"))
n = 0
for f in files:
    name = os.path.basename(f)[:-5]
    if ".sync-conflict-" in name or not os.path.exists(f):
        continue
    try:
        d = json.load(open(f))
    except Exception:
        continue
    if not d.get("access_token"):
        continue
    d = {k: v for k, v in d.items() if k not in META}
    if "refresh_token" in d:
        d["refresh_token"] = "sentinel-follower"
    dest_dir = os.path.join(profiles, name)
    os.makedirs(dest_dir, exist_ok=True)
    fd, tmp = tempfile.mkstemp(dir=dest_dir)
    with os.fdopen(fd, "w") as fh:
        json.dump(d, fh, indent=2)
    os.replace(tmp, os.path.join(dest_dir, "credentials.json"))
    n += 1
print(f"kimi-any-mirror: {n} profile(s) mirrored")
PY
