#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "$0")/.." && pwd)"
MODE="${1:-full}"
case "$MODE" in fast|full) ;; *) echo "usage: tests/run [fast|full]" >&2; exit 2 ;; esac
cd "$ROOT"

for script in ai-token ai-vault claude-token codex-token setup-claude-token; do
    bash -n "$script"
done
python3 - <<'PY'
from pathlib import Path
for script in ("ai-vault-http", "ai-any"):
    compile(Path(script).read_text(encoding="utf-8"), script, "exec")
PY

for pattern in 'test_ai_any.py' 'test_ai_token*.py' 'test_ai_vault*.py' 'test_any_mirrors.py' 'test_any_wrappers.py' 'test_ci_contract.py' 'test_compatibility_shims.py' 'test_follower_leader*.py' 'test_formula_integrity.py' 'test_img_bridge.py' 'test_release*.py' 'test_service_environment.py'; do
    python3 -m unittest discover -s tests -p "$pattern"
done
for test_file in tests/test-*.sh; do
    echo "RUN $(basename "$test_file")"
    bash "$test_file"
done

echo "ok: $MODE suite"
