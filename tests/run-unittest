#!/usr/bin/env python3
import sys
import unittest


suite = unittest.defaultTestLoader.discover(sys.argv[1], pattern=sys.argv[2])
result = unittest.TextTestRunner().run(suite)
if result.skipped or result.expectedFailures:
    print("strict-unittest: skips and expected failures are failures", file=sys.stderr)
    raise SystemExit(1)
raise SystemExit(not result.wasSuccessful())
