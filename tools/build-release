#!/usr/bin/env python3
import argparse
import hashlib
import io
import json
import os
import pathlib
import stat
import subprocess
import sys
import tempfile
import zipfile


PAYLOAD = (
    "ai-token",
    "ai-vault",
    "ai-vault-http",
    "claude-token",
    "codex-token",
    "setup-claude-token",
    "ai-any",
    "claude-any",
    "codex-any",
    "kimi-any",
    "claude-any-mirror",
    "codex-any-mirror",
    "kimi-any-mirror",
    "any-proxy.mjs",
    "codex-any-proxy.mjs",
    "kimi-any-proxy.mjs",
    "Formula/ai-token.rb",
    "Formula/ai-vault.rb",
    "Formula/ai-vault-http.rb",
    "Formula/claude-token.rb",
    "Formula/codex-token.rb",
    "tools/build-release",
    "tools/install-release",
    "tools/verify-tdd-history",
    "tools/run-live-canary",
    "tools/report-canary-failure",
    "tools/verify-live-soak",
    "tools/collect-live-soak",
    "tools/audit-live-soak",
    "deploy/canary/farol/ai-token-canary.service",
    "deploy/canary/farol/ai-token-canary.timer",
    "deploy/canary/farol/ai-token-canary-alert@.service",
    "deploy/canary/farol/ai-token-canary-vault.service",
    "deploy/canary/farol/ai-token-soak-audit.service",
    "deploy/canary/farol/ai-token-soak-audit.timer",
    "deploy/canary/agent-1/ai-token-canary.service",
    "deploy/canary/agent-1/ai-token-canary.timer",
    "deploy/canary/agent-1/ai-token-canary-alert@.service",
    "deploy/canary/macos/com.futarchy.ai-token-canary-dispatch.plist",
    "deploy/canary/macos/run-as-ai-token-canary.expect",
    "deploy/canary/macos/run-live",
    "deploy/canary/macos/run-scheduled",
)


def git(source, *arguments):
    return subprocess.check_output(
        ["git", *arguments], cwd=source, text=True, stderr=subprocess.STDOUT
    ).strip()


def fail(message):
    print(f"build-release: {message}", file=sys.stderr)
    raise SystemExit(1)


def zip_entry(bundle, name, data, mode):
    info = zipfile.ZipInfo(name, (1980, 1, 1, 0, 0, 0))
    info.create_system = 3
    info.external_attr = (stat.S_IFREG | mode) << 16
    info.compress_type = zipfile.ZIP_DEFLATED
    bundle.writestr(info, data, compress_type=zipfile.ZIP_DEFLATED, compresslevel=9)


def main():
    parser = argparse.ArgumentParser(description="test and build an immutable ai-token/ai-vault release")
    parser.add_argument("--source", type=pathlib.Path, default=pathlib.Path(__file__).resolve().parents[1])
    parser.add_argument("--output", type=pathlib.Path, default=pathlib.Path("dist/releases"))
    args = parser.parse_args()
    source = args.source.resolve()
    output = args.output.resolve()

    try:
        commit = git(source, "rev-parse", "HEAD")
        tree = git(source, "rev-parse", "HEAD^{tree}")
        commit_time = int(git(source, "show", "-s", "--format=%ct", "HEAD"))
        dirty = git(source, "status", "--porcelain", "--untracked-files=no")
    except (subprocess.CalledProcessError, ValueError) as error:
        fail(f"cannot inspect source commit: {error}")
    if dirty:
        fail("tracked worktree is dirty; commit or restore changes before release")
    missing = [relative for relative in PAYLOAD if not (source / relative).is_file()]
    if missing:
        fail("missing release payload: " + ", ".join(missing))

    subprocess.run([source / "tests" / "run", "full"], cwd=source, check=True)

    files = {}
    contents = {}
    for relative in PAYLOAD:
        path = source / relative
        data = path.read_bytes()
        mode = 0o755 if path.stat().st_mode & stat.S_IXUSR else 0o644
        contents[relative] = (data, mode)
        files[relative] = {"sha256": hashlib.sha256(data).hexdigest(), "mode": f"{mode:04o}"}
    manifest = {
        "schema": 1,
        "commit": commit,
        "tree": tree,
        "commit_time": commit_time,
        "test_command": "tests/run full",
        "files": files,
    }
    manifest_bytes = (json.dumps(manifest, indent=2, sort_keys=True) + "\n").encode()

    buffer = io.BytesIO()
    with zipfile.ZipFile(buffer, "w") as bundle:
        for relative in PAYLOAD:
            zip_entry(bundle, relative, *contents[relative])
        zip_entry(bundle, "MANIFEST.json", manifest_bytes, 0o644)
    archive_bytes = buffer.getvalue()
    digest = hashlib.sha256(archive_bytes).hexdigest()
    name = f"ai-token-vault-{commit[:12]}-{digest[:12]}.zip"
    output.mkdir(parents=True, exist_ok=True)
    archive = output / name
    if archive.exists() and archive.read_bytes() != archive_bytes:
        fail(f"immutable artifact collision: {archive}")
    if not archive.exists():
        fd, temporary = tempfile.mkstemp(dir=output, prefix=f".{name}.")
        try:
            with os.fdopen(fd, "wb") as handle:
                handle.write(archive_bytes)
                handle.flush()
                os.fsync(handle.fileno())
            os.replace(temporary, archive)
        finally:
            if os.path.exists(temporary):
                os.unlink(temporary)
    checksum = pathlib.Path(f"{archive}.sha256")
    checksum_fd, checksum_temporary = tempfile.mkstemp(
        dir=output, prefix=f".{checksum.name}.",
    )
    try:
        with os.fdopen(checksum_fd, "w") as handle:
            handle.write(f"{digest}  {name}\n")
            handle.flush()
            os.fsync(handle.fileno())
        os.chmod(checksum_temporary, 0o644)
        os.replace(checksum_temporary, checksum)
        directory_fd = os.open(output, os.O_RDONLY)
        try:
            os.fsync(directory_fd)
        finally:
            os.close(directory_fd)
    finally:
        if os.path.exists(checksum_temporary):
            os.unlink(checksum_temporary)
    print(archive)


if __name__ == "__main__":
    main()
