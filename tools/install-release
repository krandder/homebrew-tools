#!/usr/bin/env python3
import argparse
import contextlib
import datetime
import fcntl
import hashlib
import hmac
import json
import os
import pathlib
import re
import shutil
import stat
import subprocess
import sys
import tempfile
import zipfile


CORE = {"ai-token", "ai-vault", "ai-vault-http"}
HEX40 = re.compile(r"^[0-9a-f]{40}$")
HEX_PREFIX = re.compile(r"^[0-9a-f]{7,40}$")


def fail(message):
    print(f"install-release: {message}", file=sys.stderr)
    raise SystemExit(1)


def sha256(data):
    return hashlib.sha256(data).hexdigest()


def safe_name(name):
    path = pathlib.PurePosixPath(name)
    return bool(name) and not path.is_absolute() and ".." not in path.parts and "." not in path.parts


def read_bundle(archive):
    checksum = pathlib.Path(f"{archive}.sha256")
    if not checksum.is_file():
        fail(f"missing checksum file: {checksum}")
    fields = checksum.read_text().split()
    if len(fields) != 2 or fields[1] != archive.name:
        fail("checksum file does not name the selected archive")
    data = archive.read_bytes()
    digest = sha256(data)
    if not hmac.compare_digest(fields[0], digest):
        fail("archive checksum mismatch")
    try:
        with zipfile.ZipFile(archive) as bundle:
            names = bundle.namelist()
            if len(names) != len(set(names)):
                fail("archive contains duplicate paths")
            for name in names:
                if not safe_name(name):
                    fail(f"unsafe archive path: {name}")
            manifest = json.loads(bundle.read("MANIFEST.json"))
            files = manifest.get("files") or {}
            if set(names) != set(files) | {"MANIFEST.json"}:
                fail("archive and manifest payloads differ")
            if (manifest.get("schema") != 1
                    or not HEX40.match(str(manifest.get("commit", "")))
                    or not HEX40.match(str(manifest.get("tree", "")))):
                fail("invalid release manifest")
            if not CORE.issubset(files):
                fail("release manifest is missing a canonical service")
            payload = {}
            for name, metadata in files.items():
                content = bundle.read(name)
                if sha256(content) != metadata.get("sha256"):
                    fail(f"payload checksum mismatch: {name}")
                try:
                    mode = int(metadata.get("mode", ""), 8)
                except (TypeError, ValueError):
                    fail(f"invalid payload mode: {name}")
                if mode < 0 or mode > 0o777:
                    fail(f"invalid payload mode: {name}")
                payload[name] = (content, mode)
    except (KeyError, json.JSONDecodeError, zipfile.BadZipFile) as error:
        fail(f"invalid release archive: {error}")
    return manifest, payload, digest


def fsync_directory(path):
    descriptor = os.open(path, os.O_RDONLY)
    try:
        os.fsync(descriptor)
    finally:
        os.close(descriptor)


def manifest_bytes(manifest):
    return (json.dumps(manifest, indent=2, sort_keys=True) + "\n").encode()


def write_stage(releases, manifest, payload):
    stage = pathlib.Path(tempfile.mkdtemp(prefix=".install-", dir=releases))
    try:
        for name, (content, mode) in payload.items():
            destination = stage / name
            destination.parent.mkdir(parents=True, exist_ok=True)
            with destination.open("xb") as handle:
                handle.write(content)
                handle.flush()
                os.fsync(handle.fileno())
            destination.chmod(mode)
        with (stage / "MANIFEST.json").open("xb") as handle:
            handle.write(manifest_bytes(manifest))
            handle.flush()
            os.fsync(handle.fileno())
        (stage / "MANIFEST.json").chmod(0o644)
        subprocess.run(["bash", "-n", stage / "ai-token", stage / "ai-vault"], check=True)
        compile((stage / "ai-vault-http").read_text(), "ai-vault-http", "exec")
        for relative in ("tools/run-live-canary", "tools/report-canary-failure", "tools/verify-live-soak"):
            optional = stage / relative
            if optional.is_file():
                compile(optional.read_text(), relative, "exec")
        fsync_directory(stage)
        return stage
    except Exception:
        shutil.rmtree(stage, ignore_errors=True)
        raise


def verify_installed(target, manifest, payload):
    for name, (content, mode) in payload.items():
        path = target / name
        if path.is_symlink() or not path.is_file() or sha256(path.read_bytes()) != sha256(content):
            fail(f"existing immutable release was modified: {target}")
        if stat.S_IMODE(path.stat().st_mode) != mode:
            fail(f"existing immutable release mode changed: {path}")
    if (target / "MANIFEST.json").read_bytes() != manifest_bytes(manifest):
        fail(f"existing immutable release manifest changed: {target}")


def verify_selected(root, expected_commit=None):
    with deployment_lock(root):
        target = release_target(root, "current")
        if target is None:
            fail("no current release is selected")
        manifest_path = target / "MANIFEST.json"
        if manifest_path.is_symlink() or not manifest_path.is_file():
            fail("current release has no regular manifest")
        try:
            manifest = json.loads(manifest_path.read_text())
        except (OSError, json.JSONDecodeError) as error:
            fail(f"invalid installed manifest: {error}")
        files = manifest.get("files") or {}
        commit = str(manifest.get("commit", ""))
        if (manifest.get("schema") != 1 or not HEX40.match(commit)
                or not HEX40.match(str(manifest.get("tree", ""))) or not isinstance(files, dict)):
            fail("invalid installed manifest")
        if not CORE.issubset(files):
            fail("installed manifest is missing a canonical service")
        if expected_commit is not None:
            if not HEX_PREFIX.match(expected_commit) or not commit.startswith(expected_commit):
                fail(f"expected commit {expected_commit}, selected {commit}")
        expected_paths = set(files) | {"MANIFEST.json"}
        actual_paths = {
            path.relative_to(target).as_posix()
            for path in target.rglob("*")
            if path.is_file() or path.is_symlink()
        }
        if actual_paths != expected_paths:
            fail("installed payload and manifest differ")
        for name, metadata in files.items():
            if not safe_name(name) or not isinstance(metadata, dict):
                fail(f"invalid installed payload path: {name}")
            path = target / name
            if path.is_symlink() or not path.is_file():
                fail(f"installed payload is not a regular file: {name}")
            if not hmac.compare_digest(sha256(path.read_bytes()), str(metadata.get("sha256", ""))):
                fail(f"installed payload checksum mismatch: {name}")
            try:
                mode = int(metadata.get("mode", ""), 8)
            except (TypeError, ValueError):
                fail(f"invalid installed payload mode: {name}")
            if stat.S_IMODE(path.stat().st_mode) != mode:
                fail(f"installed payload mode mismatch: {name}")
        audit(root, "verify", target)
    print(json.dumps({
        "status": "ok",
        "target": target.name,
        "commit": commit,
        "tree": manifest["tree"],
        "files": len(files),
    }, separators=(",", ":")))


def atomic_symlink(root, link_name, target):
    temporary = root / f".{link_name}.tmp-{os.getpid()}"
    temporary.unlink(missing_ok=True)
    temporary.symlink_to(os.path.relpath(target, root))
    os.replace(temporary, root / link_name)
    fsync_directory(root)


def release_target(root, link_name):
    link = root / link_name
    if not link.is_symlink():
        return None
    target = link.resolve(strict=True)
    try:
        target.relative_to((root / "releases").resolve())
    except ValueError:
        fail(f"{link_name} points outside the release store")
    return target


def audit(root, action, target, replaced=None):
    record = {
        "ts": datetime.datetime.now(datetime.timezone.utc).isoformat(),
        "action": action,
        "target": target.name,
    }
    if replaced is not None:
        record["replaced"] = replaced.name
    path = root / "deployments.jsonl"
    with path.open("a") as handle:
        handle.write(json.dumps(record, separators=(",", ":")) + "\n")
        handle.flush()
        os.fsync(handle.fileno())
    path.chmod(0o600)
    fsync_directory(root)


@contextlib.contextmanager
def deployment_lock(root):
    root.mkdir(parents=True, exist_ok=True)
    with (root / ".deploy.lock").open("a") as handle:
        fcntl.flock(handle, fcntl.LOCK_EX)
        yield


def install(root, archive):
    manifest, payload, digest = read_bundle(archive)
    releases = root / "releases"
    releases.mkdir(parents=True, exist_ok=True)
    name = f"{manifest['commit'][:12]}-{digest[:12]}"
    target = releases / name
    stage = write_stage(releases, manifest, payload)
    try:
        with deployment_lock(root):
            if target.exists():
                verify_installed(target, manifest, payload)
                shutil.rmtree(stage)
            else:
                os.replace(stage, target)
                fsync_directory(releases)
            old = release_target(root, "current")
            audit(root, "install-intent", target, old)
            if old is not None and old != target:
                atomic_symlink(root, "previous", old)
            atomic_symlink(root, "current", target)
            audit(root, "install", target, old)
    finally:
        if stage.exists():
            shutil.rmtree(stage, ignore_errors=True)
    print(target)


def rollback(root):
    with deployment_lock(root):
        current = release_target(root, "current")
        previous = release_target(root, "previous")
        if current is None or previous is None or current == previous:
            fail("no distinct previous release is available")
        audit(root, "rollback-intent", previous, current)
        atomic_symlink(root, "current", previous)
        atomic_symlink(root, "previous", current)
        audit(root, "rollback", previous, current)
    print(previous)


def main():
    parser = argparse.ArgumentParser(description="verify, stage, and atomically select a release")
    subparsers = parser.add_subparsers(dest="command", required=True)
    install_parser = subparsers.add_parser("install")
    install_parser.add_argument("archive", type=pathlib.Path)
    install_parser.add_argument("--root", type=pathlib.Path, required=True)
    rollback_parser = subparsers.add_parser("rollback")
    rollback_parser.add_argument("--root", type=pathlib.Path, required=True)
    verify_parser = subparsers.add_parser("verify")
    verify_parser.add_argument("--root", type=pathlib.Path, required=True)
    verify_parser.add_argument("--expect-commit")
    args = parser.parse_args()
    root = args.root.resolve()
    if root == pathlib.Path("/"):
        fail("installation root may not be /")
    if args.command == "install":
        install(root, args.archive.resolve())
    elif args.command == "rollback":
        rollback(root)
    else:
        verify_selected(root, args.expect_commit)


if __name__ == "__main__":
    main()
