#!/usr/bin/env python3
"""Send one sanitized lifecycle-canary failure to the authenticated vault."""

import argparse
import json
import os
import pathlib
import re
import socket
import stat
import sys
import urllib.error
import urllib.parse
import urllib.request


PROFILE = re.compile(r"^canary-[A-Za-z0-9._-]+$")
COMMIT = re.compile(r"^[0-9a-f]{40}$")
SAFE = re.compile(r"^[A-Za-z0-9._-]+$")


def fail(message):
    print(f"report-canary-failure: {message}", file=sys.stderr)
    raise SystemExit(1)


def load_json(path):
    if path.is_symlink() or not path.is_file():
        fail("config must be a regular, non-symlink file")
    if stat.S_IMODE(path.stat().st_mode) & (stat.S_IWGRP | stat.S_IWOTH):
        fail("config must not be group- or world-writable")
    try:
        value = json.loads(path.read_text())
    except (OSError, json.JSONDecodeError) as error:
        fail(f"invalid config: {error}")
    if not isinstance(value, dict):
        fail("config must be an object")
    return value


def vault_settings(home):
    candidates = (home / ".codex-token" / "config", home / ".claude-token" / "config")
    path = next((candidate for candidate in candidates if candidate.is_file()), None)
    if path is None or path.is_symlink():
        fail("isolated vault configuration is missing")
    values = {}
    for line in path.read_text().splitlines():
        key, separator, value = line.partition("=")
        if separator and key in {"url", "token"}:
            values[key] = value
    url = values.get("url", "").rstrip("/")
    token = values.get("token", "")
    parsed = urllib.parse.urlparse(url)
    if parsed.scheme not in {"http", "https"} or not parsed.netloc or not token:
        fail("isolated vault URL/token is invalid")
    return url, token


def latest_failure(directory):
    try:
        paths = sorted(directory.glob("*.json"), key=lambda path: path.stat().st_mtime_ns)
    except OSError:
        paths = []
    for path in reversed(paths):
        try:
            record = json.loads(path.read_text())
        except (OSError, json.JSONDecodeError):
            continue
        if not isinstance(record, dict) or record.get("status") != "failed":
            continue
        steps = record.get("steps")
        last = steps[-1] if isinstance(steps, list) and steps else {}
        phase = str(last.get("name", "lifecycle"))
        returncode = last.get("returncode", 1)
        if not SAFE.fullmatch(phase):
            phase = "lifecycle"
        if isinstance(returncode, bool) or not isinstance(returncode, int) or returncode == 0:
            returncode = 1
        return path.name, phase, returncode
    return "unavailable.json", "lifecycle", 1


def main():
    parser = argparse.ArgumentParser(description="report a sanitized live-canary failure")
    parser.add_argument("--config", required=True, type=pathlib.Path)
    args = parser.parse_args()
    config = load_json(args.config)
    profile = str(config.get("profile", ""))
    role = str(config.get("role", ""))
    commit = str(config.get("expect_commit", ""))
    if config.get("non_human") is not True or not PROFILE.fullmatch(profile):
        fail("profile must be explicitly non-human and named canary-*")
    if role not in {"leader", "follower"} or not COMMIT.fullmatch(commit):
        fail("invalid canary role or release commit")
    home = pathlib.Path(str(config.get("home", "")))
    evidence_dir = pathlib.Path(str(config.get("evidence_dir", "")))
    if not home.is_absolute() or not evidence_dir.is_absolute():
        fail("canary paths must be absolute")
    url, token = vault_settings(home)
    evidence, phase, returncode = latest_failure(evidence_dir)
    host = os.environ.get("AI_TOKEN_CANARY_HOST") or socket.gethostname().split(".")[0]
    if not SAFE.fullmatch(host):
        host = re.sub(r"[^A-Za-z0-9._-]", "_", host)
    payload = {
        "schema": 1,
        "host": host,
        "role": role,
        "profile": profile,
        "expect_commit": commit,
        "phase": phase,
        "returncode": returncode,
        "evidence": evidence,
    }
    request = urllib.request.Request(
        f"{url}/canary-alert",
        data=json.dumps(payload, separators=(",", ":")).encode(),
        headers={"Authorization": f"Bearer {token}", "Content-Type": "application/json"},
        method="POST",
    )
    try:
        with urllib.request.urlopen(request, timeout=15) as response:
            if response.status != 200:
                fail(f"vault returned HTTP {response.status}")
    except (OSError, urllib.error.URLError) as error:
        fail(f"delivery failed: {error}")
    print(f"report-canary-failure: delivered ({host} {phase})")


if __name__ == "__main__":
    main()
