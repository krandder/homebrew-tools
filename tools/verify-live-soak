#!/bin/sh
''':'
for python in /opt/homebrew/bin/python3 /usr/local/bin/python3 /usr/bin/python3; do
    [ ! -x "$python" ] || exec "$python" "$0" "$@"
done
echo "verify-live-soak: no supported Python 3 executable found" >&2
exit 127
':'''
"""Verify consecutive, converged cross-host live-canary evidence."""

import argparse
import datetime
import hashlib
import json
import pathlib
import re
import stat
import sys


COMMIT = re.compile(r"^[0-9a-f]{40}$")
RELEASE = re.compile(r"^[0-9a-f]{12}-[0-9a-f]{12}$")
PROFILE = re.compile(r"^canary-[A-Za-z0-9._-]+$")
HOST = re.compile(r"^[A-Za-z0-9._-]+$")
RECORD_KEYS_V2 = {
    "schema",
    "timestamp",
    "host",
    "kind",
    "profile",
    "role",
    "expect_commit",
    "release",
    "status",
    "steps",
    "state_before",
    "state_after",
}
RECORD_KEYS_V3 = RECORD_KEYS_V2 | {"trigger", "previous_evidence"}
EVIDENCE_NAME = re.compile(r"^[A-Za-z0-9._-]+\.json$")
SHA256 = re.compile(r"^[0-9a-f]{64}$")


def fail(message):
    print(f"verify-live-soak: {message}", file=sys.stderr)
    raise SystemExit(1)


def requirement(value):
    host, separator, role = value.rpartition(":")
    if not separator or not HOST.fullmatch(host) or role not in {"leader", "follower"}:
        raise argparse.ArgumentTypeError("expected HOST:leader or HOST:follower")
    return host, role


def read_record(path):
    if path.is_symlink():
        fail(f"symlink evidence is forbidden: {path.name}")
    if not path.is_file() or stat.S_IMODE(path.stat().st_mode) != 0o600:
        fail(f"evidence must be a regular mode 0600 file: {path.name}")
    try:
        raw = path.read_bytes()
        record = json.loads(raw)
    except (OSError, json.JSONDecodeError) as error:
        fail(f"invalid evidence {path.name}: {error}")
    if not isinstance(record, dict) or record.get("schema") not in {2, 3}:
        fail(f"invalid evidence schema: {path.name}")
    expected_keys = RECORD_KEYS_V2 if record["schema"] == 2 else RECORD_KEYS_V3
    if set(record) != expected_keys:
        fail(f"invalid evidence schema: {path.name}")
    if record["schema"] == 3:
        if record["trigger"] not in {"manual", "scheduled"}:
            fail(f"invalid evidence trigger: {path.name}")
        previous = record["previous_evidence"]
        if previous is not None and (
            not isinstance(previous, dict)
            or set(previous) != {"name", "sha256"}
            or not EVIDENCE_NAME.fullmatch(str(previous["name"]))
            or not SHA256.fullmatch(str(previous["sha256"]))
        ):
            fail(f"invalid previous evidence link: {path.name}")
    try:
        timestamp = datetime.datetime.fromisoformat(record["timestamp"])
    except (TypeError, ValueError):
        fail(f"invalid evidence timestamp: {path.name}")
    if timestamp.tzinfo is None or timestamp.utcoffset() != datetime.timedelta(0):
        fail(f"evidence timestamp must be UTC: {path.name}")
    validate_snapshot(record["state_before"], path)
    validate_snapshot(record["state_after"], path)
    return record, timestamp, hashlib.sha256(raw).hexdigest()


def validate_snapshot(snapshot_value, path):
    if not isinstance(snapshot_value, dict) or not snapshot_value:
        fail(f"invalid credential state metadata: {path.name}")
    for metadata in snapshot_value.values():
        if not isinstance(metadata, dict) or metadata.get("exists") not in {True, False}:
            fail(f"invalid credential state metadata: {path.name}")
        expected = {"exists"} if metadata["exists"] is False else {
            "exists", "size", "mtime_ns", "ctime_ns", "inode", "mode",
        }
        if set(metadata) != expected:
            fail(f"invalid credential state metadata: {path.name}")
        if metadata["exists"] is True:
            if any(
                not isinstance(metadata[name], int) or isinstance(metadata[name], bool) or metadata[name] < 0
                for name in ("size", "mtime_ns", "ctime_ns", "inode")
            ) or not re.fullmatch(r"0[0-7]{3}", str(metadata["mode"])):
                fail(f"invalid credential state metadata: {path.name}")


def successful_steps(record, path):
    expected = ["verify-release", "publish"] if record["role"] == "leader" else [
        "verify-release", "pull", "check",
    ]
    steps = record["steps"]
    if not isinstance(steps, list) or len(steps) != len(expected):
        fail(f"invalid successful steps: {path.name}")
    for step, name in zip(steps, expected):
        if (
            not isinstance(step, dict)
            or set(step) != {"name", "returncode"}
            or step["name"] != name
            or step["returncode"] != 0
        ):
            fail(f"invalid successful steps: {path.name}")


def main():
    parser = argparse.ArgumentParser(
        description="Verify consecutive, converged cross-host live-canary evidence."
    )
    parser.add_argument("--evidence-dir", required=True, type=pathlib.Path)
    parser.add_argument("--profile", required=True)
    parser.add_argument("--expect-commit", required=True)
    parser.add_argument("--days", type=int, default=30)
    parser.add_argument(
        "--through",
        default=str(datetime.datetime.now(datetime.timezone.utc).date() - datetime.timedelta(days=1)),
    )
    parser.add_argument("--require", action="append", required=True, type=requirement)
    args = parser.parse_args()

    if args.evidence_dir.is_symlink() or not args.evidence_dir.is_dir():
        fail("evidence_dir must be an existing, non-symlink directory")
    if not PROFILE.fullmatch(args.profile):
        fail("profile must be named canary-*")
    if not COMMIT.fullmatch(args.expect_commit):
        fail("expect_commit must be a full lowercase commit SHA")
    if args.days < 1 or args.days > 365:
        fail("days must be between 1 and 365")
    try:
        through = datetime.date.fromisoformat(args.through)
    except ValueError:
        fail("through must be an ISO date")

    requirements = sorted(set(args.require))
    start = through - datetime.timedelta(days=args.days - 1)
    entries = []
    by_name = {}
    for path in sorted(args.evidence_dir.glob("*.json")):
        record, timestamp, digest = read_record(path)
        entries.append((path, record, timestamp, digest))
        by_name[path.name] = (path, record, timestamp, digest)

    present = set()
    histories = {}
    records = 0
    selected_release = None
    for path, record, timestamp, _digest in entries:
        day = timestamp.date()
        if day < start or day > through:
            continue
        if record["kind"] != "claude" or record["profile"] != args.profile:
            fail(f"profile mismatch: {path.name}")
        if record["expect_commit"] != args.expect_commit:
            fail(f"commit mismatch: {path.name}")
        release = record["release"]
        if (
            not isinstance(release, str)
            or not RELEASE.fullmatch(release)
            or not release.startswith(f"{args.expect_commit[:12]}-")
        ):
            fail(f"invalid release: {path.name}")
        if selected_release is None:
            selected_release = release
        elif release != selected_release:
            fail(f"release mismatch: {path.name}")
        host = record["host"]
        role = record["role"]
        if not isinstance(host, str) or not HOST.fullmatch(host) or role not in {"leader", "follower"}:
            fail(f"invalid host or role: {path.name}")
        if record["status"] != "ok":
            fail(f"failed canary evidence: {path.name}")
        successful_steps(record, path)
        if record["schema"] != 3:
            fail(f"scheduled provenance missing: {path.name}")
        if record["trigger"] == "scheduled":
            present.add((day, host, role))
        histories.setdefault((host, role), []).append((timestamp, path, record))
        records += 1

    for offset in range(args.days):
        day = start + datetime.timedelta(days=offset)
        for host, role in requirements:
            if (day, host, role) not in present:
                fail(f"missing evidence: {day} {host}:{role}")

    for history in histories.values():
        ordered = sorted(history, key=lambda item: (item[0], item[1].name))
        for previous, current in zip(ordered, ordered[1:]):
            if previous[2]["state_after"] != current[2]["state_before"]:
                fail(f"writer continuity mismatch: {current[1].name}")

    for host, role in requirements:
        anchors = [
            (path, record, timestamp)
            for path, record, timestamp, _digest in entries
            if timestamp.date() > through
            and record.get("schema") == 3
            and record.get("host") == host
            and record.get("role") == role
            and record.get("kind") == "claude"
            and record.get("profile") == args.profile
            and record.get("expect_commit") == args.expect_commit
            and record.get("release") == selected_release
            and record.get("trigger") == "scheduled"
            and record.get("status") == "ok"
        ]
        if not anchors:
            fail(f"missing post-window anchor: {host}:{role}")
        successful_steps(anchors[0][1], anchors[0][0])

    chain_histories = {}
    for entry in entries:
        path, record, timestamp, _digest = entry
        chain_histories.setdefault((record.get("host"), record.get("role")), []).append(entry)
        if record.get("schema") != 3:
            continue
        previous = record["previous_evidence"]
        if previous is None:
            continue
        target = by_name.get(previous["name"])
        if target is None:
            fail(f"missing chained evidence: {previous['name']}")
        if target[3] != previous["sha256"]:
            fail(f"chained evidence hash mismatch: {previous['name']}")
        if (
            target[1].get("host") != record.get("host")
            or target[1].get("role") != record.get("role")
            or target[1].get("profile") != record.get("profile")
            or target[2] >= timestamp
        ):
            fail(f"invalid chained evidence predecessor: {path.name}")

    for history in chain_histories.values():
        ordered = sorted(history, key=lambda item: (item[2], item[0].name))
        for index, current in enumerate(ordered):
            if current[1].get("schema") != 3:
                continue
            previous = current[1]["previous_evidence"]
            expected = None if index == 0 else ordered[index - 1][0].name
            actual = None if previous is None else previous["name"]
            if actual != expected:
                fail(f"nonconsecutive evidence chain: {current[0].name}")

    print(json.dumps({
        "status": "ok",
        "profile": args.profile,
        "commit": args.expect_commit,
        "release": selected_release,
        "from": str(start),
        "through": str(through),
        "days": args.days,
        "requirements": [f"{host}:{role}" for host, role in requirements],
        "records": records,
    }, separators=(",", ":"), sort_keys=True))


if __name__ == "__main__":
    main()
